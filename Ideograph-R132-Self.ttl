        :eq g2.gb2312:0x5754          ; # &g2-AJ1-02263;
        :eq g2.ks-x1001:0x6D3B        ; # &g2-AJ1-02263;
        :eq g2.jis-x0208:0x3C2B       ; # &g2-AJ1-02263;
