    :eq rep.gt-pj-1:15403         ; # &I-GT-38936;
    :eq rep.daikanwa:30095        ; # &I-M-30095;
    :eq rep.shinjigen:6598        ; # 自
    :subsume
        g2.ucs_unicode:0x81EA ,
        repi.hng-khm:04960   ,
        repi.hng-khi:05350   ;
    .
