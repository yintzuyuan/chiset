a.ucs:0x81EA
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x81EA ;
    ideo:radical         132 ; # ⾃ 
    ideo:strokes           0 ;
    ideo:total-strokes     6 ;
    :eq rep.adobe-japan1-0:02263  ; # &I-AJ1-02263;
    :eq rep.jis-x0208:0x3C2B      ; # &I-J90-3C2B;
    :eq rep.gb2312:0x5754         ; # &I-G0-5754;
    :eq rep.ks-x1001:0x6D3B       ; # &I-K0-6D3B;
    :eq rep.cns11643-1:0x485C     ; # &I-C1-485C;
    :eq rep.jis-x0213-1:0x3C2B    ; # &I-JX1-3C2B;
    :eq a.big5:0xA6DB             ; # &I-B-A6DB;
