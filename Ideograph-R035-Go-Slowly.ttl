a.ucs_component:0x590A
    a chisegg:abstract-character ;
    :abstract-character-of [ :context domain:component ;
                             :target     ucs:0x590A  ] ;
    ideo:radical          35 ; # ⼢ 
    ideo:strokes           0 ;
    ideo:total-strokes     3 ;
    :eq a.iwds-1:0092             ; # &IWDS1-092;
    .
    a.iwds-1:0092
           :abstract-character-of         iwds-1:0092    .

a.ucs:0x590A
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x590A ;
    :from.denotational_component
        a.ucs_component:0x590A ;
    ideo:radical          35 ; # ⼢ 
    ideo:strokes           0 ;
    ideo:total-strokes     3 ;
    ideo:hanyu-dazidian  ( 2 867 16 ) ;
    :eq rep.adobe-japan1-0:04539  ; # &I-AJ1-04539;
    :eq rep.jis-x0208:0x546A      ; # &I-J90-546A;
    :eq rep.cns11643-3:0x213A     ; # &I-C3-213A;
    :eq rep.jis-x0213-1:0x546A    ; # &I-JX1-546A;
    :eq rep.big5-cdp:0x8A71       ; # &I-CDP-8A71;
    :eq rep.gt:07225              ; # &I-GT-07225;
    :eq rep.gt-pj-1:21610         ; # &I-GT-07225;
    :eq rep.daikanwa:05708        ; # &I-M-05708;
    :eq rep.shinjigen:1538        ; # 夊
    :subsume
        g2.adobe-japan1-0:04539 ,
        g2.ucs_unicode:0x590A ;
    .
    rep.adobe-japan1-0:04539
               :abstract-glyph-of adobe-japan1-0:04539   .
    rep.jis-x0208:0x546A
               :abstract-glyph-of      jis-x0208:0x546A  .
    rep.cns11643-3:0x213A
               :abstract-glyph-of     cns11643-3:0x213A  .
    rep.jis-x0213-1:0x546A
               :abstract-glyph-of    jis-x0213-1:0x546A  .
    rep.big5-cdp:0x8A71
               :abstract-glyph-of       big5-cdp:0x8A71  .
    rep.gt:07225
               :abstract-glyph-of             gt:07225   .
    rep.gt-pj-1:21610
               :abstract-glyph-of        gt-pj-1:21610   .
    rep.daikanwa:05708
               :abstract-glyph-of       daikanwa:05708   .
    rep.shinjigen:1538
               :abstract-glyph-of      shinjigen:1538    .
    g2.adobe-japan1-0:04539
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of adobe-japan1-0:04539 ;
        :rep.decomposition   [ :context domain:cid     ;
                               :target  a.ucs:0x590A         ,
                                        a.ucs:0xE0100        ] ;
        :eq g2.ucs_jis:0x590A         ; # &g2-AJ1-04539;
        :eq g2.jis-x0208:0x546A       ; # &g2-AJ1-04539;
        :eq g2.jis-x0213-1:0x546A     ; # &g2-AJ1-04539;
        :eq g2.gt:07225               ; # &g2-AJ1-04539;
        :eq g2.daikanwa:05708         ; # &g2-AJ1-04539;
        :eq g2.shinjigen:1538         ; # &g2-AJ1-04539;
        :subsume
            repi.daikanwa:05708  ,
            repi.jis-x0208:0x546A ,
            repi.adobe-japan1-6:04539 ,
            repi.gt:07225        ;
        .
        g2.ucs_jis:0x590A
              :abstract-glyph-form-of [ :context domain:jis     ;
                                        :target     ucs:0x590A  ] .
        g2.jis-x0208:0x546A
              :abstract-glyph-form-of      jis-x0208:0x546A  .
        g2.jis-x0213-1:0x546A
              :abstract-glyph-form-of    jis-x0213-1:0x546A  .
        g2.gt:07225
              :abstract-glyph-form-of             gt:07225   .
        g2.daikanwa:05708
              :abstract-glyph-form-of       daikanwa:05708   .
        g2.shinjigen:1538
              :abstract-glyph-form-of      shinjigen:1538    .
        repi.daikanwa:05708
            a chisegg:glyph-image ;
            :glyph-image-of daikanwa:05708 ;
            .
        repi.jis-x0208:0x546A
            a chisegg:glyph-image ;
            :glyph-image-of jis-x0208:0x546A ;
            :eq repi.jis-x0213-1:0x546A   ; # &R-J0-546A;
            .
            repi.jis-x0213-1:0x546A
                          :glyph-image-of    jis-x0213-1:0x546A  .
        repi.adobe-japan1-0:04539
            a chisegg:glyph-image ;
            :glyph-image-of adobe-japan1-0:04539 ;
            .
        repi.gt:07225
            a chisegg:glyph-image ;
            :glyph-image-of gt:07225 ;
            .
    g2.ucs_unicode:0x590A
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of [ :context domain:unicode ;
                                  :target     ucs:0x590A  ] ;
        :g2.ucs_JP...hanazono      rdf:nil ;
        :eq g2.cns11643-3:0x213A      ; # &g2-CDP-8A71;
        :eq g2.big5-cdp:0x8A71        ; # &g2-CDP-8A71;
        :subsume
            repi.cns11643-3:0x213A ,
            repi.big5-cdp:0x8A71 ,
            repi.ucs_unicode:0x590A ;
        .
        g2.cns11643-3:0x213A
              :abstract-glyph-form-of     cns11643-3:0x213A  .
        g2.big5-cdp:0x8A71
              :abstract-glyph-form-of       big5-cdp:0x8A71  .
        repi.cns11643-3:0x213A
            a chisegg:glyph-image ;
            :glyph-image-of cns11643-3:0x213A ;
            .
        repi.big5-cdp:0x8A71
            a chisegg:glyph-image ;
            :glyph-image-of big5-cdp:0x8A71 ;
            .
        repi.ucs_unicode:0x590A
            a chisegg:glyph-image ;
            :glyph-image-of [ :context domain:unicode ;
                              :target     ucs:0x590A  ] ;
            .

