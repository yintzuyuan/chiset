a.iwds-1:0007
    a chisegg:abstract-character ;
    :abstract-character-of iwds-1:0007 ;
    ideo:radical          63 ; # ⼾ 
    ideo:strokes           0 ;
    ideo:total-strokes     4 ;
    :eq a.daikanwa:11696          ; # &IWDS1-007;
    .
    a.daikanwa:11696
           :abstract-character-of       daikanwa:11696   .

a.ucs:0x6236
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x6236 ;
    :denotation-of
        a.iwds-1:0007        ;
    ideo:radical          63 ; # ⼾ 
    ideo:strokes           0 ;
    ideo:total-strokes     4 ;
    :eq rep.ks-x1001:0x7B42       ; # &I-K0-7B42;
    :eq rep.cns11643-1:0x4542     ; # &I-C1-4542;
    :eq a.big5:0xA4E1             ; # &I-B-A4E1;
    :eq rep.daikanwa:11696        ; # &I-M-11696;
    :eq rep.jef-china3:0x4EFA     ; # &I-JC3-4EFA;
    .
    rep.ks-x1001:0x7B42
               :abstract-glyph-of       ks-x1001:0x7B42  .
