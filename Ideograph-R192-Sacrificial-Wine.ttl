a.ucs:0x9B2F
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x9B2F ;
    ideo:radical         192 ; # ⾿ 
    ideo:strokes           0 ;
    ideo:total-strokes    10 ;
    :eq rep.adobe-japan1-0:07299  ; # &I-AJ1-07299;
    :eq rep.jis-x0208:0x722E      ; # &I-J90-722E;
    :eq rep.gb2312:0x5B4B         ; # &I-G0-5B4B;
    :eq rep.cns11643-2:0x334D     ; # &I-C2-334D;
    :eq rep.jis-x0213-1:0x722E    ; # &I-JX1-722E;
    :eq rep.gt:61419              ; # &I-GT-61419;
    :eq rep.gt-k:06656            ; # &I-GT-K06656;
    :eq rep.gt-pj-1:29230         ; # &I-GT-61419;
    :eq rep.daikanwa:45661        ; # &I-M-45661;
    :eq rep.shinjigen:9502        ; # 鬯
    :subsume
        g2.ucs_unicode:0x9B2F ;
    .
    rep.adobe-japan1-0:07299
               :abstract-glyph-of adobe-japan1-0:07299   .
    rep.jis-x0208:0x722E
               :abstract-glyph-of      jis-x0208:0x722E  .
    rep.gb2312:0x5B4B
               :abstract-glyph-of         gb2312:0x5B4B  .
    rep.cns11643-2:0x334D
               :abstract-glyph-of     cns11643-2:0x334D  .
    rep.jis-x0213-1:0x722E
               :abstract-glyph-of    jis-x0213-1:0x722E  .
    rep.gt:61419
               :abstract-glyph-of             gt:61419   .
    rep.gt-k:06656
               :abstract-glyph-of           gt-k:06656   .
    rep.gt-pj-1:29230
               :abstract-glyph-of        gt-pj-1:29230   .
    rep.daikanwa:45661
               :abstract-glyph-of       daikanwa:45661   .
    rep.shinjigen:9502
               :abstract-glyph-of      shinjigen:9502    .
    g2.ucs_unicode:0x9B2F
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of [ :context domain:unicode ;
                                  :target     ucs:0x9B2F  ] ;
        :eq g2.adobe-japan1-0:07299   ; # &g2-AJ1-07299;
        :eq g2.gb2312:0x5B4B          ; # &g2-AJ1-07299;
        :eq g2.jis-x0208:0x722E       ; # &g2-AJ1-07299;
        :eq g2.cns11643-2:0x334D      ; # &g2-AJ1-07299;
        :eq g2.jis-x0213-1:0x722E     ; # &g2-AJ1-07299;
        :eq g2.gt:61419               ; # &g2-AJ1-07299;
        :eq g2.gt-k:06656             ; # &g2-AJ1-07299;
        :eq g2.daikanwa:45661         ; # &g2-AJ1-07299;
        :eq g2.shinjigen:9502         ; # &g2-AJ1-07299;
        :subsume
            repi.daikanwa:45661  ,
            repi.jis-x0208:0x722E ,
            repi.adobe-japan1-6:07299 ,
            repi.cns11643-2:0x334D ,
            repi.gt:61419        ,
            repi.ucs_unicode:0x9B2F ;
        .
        g2.adobe-japan1-0:07299
              :abstract-glyph-form-of adobe-japan1-0:07299   .
        g2.gb2312:0x5B4B
              :abstract-glyph-form-of         gb2312:0x5B4B  .
        g2.jis-x0208:0x722E
              :abstract-glyph-form-of      jis-x0208:0x722E  .
        g2.cns11643-2:0x334D
              :abstract-glyph-form-of     cns11643-2:0x334D  .
        g2.jis-x0213-1:0x722E
              :abstract-glyph-form-of    jis-x0213-1:0x722E  .
        g2.gt:61419
              :abstract-glyph-form-of             gt:61419   .
        g2.gt-k:06656
              :abstract-glyph-form-of           gt-k:06656   .
        g2.daikanwa:45661
              :abstract-glyph-form-of       daikanwa:45661   .
        g2.shinjigen:9502
              :abstract-glyph-form-of      shinjigen:9502    .
        repi.daikanwa:45661
            a chisegg:glyph-image ;
            :glyph-image-of daikanwa:45661 ;
            .
        repi.jis-x0208:0x722E
            a chisegg:glyph-image ;
            :glyph-image-of jis-x0208:0x722E ;
            :eq repi.jis-x0213-1:0x722E   ; # &R-J0-722E;
            .
            repi.jis-x0213-1:0x722E
                          :glyph-image-of    jis-x0213-1:0x722E  .
        repi.adobe-japan1-0:07299
            a chisegg:glyph-image ;
            :glyph-image-of adobe-japan1-0:07299 ;
            .
        repi.cns11643-2:0x334D
            a chisegg:glyph-image ;
            :glyph-image-of cns11643-2:0x334D ;
            .
        repi.gt:61419
            a chisegg:glyph-image ;
            :glyph-image-of gt:61419 ;
            :eq repi.gt-k:06656           ; # &R-GT-61419;
            .
            repi.gt-k:06656
                          :glyph-image-of           gt-k:06656   .
        repi.ucs_unicode:0x9B2F
            a chisegg:glyph-image ;
            :glyph-image-of [ :context domain:unicode ;
                              :target     ucs:0x9B2F  ] ;
            .

