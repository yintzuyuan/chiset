a.ucs:0x884C
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x884C ;
    ideo:radical         144 ; # ⾏ 
    ideo:strokes           0 ;
    ideo:total-strokes     6 ;
    :eq rep.adobe-japan1-0:02022  ; # &I-AJ1-02022;
    :eq rep.jis-x0208:0x3954      ; # &I-J90-3954;
    :eq rep.gb2312:0x5050         ; # &I-G0-5050;
    :eq rep.ks-x1001:0x7A3C       ; # &I-K0-7A3C;
    :eq rep.cns11643-1:0x4867     ; # &I-C1-4867;
    :eq rep.jis-x0213-1:0x3954    ; # &I-JX1-3954;
    :eq a.big5:0xA6E6             ; # &I-B-A6E6;
    :eq rep.gt:45899              ; # &I-GT-45899;
    :eq rep.gt-k:01612            ; # &I-GT-K01612;
    :eq rep.gt-pj-1:14676         ; # &I-GT-45899;
    :eq rep.daikanwa:34029        ; # &I-M-34029;
    :eq rep.shinjigen:7321        ; # 行
    :subsume
        g2.ucs_unicode:0x884C ,
        repi.hng-khi:05560   ,
        repi.hng-kar:12440   ;
    .
    rep.adobe-japan1-0:02022
               :abstract-glyph-of adobe-japan1-0:02022   .
    rep.jis-x0208:0x3954
               :abstract-glyph-of      jis-x0208:0x3954  .
    rep.gb2312:0x5050
               :abstract-glyph-of         gb2312:0x5050  .
    rep.ks-x1001:0x7A3C
               :abstract-glyph-of       ks-x1001:0x7A3C  .
    rep.cns11643-1:0x4867
               :abstract-glyph-of     cns11643-1:0x4867  .
    rep.jis-x0213-1:0x3954
               :abstract-glyph-of    jis-x0213-1:0x3954  .
    a.big5:0xA6E6
           :abstract-character-of           big5:0xA6E6  .
    rep.gt:45899
               :abstract-glyph-of             gt:45899   .
    rep.gt-k:01612
               :abstract-glyph-of           gt-k:01612   .
    rep.gt-pj-1:14676
               :abstract-glyph-of        gt-pj-1:14676   .
    rep.daikanwa:34029
               :abstract-glyph-of       daikanwa:34029   .
    rep.shinjigen:7321
               :abstract-glyph-of      shinjigen:7321    .
    g2.ucs_unicode:0x884C
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of [ :context domain:unicode ;
                                  :target     ucs:0x884C  ] ;
        :eq g2.adobe-japan1-0:02022   ; # &g2-AJ1-02022;
        :eq g2.gb2312:0x5050          ; # &g2-AJ1-02022;
        :eq g2.ks-x1001:0x7A3C        ; # &g2-AJ1-02022;
        :eq g2.jis-x0208:0x3954       ; # &g2-AJ1-02022;
        :eq g2.cns11643-1:0x4867      ; # &g2-AJ1-02022;
        :eq g2.jis-x0213-1:0x3954     ; # &g2-AJ1-02022;
        :eq g2.gt:45899               ; # &g2-AJ1-02022;
        :eq g2.gt-k:01612             ; # &g2-AJ1-02022;
        :eq g2.daikanwa:34029         ; # &g2-AJ1-02022;
        :eq g2.shinjigen:7321         ; # &g2-AJ1-02022;
        :subsume
            repi.daikanwa:34029  ,
            repi.jis-x0208:0x3954 ,
            repi.adobe-japan1-6:02022 ,
            repi.cns11643-1:0x4867 ,
