a.ucs:0x9ADF
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x9ADF ;
    ideo:radical         190 ; # ⾽ 
    ideo:strokes           0 ;
    ideo:total-strokes    10 ;
    isd:structure [ a idc:⿰ ;
        isd:left     a.ucs:0x9578 ; # 镸
        isd:right    a.ucs:0x5F61   # 彡
    ] ;
    :eq rep.adobe-japan1-0:07276  ; # &I-AJ1-07276;
    :eq rep.jis-x0208:0x7175      ; # &I-J90-7175;
    :eq rep.gb2312:0x7754         ; # &I-G0-7754;
    :eq rep.cns11643-2:0x334C     ; # &I-C2-334C;
    :eq rep.jis-x0213-1:0x7175    ; # &I-JX1-7175;
    :eq a.big5:0xD449             ; # &I-B-D449;
    :eq rep.gt:61051              ; # &I-GT-61051;
    :eq rep.gt-k:06654            ; # &I-GT-K06654;
    :eq rep.gt-pj-1:29045         ; # &I-GT-61051;
    :eq rep.daikanwa:45355        ; # &I-M-45355;
    :eq rep.shinjigen:9452        ; # 髟
    :subsume
        g2.ucs_unicode:0x9ADF ;
    .
    rep.adobe-japan1-0:07276
               :abstract-glyph-of adobe-japan1-0:07276   .
    rep.jis-x0208:0x7175
               :abstract-glyph-of      jis-x0208:0x7175  .
    rep.gb2312:0x7754
               :abstract-glyph-of         gb2312:0x7754  .
    rep.cns11643-2:0x334C
               :abstract-glyph-of     cns11643-2:0x334C  .
    rep.jis-x0213-1:0x7175
               :abstract-glyph-of    jis-x0213-1:0x7175  .
    a.big5:0xD449
           :abstract-character-of           big5:0xD449  .
    rep.gt:61051
               :abstract-glyph-of             gt:61051   .
    rep.gt-k:06654
               :abstract-glyph-of           gt-k:06654   .
    rep.gt-pj-1:29045
               :abstract-glyph-of        gt-pj-1:29045   .
    rep.daikanwa:45355
               :abstract-glyph-of       daikanwa:45355   .
    rep.shinjigen:9452
               :abstract-glyph-of      shinjigen:9452    .
    g2.ucs_unicode:0x9ADF
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of [ :context domain:unicode ;
                                  :target     ucs:0x9ADF  ] ;
        :eq g2.adobe-japan1-0:07276   ; # &g2-AJ1-07276;
        :eq g2.gb2312:0x7754          ; # &g2-AJ1-07276;
        :eq g2.jis-x0208:0x7175       ; # &g2-AJ1-07276;
        :eq g2.cns11643-2:0x334C      ; # &g2-AJ1-07276;
        :eq g2.jis-x0213-1:0x7175     ; # &g2-AJ1-07276;
        :eq g2.gt:61051               ; # &g2-AJ1-07276;
        :eq g2.gt-k:06654             ; # &g2-AJ1-07276;
        :eq g2.daikanwa:45355         ; # &g2-AJ1-07276;
        :eq g2.shinjigen:9452         ; # &g2-AJ1-07276;
        :subsume
            repi.daikanwa:45355  ,
            repi.jis-x0208:0x7175 ,
            repi.adobe-japan1-6:07276 ,
            repi.cns11643-2:0x334C ,
            repi.gt:61051        ,
            repi.ucs_unicode:0x9ADF ;
        .
        g2.adobe-japan1-0:07276
              :abstract-glyph-form-of adobe-japan1-0:07276   .
        g2.gb2312:0x7754
              :abstract-glyph-form-of         gb2312:0x7754  .
        g2.jis-x0208:0x7175
              :abstract-glyph-form-of      jis-x0208:0x7175  .
        g2.cns11643-2:0x334C
              :abstract-glyph-form-of     cns11643-2:0x334C  .
        g2.jis-x0213-1:0x7175
              :abstract-glyph-form-of    jis-x0213-1:0x7175  .
        g2.gt:61051
              :abstract-glyph-form-of             gt:61051   .
        g2.gt-k:06654
              :abstract-glyph-form-of           gt-k:06654   .
        g2.daikanwa:45355
              :abstract-glyph-form-of       daikanwa:45355   .
        g2.shinjigen:9452
              :abstract-glyph-form-of      shinjigen:9452    .
        repi.daikanwa:45355
            a chisegg:glyph-image ;
            :glyph-image-of daikanwa:45355 ;
            .
        repi.jis-x0208:0x7175
            a chisegg:glyph-image ;
            :glyph-image-of jis-x0208:0x7175 ;
            :eq repi.jis-x0213-1:0x7175   ; # &R-J0-7175;
            .
            repi.jis-x0213-1:0x7175
                          :glyph-image-of    jis-x0213-1:0x7175  .
        repi.adobe-japan1-0:07276
            a chisegg:glyph-image ;
            :glyph-image-of adobe-japan1-0:07276 ;
            .
        repi.cns11643-2:0x334C
            a chisegg:glyph-image ;
            :glyph-image-of cns11643-2:0x334C ;
            .
        repi.gt:61051
            a chisegg:glyph-image ;
            :glyph-image-of gt:61051 ;
            :eq repi.gt-k:06654           ; # &R-GT-61051;
            .
            repi.gt-k:06654
                          :glyph-image-of           gt-k:06654   .
        repi.ucs_unicode:0x9ADF
            a chisegg:glyph-image ;
            :glyph-image-of [ :context domain:unicode ;
                              :target     ucs:0x9ADF  ] ;
            .

