bucs:0x97CB
    a chisegg:super-abstract-character ;
    :super-abstract-character-of [ :context domain:bucs    ;
                                   :target     ucs:0x97CB  ] ;
    ideo:radical         178 ; # ⾱ 
    .

a.ucs:0x97CB
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x97CB ;
    :denotation-of
        bucs:0x97CB          ;
    ideo:radical         178 ; # ⾱ 
    ideo:strokes           0 ;
    isd:structure [ a idc:⿳ ;
        isd:above    a.ucs:0x2B740 ; # 𫝀
        isd:middle   a.ucs:0x53E3 ; # 口
        isd:below    a.ucs:0x3404   # 㐄
    ] ;
    :eq rep.mj:028060             ; # &I-MJ028060;
    :eq rep.adobe-japan1-0:07171  ; # &I-AJ1-07171;
    :eq rep.jis-x0208:0x706A      ; # &I-J90-706A;
    :eq rep.ks-x1001:0x6A5F       ; # &I-K0-6A5F;
    :eq rep.cns11643-1:0x5374     ; # &I-C1-5374;
    :eq rep.jis-x0213-1:0x706A    ; # &I-JX1-706A;
    :eq rep.gb12345:0x4E24        ; # 韋
    :eq a.big5:0xADB3             ; # &I-B-ADB3;
    :eq rep.hanyo-denshi...ja:0x706A ; # &I-HD-JA-706A;
    :eq rep.gt:57813              ; # &I-GT-57813;
    :eq rep.gt-k:06734            ; # &I-GT-K06734;
    :eq rep.gt-pj-1:28778         ; # &I-GT-57813;
    :eq rep.daikanwa:43108        ; # &I-M-43108;
    :eq rep.shinjigen:9106        ; # 韋
    :subsume
        rep.gt:57812         ,
        a.jis-x0208:0x706A   ;
    .
    rep.mj:028060
               :abstract-glyph-of             mj:028060  .
    rep.adobe-japan1-0:07171
               :abstract-glyph-of adobe-japan1-0:07171   .
    rep.jis-x0208:0x706A
               :abstract-glyph-of      jis-x0208:0x706A  .
    rep.ks-x1001:0x6A5F
               :abstract-glyph-of       ks-x1001:0x6A5F  .
    rep.cns11643-1:0x5374
               :abstract-glyph-of     cns11643-1:0x5374  .
    rep.jis-x0213-1:0x706A
               :abstract-glyph-of    jis-x0213-1:0x706A  .
    rep.gb12345:0x4E24
               :abstract-glyph-of        gb12345:0x4E24  .
    a.big5:0xADB3
           :abstract-character-of           big5:0xADB3  .
    rep.hanyo-denshi...ja:0x706A
               :abstract-glyph-of hanyo-denshi...ja:0x706A  .
    rep.gt:57813
               :abstract-glyph-of             gt:57813   .
    rep.gt-k:06734
               :abstract-glyph-of           gt-k:06734   .
    rep.gt-pj-1:28778
               :abstract-glyph-of        gt-pj-1:28778   .
    rep.daikanwa:43108
               :abstract-glyph-of       daikanwa:43108   .
    rep.shinjigen:9106
               :abstract-glyph-of      shinjigen:9106    .
    rep.gt:57812
        a chisegg:abstract-glyph ;
        :abstract-glyph-of gt:57812 ;
        ideo:total-strokes     9 ;
        :eq g.ucs_unicode:0x97CB      ; # &GT-57812;
        :eq rep.gt-pj-8:15473         ; # &GT-57812;
        :eq g.daikanwa:43108          ; # &GT-57812;
        :subsume
            g2.ucs_unicode:0x97CB ,
            g2.shinjigen:9106    ,
            g2.cns11643-1:0x5374 ;
        .
        g.ucs_unicode:0x97CB
                   :detailed-glyph-of [ :context domain:unicode ;
                                        :target     ucs:0x97CB  ] .
        rep.gt-pj-8:15473
                   :abstract-glyph-of        gt-pj-8:15473   .
        g.daikanwa:43108
                   :detailed-glyph-of       daikanwa:43108   .
        g2.ucs_unicode:0x97CB
            a chisegg:abstract-glyph-form ;
            :abstract-glyph-form-of [ :context domain:unicode ;
                                      :target     ucs:0x97CB  ] ;
            :g2.ucs_JP...hanazono      rdf:nil ;
            :eq g2.gb12345:0x4E24         ; # &g2-GT-57812;
            :eq g2.gt:57812               ; # &g2-GT-57812;
            :eq g2.daikanwa:43108         ; # &g2-GT-57812;
            :subsume
                repi.daikanwa:43108  ,
                repi.gt:57812        ,
                repi.ucs_unicode:0x97CB ;
            .
            g2.gb12345:0x4E24
                  :abstract-glyph-form-of        gb12345:0x4E24  .
            g2.gt:57812
                  :abstract-glyph-form-of             gt:57812   .
            g2.daikanwa:43108
                  :abstract-glyph-form-of       daikanwa:43108   .
            repi.daikanwa:43108
                a chisegg:glyph-image ;
                :glyph-image-of daikanwa:43108 ;
                .
            repi.gt:57812
                a chisegg:glyph-image ;
                :glyph-image-of gt:57812 ;
                .
            repi.ucs_unicode:0x97CB
                a chisegg:glyph-image ;
                :glyph-image-of [ :context domain:unicode ;
                                  :target     ucs:0x97CB  ] ;
                .
        g2.shinjigen:9106
            a chisegg:abstract-glyph-form ;
            :abstract-glyph-form-of shinjigen:9106 ;
            .
        g2.cns11643-1:0x5374
            a chisegg:abstract-glyph-form ;
            :abstract-glyph-form-of cns11643-1:0x5374 ;
            :eq g2.ucs_cns:0x97CB         ; # &g2-CU+97CB;
            .
            g2.ucs_cns:0x97CB
                  :abstract-glyph-form-of [ :context domain:cns     ;
                                            :target     ucs:0x97CB  ] .
    a.jis-x0208:0x706A
        a chisegg:abstract-character ;
        :abstract-character-of jis-x0208:0x706A ;
