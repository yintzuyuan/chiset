a.ucs:0x91C7
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x91C7 ;
    ideo:radical         165 ; # ⾤ 
    ideo:strokes           1 ;
    ideo:total-strokes     8 ;
    isd:structure [ a idc:⿱ ;
        isd:above    a.ucs:0x722B ; # 爫
        isd:below    a.ucs:0x6728   # 木
