rep.gt:53945
    a chisegg:abstract-glyph ;
    :abstract-glyph-of gt:53945 ;
    :denotation-of
        a.ucs:0x91C7         ;
    ideo:radical         165 ; # ⾤ 
    ideo:strokes           1 ;
    ideo:total-strokes     8 ;
    isd:structure [ a idc:⿱ ;
        isd:above    rep.jis-x0213-2:0x702A ; # &GT-25225;
        isd:below    a.ucs:0x6728   # 木
    ] ;
    :eq rep.jis-x0208_1978:0x3A53 ; # &HD-FT-3227;
    :eq rep.ks-x1001:0x737A       ; # &I-K0-737A;
    :eq rep.hanyo-denshi...ft:0x3227 ; # &I-HD-FT-3227;
    :eq rep.gt-pj-7:25427         ; # &I-GT-53945;
    :eq rep.daikanwa:40116        ; # &I-M-40116;
    :subsume
        g2.ks-x1001:0x737A   ;
    .
    rep.jis-x0208_1978:0x3A53
               :abstract-glyph-of [ :context domain:1978    ;
                                    :target jis-x0208:0x3A53  ] .
    rep.ks-x1001:0x737A
               :abstract-glyph-of       ks-x1001:0x737A  .
    rep.hanyo-denshi...ft:0x3227
               :abstract-glyph-of hanyo-denshi...ft:0x3227  .
    rep.gt-pj-7:25427
               :abstract-glyph-of        gt-pj-7:25427   .
    rep.daikanwa:40116
               :abstract-glyph-of       daikanwa:40116   .
    g2.ks-x1001:0x737A
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of ks-x1001:0x737A ;
        :rep.decomposition   [ :context domain:hanyo-denshi ;
                               :target  a.ucs:0x91C7         ,
                                        a.ucs:0xE0103        ] ;
        :eq g2.ucs_ks:0x91C7          ; # &g2-HD-FT-3227;
        :eq g2.jis-x0208_1978:0x3A53  ; # &g2-HD-FT-3227;
        :eq g2.hanyo-denshi...ft:0x3227 ; # &g2-HD-FT-3227;
        :eq g2.gt:53945               ; # &g2-HD-FT-3227;
        :eq g2.daikanwa:40116         ; # &g2-HD-FT-3227;
        :subsume
            repi.daikanwa:40116  ,
            repi.jis-x0208_1978:0x3A53 ,
            repi.hanyo-denshi...ft:0x3227 ,
            repi.gt:53945        ,
            repi.ks-x1001:0x737A ;
        .
        g2.ucs_ks:0x91C7
              :abstract-glyph-form-of [ :context domain:ks      ;
                                        :target     ucs:0x91C7  ] .
        g2.jis-x0208_1978:0x3A53
              :abstract-glyph-form-of [ :context domain:1978    ;
                                        :target jis-x0208:0x3A53  ] .
        g2.hanyo-denshi...ft:0x3227
              :abstract-glyph-form-of hanyo-denshi...ft:0x3227  .
        g2.gt:53945
              :abstract-glyph-form-of             gt:53945   .
        g2.daikanwa:40116
              :abstract-glyph-form-of       daikanwa:40116   .
        repi.daikanwa:40116
            a chisegg:glyph-image ;
            :glyph-image-of daikanwa:40116 ;
            .
        repi.jis-x0208_1978:0x3A53
            a chisegg:glyph-image ;
            :glyph-image-of [ :context domain:1978    ;
                              :target jis-x0208:0x3A53  ] ;
            .
        repi.hanyo-denshi...ft:0x3227
            a chisegg:glyph-image ;
            :glyph-image-of hanyo-denshi...ft:0x3227 ;
            .
        repi.gt:53945
            a chisegg:glyph-image ;
