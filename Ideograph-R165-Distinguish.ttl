    :abstract-character-of ucs:0x91C6 ;
    ideo:radical         165 ; # ⾤ 
    ideo:strokes           0 ;
    ideo:total-strokes     7 ;
    :eq rep.adobe-japan1-0:03428  ; # &I-AJ1-03428;
    :eq rep.jis-x0208:0x4850      ; # &I-J90-4850;
    :eq rep.iso-ir165:0x2F7E      ; # &I-EGB-2F7E;
    :eq rep.cns11643-1:0x4B5D     ; # &I-C1-4B5D;
    :eq rep.jis-x0213-1:0x4850    ; # &I-JX1-4850;
    :eq a.big5:0xA8BC             ; # &I-B-A8BC;
    :eq rep.gt:53944              ; # &I-GT-53944;
    :eq rep.gt-k:02637            ; # &I-GT-K02637;
    :eq rep.gt-pj-1:18512         ; # &I-GT-53944;
    :eq rep.daikanwa:40115        ; # &I-M-40115;
    .
    rep.adobe-japan1-0:03428
               :abstract-glyph-of adobe-japan1-0:03428   .
    rep.jis-x0208:0x4850
               :abstract-glyph-of      jis-x0208:0x4850  .
    rep.iso-ir165:0x2F7E
               :abstract-glyph-of      iso-ir165:0x2F7E  .
    rep.cns11643-1:0x4B5D
               :abstract-glyph-of     cns11643-1:0x4B5D  .
    rep.jis-x0213-1:0x4850
               :abstract-glyph-of    jis-x0213-1:0x4850  .
