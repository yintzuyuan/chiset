a.ucs_component:0x51E0
    a chisegg:abstract-character ;
    :abstract-character-of [ :context domain:component ;
                             :target     ucs:0x51E0  ] ;
    ideo:radical          16 ; # ⼏ 
    ideo:strokes           0 ;
    ideo:total-strokes     2 ;
    :eq a.iwds-1:0119             ; # &A-compU+51E0;
    .
    a.iwds-1:0119
           :abstract-character-of         iwds-1:0119    .

a.ucs:0x51E0
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x51E0 ;
    :from.denotational_component
        a.ucs_component:0x51E0 ,
        a.ucs_component:0x5140 ;
    ideo:radical          16 ; # ⼏ 
    ideo:strokes           0 ;
    ideo:total-strokes     2 ;
    ideo:hanyu-dazidian  ( 1 275 19 ) ;
    :eq rep.adobe-japan1-0:04243  ; # &I-AJ1-04243;
    :eq rep.jis-x0208:0x515C      ; # &I-J90-515C;
    :eq rep.gb2312:0x3C38         ; # &I-G0-3C38;
    :eq rep.cns11643-1:0x442D     ; # &I-C1-442D;
    :eq rep.jis-x0213-1:0x515C    ; # &I-JX1-515C;
    :eq a.big5:0xA44C             ; # &I-B-A44C;
    :eq rep.gt:02282              ; # &I-GT-02282;
    :eq rep.gt-k:00084            ; # &I-GT-K00084;
    :eq rep.gt-pj-1:20828         ; # &I-GT-02282;
    :eq rep.daikanwa:01737        ; # &I-M-01737;
    :eq rep.shinjigen:0565        ; # 几
    .
    rep.adobe-japan1-0:04243
               :abstract-glyph-of adobe-japan1-0:04243   .
    rep.jis-x0208:0x515C
               :abstract-glyph-of      jis-x0208:0x515C  .
    rep.gb2312:0x3C38
               :abstract-glyph-of         gb2312:0x3C38  .
    rep.cns11643-1:0x442D
               :abstract-glyph-of     cns11643-1:0x442D  .
    rep.jis-x0213-1:0x515C
               :abstract-glyph-of    jis-x0213-1:0x515C  .
    a.big5:0xA44C
           :abstract-character-of           big5:0xA44C  .
    rep.gt:02282
               :abstract-glyph-of             gt:02282   .
    rep.gt-k:00084
               :abstract-glyph-of           gt-k:00084   .
    rep.gt-pj-1:20828
               :abstract-glyph-of        gt-pj-1:20828   .
    rep.daikanwa:01737
               :abstract-glyph-of       daikanwa:01737   .
    rep.shinjigen:0565
               :abstract-glyph-of      shinjigen:0565    .

a.ucs:0x2E87
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x2E87 ;
    :denotation-of
        a.ucs:0x51E0         ;
    :name                 "CJK RADICAL TABLE" ;
    :general-category     "(symbol other)" ; # Informative Category
    :bidi-category        "ON" ;
    :mirrored             "nil" ;
    ideo:total-strokes     2 ;
    :form-of             [ :context domain:component ;
                           :target  a.ucs:0x51E0         ] ;
    :from.identical      [ :context domain:component ;
                           :target  a.ucs:0x20628        ] ;
    .

a.ucs:0x20627
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x20627 ;
    ideo:radical          16 ; # ⼏ 
    ideo:strokes           0 ;
    ideo:total-strokes     2 ;
    :subsume
        rep.daikanwa:01738   ,
        rep.ucs_iso:0x20627  ;
    .
    rep.daikanwa:01738
        a chisegg:abstract-glyph ;
        :abstract-glyph-of daikanwa:01738 ;
        ideo:mistakable      [ :sources chisebib:zihui ,
                                        chisebib:daikanwa ;
                               :target  a.ucs:0x513F         ,
                                        a.ucs:0x51E0         ] ;
        .
    rep.ucs_iso:0x20627
        a chisegg:abstract-glyph ;
        :abstract-glyph-of [ :context domain:iso     ;
                             :target     ucs:0x20627 ] ;
        :eq rep.cns11643-4:0x2129     ; # &C4-2129;
        :eq rep.big5-cdp:0x8AAE       ; # &I-CDP-8AAE;
        .
        rep.cns11643-4:0x2129
                   :abstract-glyph-of     cns11643-4:0x2129  .
        rep.big5-cdp:0x8AAE
                   :abstract-glyph-of       big5-cdp:0x8AAE  .

a.ucs:0x20628
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x20628 ;
    ideo:radical          16 ; # ⼏ 
    ideo:strokes           0 ;
    ideo:total-strokes     2 ;
    :eq rep.jis-x0213-2:0x2332    ; # &I-JX2-2332;
    :eq rep.big5-cdp:0x8D66       ; # &I-CDP-8D66;
    :eq rep.gt:02284              ; # &I-GT-02284;
    :eq rep.gt-k:00086            ; # &I-GT-K00086;
    :eq rep.gt-pj-9:20573         ; # &I-GT-02284;
    :form-of             [ :context domain:component ;
                           :target  a.ucs:0x51E0         ] ;
    .
    rep.jis-x0213-2:0x2332
               :abstract-glyph-of    jis-x0213-2:0x2332  .
    rep.big5-cdp:0x8D66
               :abstract-glyph-of       big5-cdp:0x8D66  .
    rep.gt:02284
               :abstract-glyph-of             gt:02284   .
    rep.gt-k:00086
               :abstract-glyph-of           gt-k:00086   .
    rep.gt-pj-9:20573
               :abstract-glyph-of        gt-pj-9:20573   .

rep.big5-cdp:0x865B
    a chisegg:abstract-glyph ;
    :abstract-glyph-of big5-cdp:0x865B ;
    ideo:radical          16 ; # ⼏ 
    ideo:strokes           0 ;
    ideo:total-strokes     5 ;
    :eq rep.gt-k:01371            ; # &I-GT-K01371;
    :eq rep.gt-pj-k1:19029        ; # &CDP-865B;
    :subsume
        g2.gt-k:01371        ,
        g2.big5-cdp:0x865B   ;
    .
    rep.gt-k:01371
               :abstract-glyph-of           gt-k:01371   .
    rep.gt-pj-k1:19029
               :abstract-glyph-of       gt-pj-k1:19029   .
    g2.gt-k:01371
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of gt-k:01371 ;
        .
    g2.big5-cdp:0x865B
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of big5-cdp:0x865B ;
        .

a.ucs_component:0x51E1
