    :eq rep.gt-k:01016            ; # &I-GT-K01016;
    :eq rep.gt-pj-1:19793         ; # &I-GT-27874;
    :eq rep.daikanwa:21703        ; # &I-M-21703;
    :eq rep.shinjigen:5014        ; # &AJ1-03899;
    :subsume
        g2.ucs_unicode:0x7528 ,
        repi.hng-khi:01150   ;
    .
