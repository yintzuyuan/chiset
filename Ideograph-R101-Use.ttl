        :abstract-glyph-form-of [ :context domain:unicode ;
                                  :target     ucs:0x7528  ] ;
        :eq g2.adobe-japan1-0:03899   ; # &g2-AJ1-03899;
        :eq g2.gb2312:0x5343          ; # &g2-AJ1-03899;
        :eq g2.ks-x1001:0x6944        ; # &g2-AJ1-03899;
        :eq g2.jis-x0208:0x4D51       ; # &g2-AJ1-03899;
