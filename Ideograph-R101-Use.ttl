        a.ucs:0x7528         ;
    ideo:radical         101 ; # ⽤ 
    ideo:strokes           0 ;
    ideo:total-strokes     5 ;
    :eq a.ucs_iwds-1:0x7528       ; # &AJ1-03899;
    :eq rep.ucs_unicode:0x7528    ; # &AJ1-03899;
    :eq rep.jis-x0208:0x4D51      ; # &I-J90-4D51;
