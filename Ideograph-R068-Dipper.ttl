a.ucs:0x6597
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x6597 ;
    ideo:radical          68 ; # ⽃ 
    ideo:strokes           0 ;
    ideo:total-strokes     4 ;
    :eq rep.adobe-japan1-0:03143  ; # &I-AJ1-03143;
    :eq rep.jis-x0208:0x454D      ; # &I-J90-454D;
    :eq rep.gb2312:0x3637         ; # &I-G0-3637;
    :eq rep.ks-x1001:0x5460       ; # &I-K0-5460;
    :eq rep.cns11643-1:0x4547     ; # &I-C1-4547;
    :eq rep.jis-x0213-1:0x454D    ; # &I-JX1-454D;
    :eq a.big5:0xA4E6             ; # &I-B-A4E6;
    :eq rep.gt:17057              ; # &I-GT-17057;
    :eq rep.gt-k:00469            ; # &I-GT-K00469;
    :eq rep.gt-pj-1:17741         ; # &I-GT-17057;
    :eq rep.daikanwa:13489        ; # &I-M-13489;
    :eq rep.shinjigen:3210        ; # 斗
    :subsume
        g2.ucs_unicode:0x6597 ;
    .
    rep.adobe-japan1-0:03143
               :abstract-glyph-of adobe-japan1-0:03143   .
    rep.jis-x0208:0x454D
               :abstract-glyph-of      jis-x0208:0x454D  .
    rep.gb2312:0x3637
               :abstract-glyph-of         gb2312:0x3637  .
    rep.ks-x1001:0x5460
               :abstract-glyph-of       ks-x1001:0x5460  .
    rep.cns11643-1:0x4547
               :abstract-glyph-of     cns11643-1:0x4547  .
    rep.jis-x0213-1:0x454D
               :abstract-glyph-of    jis-x0213-1:0x454D  .
    a.big5:0xA4E6
           :abstract-character-of           big5:0xA4E6  .
    rep.gt:17057
               :abstract-glyph-of             gt:17057   .
    rep.gt-k:00469
               :abstract-glyph-of           gt-k:00469   .
    rep.gt-pj-1:17741
               :abstract-glyph-of        gt-pj-1:17741   .
    rep.daikanwa:13489
               :abstract-glyph-of       daikanwa:13489   .
    rep.shinjigen:3210
               :abstract-glyph-of      shinjigen:3210    .
    g2.ucs_unicode:0x6597
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of [ :context domain:unicode ;
                                  :target     ucs:0x6597  ] ;
        :rep.decomposition   [ :context domain:cid     ;
                               :target  a.ucs:0x6597         ,
                                        a.ucs:0xE0100        ] ;
        :eq g2.adobe-japan1-0:03143   ; # &g2-AJ1-03143;
        :eq g2.gb2312:0x3637          ; # &g2-AJ1-03143;
        :eq g2.ks-x1001:0x5460        ; # &g2-AJ1-03143;
        :eq g2.jis-x0208:0x454D       ; # &g2-AJ1-03143;
        :eq g2.cns11643-1:0x4547      ; # &g2-AJ1-03143;
        :eq g2.jis-x0213-1:0x454D     ; # &g2-AJ1-03143;
        :eq g2.gt:17057               ; # &g2-AJ1-03143;
        :eq g2.gt-k:00469             ; # &g2-AJ1-03143;
        :eq g2.daikanwa:13489         ; # &g2-AJ1-03143;
        :eq g2.shinjigen:3210         ; # &g2-AJ1-03143;
        :subsume
            repi.daikanwa:13489  ,
            repi.jis-x0208:0x454D ,
            repi.adobe-japan1-6:03143 ,
            repi.cns11643-1:0x4547 ,
            repi.gt:17057        ,
            repi.ks-x1001:0x5460 ,
            repi.ucs_unicode:0x6597 ;
        .
        g2.adobe-japan1-0:03143
              :abstract-glyph-form-of adobe-japan1-0:03143   .
        g2.gb2312:0x3637
              :abstract-glyph-form-of         gb2312:0x3637  .
        g2.ks-x1001:0x5460
              :abstract-glyph-form-of       ks-x1001:0x5460  .
        g2.jis-x0208:0x454D
              :abstract-glyph-form-of      jis-x0208:0x454D  .
        g2.cns11643-1:0x4547
