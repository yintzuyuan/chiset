        repi.jis-x0208:0x454D
            a chisegg:glyph-image ;
            :glyph-image-of jis-x0208:0x454D ;
            :eq repi.jis-x0213-1:0x454D   ; # &R-J0-454D;
            .
            repi.jis-x0213-1:0x454D
                          :glyph-image-of    jis-x0213-1:0x454D  .
        repi.adobe-japan1-0:03143
