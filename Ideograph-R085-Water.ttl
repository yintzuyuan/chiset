a.ucs_cognate:0x6C34
    a chisegg:abstract-character ;
    :abstract-character-of [ :context domain:cognate ;
                             :target     ucs:0x6C34  ] ;
    ideo:radical          85 ; # ⽔ 
    ideo:strokes           0 ;
    ideo:total-strokes     4 ;
    :eq a.ucs_component:0x6C34    ; # &A-cgnU+6C34;
    .
    a.ucs_component:0x6C34
           :abstract-character-of [ :context domain:component ;
                                    :target     ucs:0x6C34  ] .

a.ucs:0x6C34
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x6C34 ;
