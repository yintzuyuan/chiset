        :eq g2.gt:21883               ; # &g2-AJ1-02603;
        :eq g2.gt-k:00453             ; # &g2-AJ1-02603;
        :eq g2.daikanwa:17083         ; # &g2-AJ1-02603;
        :eq g2.shinjigen:4049         ; # &g2-AJ1-02603;
