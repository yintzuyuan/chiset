    :eq rep.shinjigen:4049        ; # 水
    :subsume
        g2.ucs_unicode:0x6C34 ,
        repi.hng-khm:00820   ,
        repi.hng-khi:04550   ,
        repi.hng-kar:10180   ;
    .
