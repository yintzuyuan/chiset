a.ucs:0x821B
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x821B ;
    ideo:radical         136 ; # ⾇ 
    ideo:strokes           0 ;
    .

rep.mj:021365
    a chisegg:abstract-glyph ;
    :abstract-glyph-of mj:021365 ;
    :denotation-of
        a.ucs:0x821B         ;
    ideo:radical         136 ; # ⾇ 
    ideo:strokes           0 ;
    isd:structure [ a idc:⿰ ;
        isd:left     a.ucs:0x5915 ; # 夕
        isd:right    a.ucs:0x3404   # 㐄
    ] ;
    :eq a.ucs_iwds-1:0x821B       ; # &MJ021365;
    :eq rep.ucs_unicode:0x821B    ; # &MJ021365;
    :eq rep.adobe-japan1-0:02726  ; # &I-AJ1-02726;
    :eq rep.jis-x0208:0x4124      ; # &I-J90-4124;
    :eq rep.gb2312:0x6236         ; # &I-G0-6236;
    :eq rep.ks-x1001:0x743F       ; # &I-K0-743F;
    :eq rep.cns11643-1:0x4860     ; # &I-C1-4860;
    :eq rep.jis-x0213-1:0x4124    ; # &I-JX1-4124;
    :eq a.big5:0xA6DF             ; # &I-B-A6DF;
    :eq rep.hanyo-denshi...ja:0x4124 ; # &I-HD-JA-4124;
    :eq rep.hanyo-denshi...ib:0x2354 ; # &I-HD-IB-2354;
    :eq rep.gt:39240              ; # &I-GT-39240;
    :eq rep.gt-k:01657            ; # &I-GT-K01657;
    :eq rep.gt-pj-1:16676         ; # &I-GT-39240;
    :eq rep.daikanwa:30338        ; # &I-M-30338;
    :eq rep.shinjigen:6636        ; # &MJ021365;
    :subsume
        g2.mj:021365         ,
        g2.cns11643-1:0x4860 ,
        rep.mj:021367        ;
    .
