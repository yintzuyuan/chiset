        a chisegg:abstract-glyph ;
        :abstract-glyph-of jis-x0213-1:0x7944 ;
        :eq rep.ucs_unicode:0x79B8    ; # &JX1-7944;
        :eq rep.jis-x0212:0x5072      ; # &JX1-7944;
        :eq rep.iso-ir165:0x2E22      ; # &I-EGB-2E22;
        :eq rep.daikanwa:24884        ; # &I-M-24884;
        :eq rep.jef-china3:0x5CEE     ; # &I-JC3-5CEE;
        .
        rep.ucs_unicode:0x79B8
                   :abstract-glyph-of [ :context domain:unicode ;
                                        :target     ucs:0x79B8  ] .
        rep.jis-x0212:0x5072
