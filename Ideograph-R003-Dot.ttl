        repi.jis-x0208:0x5026
            a chisegg:glyph-image ;
            :glyph-image-of jis-x0208:0x5026 ;
            :eq repi.jis-x0213-1:0x5026   ; # &R-J0-5026;
            .
            repi.jis-x0213-1:0x5026
                          :glyph-image-of    jis-x0213-1:0x5026  .
        repi.adobe-japan1-0:04095
            a chisegg:glyph-image ;
            :glyph-image-of adobe-japan1-0:04095 ;
            .
        repi.big5-cdp:0x8B41
            a chisegg:glyph-image ;
            :glyph-image-of big5-cdp:0x8B41 ;
            .
        repi.cns11643-3:0x2122
            a chisegg:glyph-image ;
            :glyph-image-of cns11643-3:0x2122 ;
            .
        repi.gt:00128
            a chisegg:glyph-image ;
            :glyph-image-of gt:00128 ;
            :eq repi.gt-k:00010           ; # &R-GT-00128;
