a.ucs:0x4E36
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x4E36 ;
    ideo:radical           3 ; # ⼂ 
    ideo:strokes           0 ;
    ideo:total-strokes     1 ;
    ideo:hanyu-dazidian  ( 1 42 8 ) ;
    :sound               [ :context domain:ja...kun ;
                           :target  ( "ten" ) ;
                         ] ;
    :sound               [ :context domain:ja...on ;
                           :target  ( "tyu" ) ;
                         ] ;
    :eq rep.adobe-japan1-0:04095  ; # &I-AJ1-04095;
    :eq rep.jis-x0208:0x5026      ; # &I-J90-5026;
    :eq rep.gb2312:0x583C         ; # &I-G0-583C;
    :eq rep.cns11643-3:0x2122     ; # &I-C3-2122;
    :eq rep.jis-x0213-1:0x5026    ; # &I-JX1-5026;
    :eq rep.big5-cdp:0x8B41       ; # &I-CDP-8B41;
    :eq rep.gt:00128              ; # &I-GT-00128;
    :eq rep.gt-k:00010            ; # &I-GT-K00010;
    :eq rep.gt-pj-1:20518         ; # &I-GT-00128;
    :eq rep.daikanwa:00091        ; # &I-M-00091;
    :subsume
        g2.ucs_unicode:0x4E36 ;
    .
    rep.adobe-japan1-0:04095
               :abstract-glyph-of adobe-japan1-0:04095   .
    rep.jis-x0208:0x5026
               :abstract-glyph-of      jis-x0208:0x5026  .
    rep.gb2312:0x583C
               :abstract-glyph-of         gb2312:0x583C  .
    rep.cns11643-3:0x2122
               :abstract-glyph-of     cns11643-3:0x2122  .
    rep.jis-x0213-1:0x5026
               :abstract-glyph-of    jis-x0213-1:0x5026  .
    rep.big5-cdp:0x8B41
               :abstract-glyph-of       big5-cdp:0x8B41  .
    rep.gt:00128
               :abstract-glyph-of             gt:00128   .
    rep.gt-k:00010
               :abstract-glyph-of           gt-k:00010   .
    rep.gt-pj-1:20518
               :abstract-glyph-of        gt-pj-1:20518   .
    rep.daikanwa:00091
               :abstract-glyph-of       daikanwa:00091   .
    g2.ucs_unicode:0x4E36
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of [ :context domain:unicode ;
                                  :target     ucs:0x4E36  ] ;
        :eq g2.adobe-japan1-0:04095   ; # &g2-AJ1-04095;
        :eq g2.gb2312:0x583C          ; # &g2-AJ1-04095;
        :eq g2.jis-x0208:0x5026       ; # &g2-AJ1-04095;
        :eq g2.cns11643-3:0x2122      ; # &g2-AJ1-04095;
        :eq g2.jis-x0213-1:0x5026     ; # &g2-AJ1-04095;
        :eq g2.big5-cdp:0x8B41        ; # &g2-AJ1-04095;
        :eq g2.gt:00128               ; # &g2-AJ1-04095;
        :eq g2.gt-k:00010             ; # &g2-AJ1-04095;
        :eq g2.daikanwa:00091         ; # &g2-AJ1-04095;
        :subsume
            repi.daikanwa:00091  ,
            repi.jis-x0208:0x5026 ,
            repi.adobe-japan1-6:04095 ,
            repi.big5-cdp:0x8B41 ,
            repi.cns11643-3:0x2122 ,
            repi.gt:00128        ,
            repi.ucs_unicode:0x4E36 ;
        .
        g2.adobe-japan1-0:04095
              :abstract-glyph-form-of adobe-japan1-0:04095   .
        g2.gb2312:0x583C
              :abstract-glyph-form-of         gb2312:0x583C  .
        g2.jis-x0208:0x5026
              :abstract-glyph-form-of      jis-x0208:0x5026  .
        g2.cns11643-3:0x2122
              :abstract-glyph-form-of     cns11643-3:0x2122  .
        g2.jis-x0213-1:0x5026
              :abstract-glyph-form-of    jis-x0213-1:0x5026  .
        g2.big5-cdp:0x8B41
              :abstract-glyph-form-of       big5-cdp:0x8B41  .
        g2.gt:00128
              :abstract-glyph-form-of             gt:00128   .
        g2.gt-k:00010
              :abstract-glyph-form-of           gt-k:00010   .
        g2.daikanwa:00091
              :abstract-glyph-form-of       daikanwa:00091   .
        repi.daikanwa:00091
            a chisegg:glyph-image ;
            :glyph-image-of daikanwa:00091 ;
