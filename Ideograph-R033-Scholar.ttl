a.iwds-1:0072
    a chisegg:abstract-character ;
    :abstract-character-of iwds-1:0072 ;
    ideo:radical          33 ; # ⼠ 
    ideo:strokes           0 ;
    ideo:total-strokes     3 ;
    :eq a.big5-cdp:0x8BF1         ; # &IWDS1-072;
    .
