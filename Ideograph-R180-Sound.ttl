a.ucs:0x97F3
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x97F3 ;
    ideo:radical         180 ; # ⾳ 
    ideo:strokes           0 ;
    ideo:total-strokes     9 ;
    :eq rep.adobe-japan1-0:01339  ; # &I-AJ1-01339;
    :eq rep.jis-x0208:0x323B      ; # &I-J90-323B;
    :eq rep.gb2312:0x5274         ; # &I-G0-5274;
    :eq rep.ks-x1001:0x6B65       ; # &I-K0-6B65;
    :eq rep.cns11643-1:0x5376     ; # &I-C1-5376;
    :eq rep.jis-x0213-1:0x323B    ; # &I-JX1-323B;
    :eq rep.hanyo-denshi...ja:0x323B ; # &I-HD-JA-323B;
    :eq rep.gt:58109              ; # &I-GT-58109;
    :eq rep.gt-k:05029            ; # &I-GT-K05029;
    :eq rep.gt-pj-1:12859         ; # &I-GT-58109;
    :eq rep.daikanwa:43265        ; # &I-M-43265;
    :eq rep.shinjigen:9132        ; # 音
    :subsume
        rep.gt:58108         ,
        g2.ucs_unicode:0x97F3 ;
    .
    rep.adobe-japan1-0:01339
               :abstract-glyph-of adobe-japan1-0:01339   .
    rep.jis-x0208:0x323B
               :abstract-glyph-of      jis-x0208:0x323B  .
    rep.gb2312:0x5274
               :abstract-glyph-of         gb2312:0x5274  .
    rep.ks-x1001:0x6B65
               :abstract-glyph-of       ks-x1001:0x6B65  .
    rep.cns11643-1:0x5376
               :abstract-glyph-of     cns11643-1:0x5376  .
    rep.jis-x0213-1:0x323B
               :abstract-glyph-of    jis-x0213-1:0x323B  .
    rep.hanyo-denshi...ja:0x323B
               :abstract-glyph-of hanyo-denshi...ja:0x323B  .
    rep.gt:58109
               :abstract-glyph-of             gt:58109   .
    rep.gt-k:05029
               :abstract-glyph-of           gt-k:05029   .
    rep.gt-pj-1:12859
               :abstract-glyph-of        gt-pj-1:12859   .
    rep.daikanwa:43265
               :abstract-glyph-of       daikanwa:43265   .
    rep.shinjigen:9132
               :abstract-glyph-of      shinjigen:9132    .
    rep.gt:58108
        a chisegg:abstract-glyph ;
        :abstract-glyph-of gt:58108 ;
        :eq rep.gt-k:05028            ; # &I-GT-K05028;
        :eq rep.gt-pj-8:15954         ; # &GT-58108;
        :eq g2.daikanwa:43265         ; # &GT-58108;
        :eq rep.shinjigen:9133        ; # &GT-58108;
        :eq rep.jef-china3:0x6CD8     ; # &I-JC3-6CD8;
        :subsume
            repi.daikanwa:43265  ,
            repi.gt:58108        ,
            repi.jef-china3:0x6CD8 ;
        .
        rep.gt-k:05028
                   :abstract-glyph-of           gt-k:05028   .
        rep.gt-pj-8:15954
                   :abstract-glyph-of        gt-pj-8:15954   .
        g2.daikanwa:43265
              :abstract-glyph-form-of       daikanwa:43265   .
        rep.shinjigen:9133
                   :abstract-glyph-of      shinjigen:9133    .
        rep.jef-china3:0x6CD8
                   :abstract-glyph-of     jef-china3:0x6CD8  .
        repi.daikanwa:43265
            a chisegg:glyph-image ;
            :glyph-image-of daikanwa:43265 ;
            .
        repi.gt:58108
            a chisegg:glyph-image ;
            :glyph-image-of gt:58108 ;
            :eq repi.gt-k:05028           ; # &R-GT-58108;
            .
            repi.gt-k:05028
                          :glyph-image-of           gt-k:05028   .
        repi.jef-china3:0x6CD8
            a chisegg:glyph-image ;
            :glyph-image-of jef-china3:0x6CD8 ;
            .
    g2.ucs_unicode:0x97F3
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of [ :context domain:unicode ;
                                  :target     ucs:0x97F3  ] ;
        :rep.decomposition   [ :context domain:hanyo-denshi ;
                               :target  a.ucs:0x97F3         ,
                                        a.ucs:0xE0102        ] ;
        :eq g2.adobe-japan1-0:01339   ; # &g2-AJ1-01339;
        :eq g2.gb2312:0x5274          ; # &g2-AJ1-01339;
        :eq g2.ks-x1001:0x6B65        ; # &g2-AJ1-01339;
        :eq g2.jis-x0208:0x323B       ; # &g2-AJ1-01339;
