        :eq g2.jis-x0213-1:0x323B     ; # &g2-AJ1-01339;
        :eq g2.hanyo-denshi...ja:0x323B ; # &g2-AJ1-01339;
        :eq g2.gt:58109               ; # &g2-AJ1-01339;
        :eq g2.gt-k:05029             ; # &g2-AJ1-01339;
        :eq g2.shinjigen:9132         ; # &g2-AJ1-01339;
        :subsume
            repi.jis-x0208:0x323B ,
            repi.adobe-japan1-6:01339 ,
            repi.ks-x1001:0x6B65 ,
            repi.gt:58109        ,
