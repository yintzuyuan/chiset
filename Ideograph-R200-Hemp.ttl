    rep.shinjigen:9804
               :abstract-glyph-of      shinjigen:9804    .
    g2.ucs_unicode:0x9EBB
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of [ :context domain:unicode ;
                                  :target     ucs:0x9EBB  ] ;
        :eq g2.adobe-japan1-0:03729   ; # &g2-AJ1-03729;
        :eq g2.gb2312:0x4269          ; # &g2-AJ1-03729;
        :eq g2.jis-x0208:0x4B63       ; # &g2-AJ1-03729;
        :eq g2.jis-x0213-1:0x4B63     ; # &g2-AJ1-03729;
        :eq g2.big5-cdp:0x8A5F        ; # &g2-AJ1-03729;
        :eq g2.gt:65257               ; # &g2-AJ1-03729;
        :eq g2.gt-k:07878             ; # &g2-AJ1-03729;
        :eq g2.daikanwa:47888         ; # &g2-AJ1-03729;
        :eq g2.shinjigen:9804         ; # &g2-AJ1-03729;
        :subsume
            repi.daikanwa:47888  ,
            repi.jis-x0208:0x4B63 ,
            repi.adobe-japan1-6:03729 ,
            repi.big5-cdp:0x8A5F ,
            repi.gt:65257        ,
            repi.ucs_unicode:0x9EBB ;
