a.ucs:0x9EBB
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x9EBB ;
    ideo:radical         200 ; # ⿇ 
    ideo:strokes           0 ;
    ideo:total-strokes    11 ;
    :eq a.jis-x0208:0x4B63        ; # 麻
    :eq a.jis-x0213-1:0x4B63      ; # 麻
    .
    a.jis-x0208:0x4B63
           :abstract-character-of      jis-x0208:0x4B63  .
    a.jis-x0213-1:0x4B63
           :abstract-character-of    jis-x0213-1:0x4B63  .

rep.gt:65256
    a chisegg:abstract-glyph ;
    :abstract-glyph-of gt:65256 ;
    :denotation-of
        a.ucs:0x9EBB         ;
    ideo:radical         200 ; # ⿇ 
    ideo:strokes           0 ;
    ideo:total-strokes    11 ;
    :eq rep.ucs_cns:0x9EBB        ; # &GT-65256;
    :eq rep.ucs_ks:0x9EBB         ; # &GT-65256;
    :eq rep.ks-x1001:0x582B       ; # &GT-65256;
    :eq rep.cns11643-1:0x5E28     ; # &I-C1-5E28;
    :eq rep.gt-k:07879            ; # &I-GT-K07879;
    :eq rep.gt-pj-8:27985         ; # &I-GT-65256;
    :eq rep.daikanwa:47887        ; # &I-M-47887;
    :eq rep.shinjigen:9805        ; # &GT-65256;
    :eq rep.jef-china3:0x6FC6     ; # &I-JC3-6FC6;
    :subsume
        g2.ks-x1001:0x582B   ,
        g2.cns11643-1:0x5E28 ;
    .
    rep.ucs_cns:0x9EBB
               :abstract-glyph-of [ :context domain:cns     ;
                                    :target     ucs:0x9EBB  ] .
    rep.ucs_ks:0x9EBB
               :abstract-glyph-of [ :context domain:ks      ;
                                    :target     ucs:0x9EBB  ] .
    rep.ks-x1001:0x582B
               :abstract-glyph-of       ks-x1001:0x582B  .
    rep.cns11643-1:0x5E28
               :abstract-glyph-of     cns11643-1:0x5E28  .
    rep.gt-k:07879
               :abstract-glyph-of           gt-k:07879   .
    rep.gt-pj-8:27985
               :abstract-glyph-of        gt-pj-8:27985   .
    rep.daikanwa:47887
               :abstract-glyph-of       daikanwa:47887   .
    rep.shinjigen:9805
               :abstract-glyph-of      shinjigen:9805    .
    rep.jef-china3:0x6FC6
               :abstract-glyph-of     jef-china3:0x6FC6  .
    g2.ks-x1001:0x582B
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of ks-x1001:0x582B ;
        :eq g2.ucs_ks:0x9EBB          ; # &g2-GT-65256;
        :eq g2.gt:65256               ; # &g2-GT-65256;
        :eq g2.gt-k:07879             ; # &g2-GT-65256;
        :eq g2.daikanwa:47887         ; # &g2-GT-65256;
        :eq g2.shinjigen:9805         ; # &g2-GT-65256;
        :eq g2.jef-china3:0x6FC6      ; # &g2-GT-65256;
        :subsume
            repi.daikanwa:47887  ,
            repi.ks-x1001:0x582B ,
            repi.gt:65256        ,
            repi.jef-china3:0x6FC6 ;
        .
        g2.ucs_ks:0x9EBB
              :abstract-glyph-form-of [ :context domain:ks      ;
                                        :target     ucs:0x9EBB  ] .
        g2.gt:65256
              :abstract-glyph-form-of             gt:65256   .
        g2.gt-k:07879
              :abstract-glyph-form-of           gt-k:07879   .
        g2.daikanwa:47887
              :abstract-glyph-form-of       daikanwa:47887   .
        g2.shinjigen:9805
              :abstract-glyph-form-of      shinjigen:9805    .
        g2.jef-china3:0x6FC6
              :abstract-glyph-form-of     jef-china3:0x6FC6  .
        repi.daikanwa:47887
            a chisegg:glyph-image ;
            :glyph-image-of daikanwa:47887 ;
            .
        repi.ks-x1001:0x582B
            a chisegg:glyph-image ;
            :glyph-image-of ks-x1001:0x582B ;
            :eq repi.ucs_ks:0x9EBB        ; # &R-K0-582B;
            .
            repi.ucs_ks:0x9EBB
                          :glyph-image-of [ :context domain:ks      ;
                                            :target     ucs:0x9EBB  ] .
        repi.gt:65256
            a chisegg:glyph-image ;
            :glyph-image-of gt:65256 ;
            :eq repi.gt-k:07879           ; # &R-GT-65256;
            .
            repi.gt-k:07879
                          :glyph-image-of           gt-k:07879   .
        repi.jef-china3:0x6FC6
            a chisegg:glyph-image ;
            :glyph-image-of jef-china3:0x6FC6 ;
            .
    g2.cns11643-1:0x5E28
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of cns11643-1:0x5E28 ;
        :eq g2.ucs_cns:0x9EBB         ; # &g2-CU+9EBB;
        .
        g2.ucs_cns:0x9EBB
              :abstract-glyph-form-of [ :context domain:cns     ;
                                        :target     ucs:0x9EBB  ] .

a.ucs:0x2FA15
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x2FA15 ;
    :denotation-of
        a.ucs:0x9EBB         ;
    :to.canonical-ucs	a.ucs:0x9EBB ; # 麻
    ideo:radical         200 ; # ⿇ 
    ideo:strokes           0 ;
    ideo:total-strokes    11 ;
    :eq rep.cns11643-6:0x463E     ; # &I-C6-463E;
    :subsume
        g2.ucs_iso:0x2FA15   ,
        repi.hng-kar:04630   ;
    .
    rep.cns11643-6:0x463E
               :abstract-glyph-of     cns11643-6:0x463E  .
    g2.ucs_iso:0x2FA15
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of [ :context domain:iso     ;
                                  :target     ucs:0x2FA15 ] ;
        :eq g2.cns11643-6:0x463E      ; # &g2-IU-0002FA15;
        :subsume
            repi.cns11643-6:0x463E ,
            repi.ucs_iso:0x2FA15 ;
        .
        g2.cns11643-6:0x463E
              :abstract-glyph-form-of     cns11643-6:0x463E  .
        repi.cns11643-6:0x463E
            a chisegg:glyph-image ;
            :glyph-image-of cns11643-6:0x463E ;
            .
        repi.ucs_iso:0x2FA15
            a chisegg:glyph-image ;
            :glyph-image-of [ :context domain:iso     ;
                              :target     ucs:0x2FA15 ] ;
            .
    repi.hng-kar:04630
        a chisegg:glyph-image ;
        :glyph-image-of hng-kar:04630 ;
        .

