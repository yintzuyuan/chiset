a.ucs:0x5F50
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x5F50 ;
    ideo:radical          58 ; # ⼹ 
    ideo:strokes           0 ;
    ideo:total-strokes     3 ;
    .

rep.adobe-japan1-4:14521
    a chisegg:abstract-glyph ;
    :abstract-glyph-of adobe-japan1-4:14521 ;
    :denotation-of
        a.ucs:0x5F50         ;
    ideo:radical          58 ; # ⼹ 
    ideo:strokes           0 ;
    ideo:total-strokes     3 ;
    :eq rep.ucs_jis:0x5F50        ; # &AJ1-14521;
    :eq rep.jis-x0212:0x3C77      ; # &I-JSP-3C77;
    :eq rep.cns11643-3:0x2140     ; # &I-C3-2140;
    :eq rep.big5-cdp:0x8A6E       ; # &I-CDP-8A6E;
    :eq rep.gt:12503              ; # &I-GT-12503;
    :eq rep.gt-k:00268            ; # &I-GT-K00268;
    :eq rep.gt-pj-3:18810         ; # &I-GT-12503;
    :eq rep.daikanwa:09908        ; # &I-M-09908;
    :eq rep.jef-china3:0x4CF9     ; # &I-JC3-4CF9;
    :subsume
        g2.ucs_jis:0x5F50    ,
        g2.adobe-japan1-4:14521 ;
    .
    rep.ucs_jis:0x5F50
               :abstract-glyph-of [ :context domain:jis     ;
                                    :target     ucs:0x5F50  ] .
    rep.jis-x0212:0x3C77
               :abstract-glyph-of      jis-x0212:0x3C77  .
    rep.cns11643-3:0x2140
               :abstract-glyph-of     cns11643-3:0x2140  .
    rep.big5-cdp:0x8A6E
               :abstract-glyph-of       big5-cdp:0x8A6E  .
    rep.gt:12503
               :abstract-glyph-of             gt:12503   .
    rep.gt-k:00268
               :abstract-glyph-of           gt-k:00268   .
    rep.gt-pj-3:18810
               :abstract-glyph-of        gt-pj-3:18810   .
    rep.daikanwa:09908
               :abstract-glyph-of       daikanwa:09908   .
    rep.jef-china3:0x4CF9
               :abstract-glyph-of     jef-china3:0x4CF9  .
    g2.ucs_jis:0x5F50
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of [ :context domain:jis     ;
                                  :target     ucs:0x5F50  ] ;
        :eq g2.ucs_cns:0x5F50         ; # &g2-GT-12503;
        :eq g2.jis-x0212:0x3C77       ; # &g2-GT-12503;
        :eq g2.cns11643-3:0x2140      ; # &g2-GT-12503;
        :eq g2.big5-cdp:0x8A6E        ; # &g2-GT-12503;
        :eq g2.gt:12503               ; # &g2-GT-12503;
        :eq g2.gt-k:00268             ; # &g2-GT-12503;
        :eq g2.daikanwa:09908         ; # &g2-GT-12503;
        :eq g2.jef-china3:0x4CF9      ; # &g2-GT-12503;
        :subsume
            repi.daikanwa:09908  ,
            repi.jis-x0212:0x3C77 ,
            repi.jef-china3:0x4CF9 ,
            repi.gt:12503        ,
            repi.cns11643-3:0x2140 ,
            repi.big5-cdp:0x8A6E ;
        .
        g2.ucs_cns:0x5F50
              :abstract-glyph-form-of [ :context domain:cns     ;
                                        :target     ucs:0x5F50  ] .
        g2.jis-x0212:0x3C77
              :abstract-glyph-form-of      jis-x0212:0x3C77  .
        g2.cns11643-3:0x2140
              :abstract-glyph-form-of     cns11643-3:0x2140  .
        g2.big5-cdp:0x8A6E
              :abstract-glyph-form-of       big5-cdp:0x8A6E  .
        g2.gt:12503
              :abstract-glyph-form-of             gt:12503   .
        g2.gt-k:00268
              :abstract-glyph-form-of           gt-k:00268   .
        g2.daikanwa:09908
              :abstract-glyph-form-of       daikanwa:09908   .
        g2.jef-china3:0x4CF9
              :abstract-glyph-form-of     jef-china3:0x4CF9  .
        repi.daikanwa:09908
            a chisegg:glyph-image ;
            :glyph-image-of daikanwa:09908 ;
            .
        repi.jis-x0212:0x3C77
            a chisegg:glyph-image ;
            :glyph-image-of jis-x0212:0x3C77 ;
            .
        repi.jef-china3:0x4CF9
            a chisegg:glyph-image ;
            :glyph-image-of jef-china3:0x4CF9 ;
            .
        repi.gt:12503
            a chisegg:glyph-image ;
            :glyph-image-of gt:12503 ;
            :eq repi.gt-k:00268           ; # &R-GT-12503;
            .
