a.ucs:0x8C55
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x8C55 ;
    ideo:radical         152 ; # ⾗ 
    ideo:strokes           0 ;
    .

rep.mj:024906
    a chisegg:abstract-glyph ;
    :abstract-glyph-of mj:024906 ;
    :denotation-of
        a.ucs:0x8C55         ;
    ideo:radical         152 ; # ⾗ 
    ideo:strokes           0 ;
    ideo:total-strokes     7 ;
    :eq rep.ucs_unicode:0x8C55    ; # &MJ024906;
    :eq rep.adobe-japan1-0:06742  ; # &I-AJ1-06742;
    :eq rep.jis-x0208:0x6C35      ; # &I-J90-6C35;
    :eq rep.gb2312:0x7539         ; # &I-G0-7539;
    :eq rep.ks-x1001:0x634E       ; # &I-K0-634E;
    :eq rep.cns11643-1:0x4B49     ; # &I-C1-4B49;
    :eq rep.jis-x0213-1:0x6C35    ; # &I-JX1-6C35;
    :eq a.big5:0xA8A8             ; # &I-B-A8A8;
    :eq rep.hanyo-denshi...ja:0x6C35 ; # &I-HD-JA-6C35;
    :eq rep.hanyo-denshi...ft:0x395B ; # &I-HD-FT-395B;
    :eq rep.gt:48747              ; # &I-GT-48747;
    :eq rep.gt-k:02730            ; # &I-GT-K02730;
    :eq rep.gt-pj-1:27701         ; # &I-GT-48747;
    :eq rep.daikanwa:36334        ; # &I-M-36334;
    :eq rep.shinjigen:7813        ; # &MJ024906;
    :subsume
        g2.mj:024906         ,
        g2.ucs_unicode:0x8C55 ,
        rep.mj:024907        ;
    .
    rep.ucs_unicode:0x8C55
               :abstract-glyph-of [ :context domain:unicode ;
                                    :target     ucs:0x8C55  ] .
    rep.adobe-japan1-0:06742
               :abstract-glyph-of adobe-japan1-0:06742   .
    rep.jis-x0208:0x6C35
               :abstract-glyph-of      jis-x0208:0x6C35  .
    rep.gb2312:0x7539
               :abstract-glyph-of         gb2312:0x7539  .
    rep.ks-x1001:0x634E
               :abstract-glyph-of       ks-x1001:0x634E  .
    rep.cns11643-1:0x4B49
               :abstract-glyph-of     cns11643-1:0x4B49  .
    rep.jis-x0213-1:0x6C35
               :abstract-glyph-of    jis-x0213-1:0x6C35  .
    a.big5:0xA8A8
           :abstract-character-of           big5:0xA8A8  .
    rep.hanyo-denshi...ja:0x6C35
               :abstract-glyph-of hanyo-denshi...ja:0x6C35  .
    rep.hanyo-denshi...ft:0x395B
               :abstract-glyph-of hanyo-denshi...ft:0x395B  .
    rep.gt:48747
               :abstract-glyph-of             gt:48747   .
    rep.gt-k:02730
               :abstract-glyph-of           gt-k:02730   .
    rep.gt-pj-1:27701
               :abstract-glyph-of        gt-pj-1:27701   .
    rep.daikanwa:36334
               :abstract-glyph-of       daikanwa:36334   .
    rep.shinjigen:7813
               :abstract-glyph-of      shinjigen:7813    .
    g2.mj:024906
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of mj:024906 ;
        :rep.decomposition   [ :context domain:hanyo-denshi ;
                               :target  a.ucs:0x8C55         ,
                                        a.ucs:0xE0101        ] ;
        :eq g2.ucs_jis...1990:0x8C55  ; # &g2-MJ024906;
        :eq g2.ucs_jis...2000:0x8C55  ; # &g2-MJ024906;
        :eq g2.ucs_jis...2004:0x8C55  ; # &g2-MJ024906;
        :eq g2.ucs_ks:0x8C55          ; # &g2-MJ024906;
        :eq g2.adobe-japan1-0:06742   ; # &g2-MJ024906;
        :eq g2.ks-x1001:0x634E        ; # &g2-MJ024906;
        :eq g2.jis-x0208_1990:0x6C35  ; # &g2-MJ024906;
        :eq g2.jis-x0213-1:0x6C35     ; # &g2-MJ024906;
        :eq g2.hanyo-denshi...ja:0x6C35 ; # &g2-MJ024906;
        :eq g2.gt:48747               ; # &g2-MJ024906;
        :eq g2.gt-k:02730             ; # &g2-MJ024906;
        :eq g2.daikanwa:36334         ; # &g2-MJ024906;
        :eq g2.shinjigen:7813         ; # &g2-MJ024906;
        :subsume
            repi.daikanwa:36334  ,
            repi.jis-x0208_1990:0x6C35 ,
            repi.adobe-japan1-6:06742 ,
            repi.mj:024906       ,
