a.ucs_component:0x81E5
    a chisegg:abstract-character ;
    :abstract-character-of [ :context domain:component ;
                             :target     ucs:0x81E5  ] ;
    ideo:radical         131 ; # ⾂ 
    ideo:strokes           2 ;
    ideo:total-strokes     8 ;
    :eq bucs:0x81E5               ; # &BUCS+81E5;
    :eq a.iwds-1:0043             ; # &BUCS+81E5;
