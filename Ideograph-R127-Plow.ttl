a.ucs:0x8012
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x8012 ;
    ideo:radical         127 ; # ⽾ 
    ideo:strokes           0 ;
    ideo:total-strokes     6 ;
    :eq a.big5:0xA6D4             ; # &I-B-A6D4;
    .
    a.big5:0xA6D4
           :abstract-character-of           big5:0xA6D4  .

rep.adobe-japan1-0:06205
    a chisegg:abstract-glyph ;
    :abstract-glyph-of adobe-japan1-0:06205 ;
    :denotation-of
        a.ucs:0x8012         ;
    ideo:radical         127 ; # ⽾ 
    ideo:strokes           0 ;
    ideo:total-strokes     6 ;
    :eq rep.ucs_cns:0x8012        ; # &AJ1-06205;
    :eq rep.ucs_jis:0x8012        ; # &AJ1-06205;
    :eq rep.ucs_ks:0x8012         ; # &AJ1-06205;
    :eq rep.jis-x0208:0x6650      ; # &I-J90-6650;
    :eq rep.cns11643-1:0x4855     ; # &I-C1-4855;
    :eq rep.jis-x0213-1:0x6650    ; # &I-JX1-6650;
    :eq rep.hanyo-denshi...ja:0x6650 ; # &I-HD-JA-6650;
    :eq rep.gt:37363              ; # &I-GT-37363;
    :eq rep.gt-k:01732            ; # &I-GT-K01732;
    :eq rep.gt-pj-1:26192         ; # &I-GT-37363;
    :eq rep.daikanwa:28898        ; # &I-M-28898;
    :eq rep.shinjigen:6352        ; # &AJ1-06205;
    :subsume
        g2.adobe-japan1-0:06205 ,
        rep.gt-k:01733       ;
    .
    rep.ucs_cns:0x8012
               :abstract-glyph-of [ :context domain:cns     ;
                                    :target     ucs:0x8012  ] .
    rep.ucs_jis:0x8012
               :abstract-glyph-of [ :context domain:jis     ;
                                    :target     ucs:0x8012  ] .
    rep.ucs_ks:0x8012
               :abstract-glyph-of [ :context domain:ks      ;
                                    :target     ucs:0x8012  ] .
