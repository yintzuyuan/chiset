    rep.daikanwa:28898
               :abstract-glyph-of       daikanwa:28898   .
    rep.shinjigen:6352
               :abstract-glyph-of      shinjigen:6352    .
    g2.adobe-japan1-0:06205
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of adobe-japan1-0:06205 ;
        :rep.decomposition   [ :context domain:hanyo-denshi ;
                               :target  a.ucs:0x8012         ,
                                        a.ucs:0xE0102        ] ;
        :eq g2.ucs_cns:0x8012         ; # &g2-AJ1-06205;
        :eq g2.ucs_jis:0x8012         ; # &g2-AJ1-06205;
        :eq g2.jis-x0208:0x6650       ; # &g2-AJ1-06205;
        :eq g2.cns11643-1:0x4855      ; # &g2-AJ1-06205;
        :eq g2.jis-x0213-1:0x6650     ; # &g2-AJ1-06205;
        :eq g2.hanyo-denshi...ja:0x6650 ; # &g2-AJ1-06205;
        :eq g2.gt:37363               ; # &g2-AJ1-06205;
        :eq g2.gt-k:01732             ; # &g2-AJ1-06205;
        :eq g2.daikanwa:28898         ; # &g2-AJ1-06205;
        :eq g2.shinjigen:6352         ; # &g2-AJ1-06205;
        :subsume
            repi.daikanwa:28898  ,
            repi.gt:37363        ,
            repi.jis-x0208:0x6650 ,
            repi.adobe-japan1-6:06205 ,
            repi.cns11643-1:0x4855 ;
