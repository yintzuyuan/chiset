a.ucs:0x200CC
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x200CC ;
    ideo:radical           [ :context domain:ucs     ;
                             :target            5 ; # ⼄
                           ] ;
    ideo:strokes           [ :context domain:ucs     ;
                             :target  0 ] ;
    ideo:radical           [ :context domain:daikanwa ;
                             :target            6 ; # ⼅
                           ] ;
    ideo:strokes           [ :context domain:daikanwa ;
                             :target  0 ] ;
    ideo:total-strokes     1 ;
    ideo:hanyu-dazidian  ( 1 48 2 ) ;
    :eq rep.big5-cdp:0x8B61       ; # &I-CDP-8B61;
    :eq rep.gt:00301              ; # &I-GT-00301;
    :eq rep.gt-k:00023            ; # &I-GT-K00023;
    :eq rep.gt-pj-11:17193        ; # &I-GT-00301;
    :eq rep.daikanwa...ho:0006    ; # 𠃌
    .
    rep.big5-cdp:0x8B61
               :abstract-glyph-of       big5-cdp:0x8B61  .
    rep.gt:00301
               :abstract-glyph-of             gt:00301   .
    rep.gt-k:00023
               :abstract-glyph-of           gt-k:00023   .
    rep.gt-pj-11:17193
               :abstract-glyph-of       gt-pj-11:17193   .
    rep.daikanwa...ho:0006
               :abstract-glyph-of  daikanwa...ho:0006    .

a.ucs:0x4E86
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x4E86 ;
    ideo:radical           6 ; # ⼅ 
    ideo:strokes           1 ;
    ideo:total-strokes     2 ;
    ideo:hanyu-dazidian  ( 1 48 6 ) ;
    :sound               [ :context domain:ja...kun...name ;
                           :target  ( "satoru" ) ;
                         ] ;
    :sound               [ :context domain:ja...on ;
                           :target  ( "rEu" ) ;
                         ] ;
    :eq rep.adobe-japan1-0:03971  ; # &I-AJ1-03971;
    :eq rep.jis-x0208:0x4E3B      ; # &I-J90-4E3B;
    :eq rep.gb2312:0x414B         ; # &I-G0-414B;
    :eq rep.ks-x1001:0x5675       ; # &I-K0-5675;
    :eq rep.cns11643-1:0x4427     ; # &I-C1-4427;
    :eq rep.jis-x0213-1:0x4E3B    ; # &I-JX1-4E3B;
    :eq a.big5:0xA446             ; # &I-B-A446;
    :eq rep.gt:00306              ; # &I-GT-00306;
    :eq rep.gt-k:00066            ; # &I-GT-K00066;
    :eq rep.gt-pj-1:20027         ; # &I-GT-00306;
    :eq rep.daikanwa:00226        ; # &I-M-00226;
    :eq rep.shinjigen:0066        ; # 了
    :subsume
        g2.ucs_unicode:0x4E86 ,
        repi.hng-jyu:01110   ,
        repi.hng-kss:00040   ;
    .
