a.ucs:0x4E85
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x4E85 ;
    ideo:radical           6 ; # ⼅ 
    ideo:strokes           0 ;
    ideo:total-strokes     1 ;
    ideo:hanyu-dazidian  ( 1 28 3 ) ;
    :sound               [ :context domain:ja...on...kan ;
                           :target  ( "ketu" ) ;
                         ] ;
    :eq rep.adobe-japan1-0:04102  ; # &I-AJ1-04102;
    :eq rep.jis-x0208:0x502D      ; # &I-J90-502D;
    :eq rep.iso-ir165:0x2F7C      ; # &I-EGB-2F7C;
    :eq rep.cns11643-3:0x2124     ; # &I-C3-2124;
    :eq rep.jis-x0213-1:0x502D    ; # &I-JX1-502D;
    :eq rep.big5-cdp:0x8A6F       ; # &I-CDP-8A6F;
    :eq rep.gt:00299              ; # &I-GT-00299;
    :eq rep.gt-k:00015            ; # &I-GT-K00015;
    :eq rep.gt-pj-1:20525         ; # &I-GT-00299;
    :eq rep.daikanwa:00224        ; # &I-M-00224;
    .
    rep.adobe-japan1-0:04102
               :abstract-glyph-of adobe-japan1-0:04102   .
    rep.jis-x0208:0x502D
               :abstract-glyph-of      jis-x0208:0x502D  .
    rep.iso-ir165:0x2F7C
               :abstract-glyph-of      iso-ir165:0x2F7C  .
    rep.cns11643-3:0x2124
               :abstract-glyph-of     cns11643-3:0x2124  .
    rep.jis-x0213-1:0x502D
               :abstract-glyph-of    jis-x0213-1:0x502D  .
    rep.big5-cdp:0x8A6F
               :abstract-glyph-of       big5-cdp:0x8A6F  .
    rep.gt:00299
               :abstract-glyph-of             gt:00299   .
    rep.gt-k:00015
               :abstract-glyph-of           gt-k:00015   .
    rep.gt-pj-1:20525
               :abstract-glyph-of        gt-pj-1:20525   .
    rep.daikanwa:00224
               :abstract-glyph-of       daikanwa:00224   .

