        :eq g2.adobe-japan1-0:03971   ; # &g2-AJ1-03971;
        :eq g2.gb2312:0x414B          ; # &g2-AJ1-03971;
        :eq g2.ks-x1001:0x5675        ; # &g2-AJ1-03971;
