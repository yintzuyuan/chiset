a.ucs:0x8F9B
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x8F9B ;
    ideo:radical         160 ; # ⾟ 
    ideo:strokes           0 ;
    ideo:total-strokes     7 ;
    :eq rep.adobe-japan1-0:02575  ; # &I-AJ1-02575;
    :eq rep.jis-x0208:0x3F49      ; # &I-J90-3F49;
    :eq rep.gb2312:0x5041         ; # &I-G0-5041;
    :eq rep.ks-x1001:0x6374       ; # &I-K0-6374;
    :eq rep.cns11643-1:0x4B50     ; # &I-C1-4B50;
    :eq rep.jis-x0213-1:0x3F49    ; # &I-JX1-3F49;
    :eq a.big5:0xA8AF             ; # &I-B-A8AF;
    :eq rep.gt:51557              ; # &I-GT-51557;
    :eq rep.gt-k:02584            ; # &I-GT-K02584;
    :eq rep.gt-pj-1:16201         ; # &I-GT-51557;
    :eq rep.daikanwa:38630        ; # &I-M-38630;
    :eq rep.shinjigen:8196        ; # 辛
    :subsume
        g2.ucs_unicode:0x8F9B ;
    .
    rep.adobe-japan1-0:02575
               :abstract-glyph-of adobe-japan1-0:02575   .
    rep.jis-x0208:0x3F49
               :abstract-glyph-of      jis-x0208:0x3F49  .
    rep.gb2312:0x5041
               :abstract-glyph-of         gb2312:0x5041  .
    rep.ks-x1001:0x6374
               :abstract-glyph-of       ks-x1001:0x6374  .
    rep.cns11643-1:0x4B50
               :abstract-glyph-of     cns11643-1:0x4B50  .
    rep.jis-x0213-1:0x3F49
               :abstract-glyph-of    jis-x0213-1:0x3F49  .
    a.big5:0xA8AF
           :abstract-character-of           big5:0xA8AF  .
    rep.gt:51557
               :abstract-glyph-of             gt:51557   .
    rep.gt-k:02584
               :abstract-glyph-of           gt-k:02584   .
    rep.gt-pj-1:16201
               :abstract-glyph-of        gt-pj-1:16201   .
    rep.daikanwa:38630
               :abstract-glyph-of       daikanwa:38630   .
    rep.shinjigen:8196
               :abstract-glyph-of      shinjigen:8196    .
    g2.ucs_unicode:0x8F9B
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of [ :context domain:unicode ;
                                  :target     ucs:0x8F9B  ] ;
        :eq g2.adobe-japan1-0:02575   ; # &g2-AJ1-02575;
        :eq g2.gb2312:0x5041          ; # &g2-AJ1-02575;
        :eq g2.ks-x1001:0x6374        ; # &g2-AJ1-02575;
        :eq g2.jis-x0208:0x3F49       ; # &g2-AJ1-02575;
        :eq g2.cns11643-1:0x4B50      ; # &g2-AJ1-02575;
        :eq g2.jis-x0213-1:0x3F49     ; # &g2-AJ1-02575;
        :eq g2.gt:51557               ; # &g2-AJ1-02575;
        :eq g2.gt-k:02584             ; # &g2-AJ1-02575;
        :eq g2.daikanwa:38630         ; # &g2-AJ1-02575;
        :eq g2.shinjigen:8196         ; # &g2-AJ1-02575;
        :subsume
            repi.daikanwa:38630  ,
            repi.jis-x0208:0x3F49 ,
            repi.adobe-japan1-6:02575 ,
            repi.ks-x1001:0x6374 ,
