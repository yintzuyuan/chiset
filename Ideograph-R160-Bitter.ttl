rep.gt-k:02585
    a chisegg:abstract-glyph ;
    :abstract-glyph-of gt-k:02585 ;
    :denotation-of
        a.ucs:0x8F9B         ;
    ideo:radical         160 ; # ⾟ 
    ideo:strokes           0 ;
    ideo:total-strokes     7 ;
    :eq rep.gt-pj-k1:15721        ; # &GT-K02585;
    :form-of             [ :context domain:component...connect-right ;
