a.ucs:0x6B20
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x6B20 ;
    ideo:radical          76 ; # ⽋ 
    ideo:strokes           0 ;
    ideo:total-strokes     4 ;
    :eq rep.adobe-japan1-0:01853  ; # &I-AJ1-01853;
    :eq rep.jis-x0208:0x3767      ; # &I-J90-3767;
    :eq rep.gb2312:0x4737         ; # &I-G0-4737;
    :eq rep.ks-x1001:0x7D62       ; # &I-K0-7D62;
    :eq rep.cns11643-1:0x454E     ; # &I-C1-454E;
    :eq rep.jis-x0213-1:0x3767    ; # &I-JX1-3767;
    :eq a.big5:0xA4ED             ; # &I-B-A4ED;
    :eq rep.gt:20571              ; # &I-GT-20571;
    :eq rep.gt-k:00415            ; # &I-GT-K00415;
    :eq rep.gt-pj-1:14183         ; # &I-GT-20571;
    :eq rep.daikanwa:15991        ; # &I-M-15991;
    :eq rep.shinjigen:3905        ; # 欠
    ideo:simplified-form-of [ :context domain:JP...Jouyou ;
                              :target  rep.adobe-japan1-0:06157 ] ;
    :subsume
        g2.adobe-japan1-0:01853 ,
        g2.ucs_unicode:0x6B20 ;
    .
    rep.adobe-japan1-0:01853
               :abstract-glyph-of adobe-japan1-0:01853   .
    rep.jis-x0208:0x3767
               :abstract-glyph-of      jis-x0208:0x3767  .
    rep.gb2312:0x4737
               :abstract-glyph-of         gb2312:0x4737  .
    rep.ks-x1001:0x7D62
               :abstract-glyph-of       ks-x1001:0x7D62  .
    rep.cns11643-1:0x454E
               :abstract-glyph-of     cns11643-1:0x454E  .
