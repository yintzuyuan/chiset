a.jis-x0208:0x722F
    a chisegg:abstract-character ;
    :abstract-character-of jis-x0208:0x722F ;
    :denotation-of
        a.ucs:0x9B32         ;
    ideo:radical         193 ; # ⿀ 
    ideo:strokes           0 ;
    ideo:total-strokes    10 ;
    :eq a.ucs_jis:0x9B32          ; # &J97-722F;
    :eq a.jis-x0213-1:0x722F      ; # &J97-722F;
    .
    a.ucs_jis:0x9B32
           :abstract-character-of [ :context domain:jis     ;
                                    :target     ucs:0x9B32  ] .
    a.jis-x0213-1:0x722F
           :abstract-character-of    jis-x0213-1:0x722F  .

rep.adobe-japan1-0:07300
    a chisegg:abstract-glyph ;
    :abstract-glyph-of adobe-japan1-0:07300 ;
    :denotation-of
        a.jis-x0208:0x722F   ;
    ideo:radical         193 ; # ⿀ 
    ideo:strokes           0 ;
    ideo:total-strokes    10 ;
    :eq rep.ucs_jis:0x9B32        ; # &AJ1-07300;
    :eq rep.jis-x0208:0x722F      ; # &I-J90-722F;
    :eq rep.jis-x0213-1:0x722F    ; # &I-JX1-722F;
    :eq rep.gt:61436              ; # &I-GT-61436;
    :eq rep.gt-k:06657            ; # &I-GT-K06657;
    :eq rep.gt-pj-1:29231         ; # &I-GT-61436;
    :eq rep.daikanwa:45672        ; # &I-M-45672;
    :eq rep.shinjigen:9503        ; # &AJ1-07300;
    :subsume
        g2.adobe-japan1-0:07300 ,
        g2.gt:61436          ;
    .
    rep.ucs_jis:0x9B32
               :abstract-glyph-of [ :context domain:jis     ;
                                    :target     ucs:0x9B32  ] .
    rep.jis-x0208:0x722F
               :abstract-glyph-of      jis-x0208:0x722F  .
    rep.jis-x0213-1:0x722F
               :abstract-glyph-of    jis-x0213-1:0x722F  .
    rep.gt:61436
               :abstract-glyph-of             gt:61436   .
    rep.gt-k:06657
               :abstract-glyph-of           gt-k:06657   .
    rep.gt-pj-1:29231
               :abstract-glyph-of        gt-pj-1:29231   .
    rep.daikanwa:45672
               :abstract-glyph-of       daikanwa:45672   .
    rep.shinjigen:9503
               :abstract-glyph-of      shinjigen:9503    .
    g2.adobe-japan1-0:07300
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of adobe-japan1-0:07300 ;
        :eq g2.ucs_jis:0x9B32         ; # &g2-AJ1-07300;
        :eq g2.jis-x0208:0x722F       ; # &g2-AJ1-07300;
        :eq g2.jis-x0213-1:0x722F     ; # &g2-AJ1-07300;
        :eq g2.daikanwa:45672         ; # &g2-AJ1-07300;
        :eq g2.shinjigen:9503         ; # &g2-AJ1-07300;
        :subsume
            repi.daikanwa:45672  ,
            repi.jis-x0208:0x722F ,
            repi.adobe-japan1-6:07300 ;
        .
        g2.ucs_jis:0x9B32
              :abstract-glyph-form-of [ :context domain:jis     ;
                                        :target     ucs:0x9B32  ] .
        g2.jis-x0208:0x722F
              :abstract-glyph-form-of      jis-x0208:0x722F  .
        g2.jis-x0213-1:0x722F
              :abstract-glyph-form-of    jis-x0213-1:0x722F  .
        g2.daikanwa:45672
              :abstract-glyph-form-of       daikanwa:45672   .
        g2.shinjigen:9503
              :abstract-glyph-form-of      shinjigen:9503    .
        repi.daikanwa:45672
            a chisegg:glyph-image ;
            :glyph-image-of daikanwa:45672 ;
            .
        repi.jis-x0208:0x722F
            a chisegg:glyph-image ;
            :glyph-image-of jis-x0208:0x722F ;
            :eq repi.jis-x0213-1:0x722F   ; # &R-J0-722F;
            .
            repi.jis-x0213-1:0x722F
                          :glyph-image-of    jis-x0213-1:0x722F  .
        repi.adobe-japan1-0:07300
            a chisegg:glyph-image ;
            :glyph-image-of adobe-japan1-0:07300 ;
            .
    g2.gt:61436
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of gt:61436 ;
        :eq g2.gt-k:06657             ; # &g2-GT-61436;
        .
        g2.gt-k:06657
              :abstract-glyph-form-of           gt-k:06657   .

