    :eq rep.gt-k:00438            ; # &I-GT-K00438;
    :eq rep.gt-pj-1:15199         ; # &I-GT-20884;
    :eq rep.daikanwa:16253        ; # &I-M-16253;
    :eq rep.shinjigen:3947        ; # &AJ1-02221;
