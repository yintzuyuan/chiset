a.ucs:0x65B9
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x65B9 ;
    ideo:radical          70 ; # ⽅ 
    ideo:strokes           0 ;
    ideo:total-strokes     4 ;
    :eq rep.adobe-japan1-0:03661  ; # &I-AJ1-03661;
    :eq rep.jis-x0208:0x4A7D      ; # &I-J90-4A7D;
    :eq rep.gb2312:0x373D         ; # &I-G0-373D;
    :eq rep.ks-x1001:0x5B30       ; # &I-K0-5B30;
    :eq rep.cns11643-1:0x4549     ; # &I-C1-4549;
    :eq rep.jis-x0213-1:0x4A7D    ; # &I-JX1-4A7D;
    :eq a.big5:0xA4E8             ; # &I-B-A4E8;
    :eq rep.gt:17214              ; # &I-GT-17214;
    :eq rep.gt-k:00490            ; # &I-GT-K00490;
    :eq rep.gt-pj-1:19069         ; # &I-GT-17214;
    :eq rep.daikanwa:13620        ; # &I-M-13620;
    :eq rep.shinjigen:3236        ; # 方
    :subsume
        g2.ucs_unicode:0x65B9 ;
    .
    rep.adobe-japan1-0:03661
               :abstract-glyph-of adobe-japan1-0:03661   .
    rep.jis-x0208:0x4A7D
               :abstract-glyph-of      jis-x0208:0x4A7D  .
    rep.gb2312:0x373D
               :abstract-glyph-of         gb2312:0x373D  .
    rep.ks-x1001:0x5B30
               :abstract-glyph-of       ks-x1001:0x5B30  .
    rep.cns11643-1:0x4549
               :abstract-glyph-of     cns11643-1:0x4549  .
    rep.jis-x0213-1:0x4A7D
               :abstract-glyph-of    jis-x0213-1:0x4A7D  .
    a.big5:0xA4E8
           :abstract-character-of           big5:0xA4E8  .
    rep.gt:17214
               :abstract-glyph-of             gt:17214   .
    rep.gt-k:00490
               :abstract-glyph-of           gt-k:00490   .
    rep.gt-pj-1:19069
               :abstract-glyph-of        gt-pj-1:19069   .
    rep.daikanwa:13620
               :abstract-glyph-of       daikanwa:13620   .
    rep.shinjigen:3236
               :abstract-glyph-of      shinjigen:3236    .
    g2.ucs_unicode:0x65B9
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of [ :context domain:unicode ;
                                  :target     ucs:0x65B9  ] ;
        :eq g2.adobe-japan1-0:03661   ; # &g2-AJ1-03661;
        :eq g2.gb2312:0x373D          ; # &g2-AJ1-03661;
        :eq g2.ks-x1001:0x5B30        ; # &g2-AJ1-03661;
        :eq g2.jis-x0208:0x4A7D       ; # &g2-AJ1-03661;
        :eq g2.cns11643-1:0x4549      ; # &g2-AJ1-03661;
        :eq g2.jis-x0213-1:0x4A7D     ; # &g2-AJ1-03661;
        :eq g2.gt:17214               ; # &g2-AJ1-03661;
        :eq g2.gt-k:00490             ; # &g2-AJ1-03661;
        :eq g2.daikanwa:13620         ; # &g2-AJ1-03661;
        :eq g2.shinjigen:3236         ; # &g2-AJ1-03661;
        :subsume
            repi.daikanwa:13620  ,
            repi.jis-x0208:0x4A7D ,
            repi.adobe-japan1-6:03661 ,
            repi.ks-x1001:0x5B30 ,
