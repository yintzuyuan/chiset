a.ucs:0x6BD4
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x6BD4 ;
    ideo:radical          81 ; # ⽐ 
    ideo:strokes           0 ;
    ideo:total-strokes     4 ;
    :eq rep.adobe-japan1-0:03450  ; # &I-AJ1-03450;
    :eq rep.jis-x0208:0x4866      ; # &I-J90-4866;
    :eq rep.gb2312:0x3148         ; # &I-G0-3148;
    :eq rep.ks-x1001:0x5D6F       ; # &I-K0-5D6F;
    :eq rep.cns11643-1:0x4552     ; # &I-C1-4552;
    :eq rep.jis-x0213-1:0x4866    ; # &I-JX1-4866;
    :eq a.big5:0xA4F1             ; # &I-B-A4F1;
    :eq rep.gt:21460              ; # &I-GT-21460;
    :eq rep.gt-k:00477            ; # &I-GT-K00477;
    :eq rep.gt-pj-1:18534         ; # &I-GT-21460;
    :eq rep.daikanwa:16743        ; # &I-M-16743;
    :eq rep.shinjigen:4012        ; # 比
    :subsume
        g2.ucs_unicode:0x6BD4 ,
        g2.cns11643-1:0x4552 ,
        repi.hng-kar:10140   ,
        repi.hng-khi:04540   ,
        repi.hng-khm:04030   ;
    .
    rep.adobe-japan1-0:03450
               :abstract-glyph-of adobe-japan1-0:03450   .
    rep.jis-x0208:0x4866
               :abstract-glyph-of      jis-x0208:0x4866  .
    rep.gb2312:0x3148
               :abstract-glyph-of         gb2312:0x3148  .
    rep.ks-x1001:0x5D6F
               :abstract-glyph-of       ks-x1001:0x5D6F  .
    rep.cns11643-1:0x4552
               :abstract-glyph-of     cns11643-1:0x4552  .
    rep.jis-x0213-1:0x4866
               :abstract-glyph-of    jis-x0213-1:0x4866  .
    a.big5:0xA4F1
           :abstract-character-of           big5:0xA4F1  .
    rep.gt:21460
               :abstract-glyph-of             gt:21460   .
    rep.gt-k:00477
               :abstract-glyph-of           gt-k:00477   .
    rep.gt-pj-1:18534
               :abstract-glyph-of        gt-pj-1:18534   .
    rep.daikanwa:16743
