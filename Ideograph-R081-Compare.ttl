    rep.shinjigen:4012
               :abstract-glyph-of      shinjigen:4012    .
    g2.ucs_unicode:0x6BD4
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of [ :context domain:unicode ;
                                  :target     ucs:0x6BD4  ] ;
        :eq g2.adobe-japan1-0:03450   ; # &g2-AJ1-03450;
        :eq g2.gb2312:0x3148          ; # &g2-AJ1-03450;
        :eq g2.ks-x1001:0x5D6F        ; # &g2-AJ1-03450;
        :eq g2.jis-x0208:0x4866       ; # &g2-AJ1-03450;
        :eq g2.jis-x0213-1:0x4866     ; # &g2-AJ1-03450;
        :eq g2.gt:21460               ; # &g2-AJ1-03450;
        :eq g2.gt-k:00477             ; # &g2-AJ1-03450;
        :eq g2.daikanwa:16743         ; # &g2-AJ1-03450;
        :eq g2.shinjigen:4012         ; # &g2-AJ1-03450;
        :subsume
            repi.daikanwa:16743  ,
            repi.jis-x0208:0x4866 ,
