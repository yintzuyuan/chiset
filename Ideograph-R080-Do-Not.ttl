a.ucs:0x6BCB
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x6BCB ;
    ideo:radical          80 ; # ⽏ 
    ideo:strokes           0 ;
    ideo:total-strokes     4 ;
    :sound               [ :context domain:ja...on...go ;
                           :target  ( "mu" ) ;
                         ] ;
    :sound               [ :context domain:ja...on...kan ;
                           :target  ( "bu" ) ;
                         ] ;
    .

rep.adobe-japan1-0:05368
    a chisegg:abstract-glyph ;
    :abstract-glyph-of adobe-japan1-0:05368 ;
    :denotation-of
        a.ucs:0x6BCB         ;
    ideo:radical          80 ; # ⽏ 
    ideo:strokes           0 ;
    ideo:total-strokes     4 ;
    :sound               [ :context domain:ja...on...go...p1 ;
                           :target  ( "mu" ) ;
                         ] ;
    :sound               [ :context domain:ja...on...go...p2 ;
                           :target  ( "mu" ) ;
                         ] ;
    :sound               [ :context domain:ja...on...go...p3 ;
                           :target  ( "mu" ) ;
                         ] ;
    :sound               [ :context domain:ja...on...kan...p1 ;
                           :sources chisebib:daikanwa ,
                                    chisebib:shinjigen_1ed ;
                           :target  ( "bu" ) ;
                         ] ;
    :sound               [ :context domain:ja...on...kan...p2 ;
                           :target  ( "bou" ) ;
                         ] ;
    :sound               [ :context domain:ja...on...kan...p3 ;
                           :target  ( "bu" ) ;
                         ] ;
    :eq rep.ucs_jis:0x6BCB        ; # &AJ1-05368;
    :eq rep.jis-x0208:0x5D59      ; # &I-J90-5D59;
    :eq rep.ks-x1001:0x596C       ; # &I-K0-596C;
    :eq rep.jis-x0213-1:0x5D59    ; # &I-JX1-5D59;
    :eq rep.gt:21437              ; # &I-GT-21437;
    :eq rep.gt-k:00538            ; # &I-GT-K00538;
    :eq rep.gt-pj-1:23897         ; # &I-GT-21437;
    :eq rep.daikanwa:16721        ; # &I-M-16721;
    :eq rep.shinjigen:4007        ; # &AJ1-05368;
    :subsume
        g2.adobe-japan1-0:05368 ,
        repi.hng-kar:10110   ,
        repi.hng-khm:00750   ;
    .
    rep.ucs_jis:0x6BCB
               :abstract-glyph-of [ :context domain:jis     ;
                                    :target     ucs:0x6BCB  ] .
    rep.jis-x0208:0x5D59
               :abstract-glyph-of      jis-x0208:0x5D59  .
    rep.ks-x1001:0x596C
               :abstract-glyph-of       ks-x1001:0x596C  .
    rep.jis-x0213-1:0x5D59
               :abstract-glyph-of    jis-x0213-1:0x5D59  .
    rep.gt:21437
               :abstract-glyph-of             gt:21437   .
    rep.gt-k:00538
               :abstract-glyph-of           gt-k:00538   .
    rep.gt-pj-1:23897
               :abstract-glyph-of        gt-pj-1:23897   .
    rep.daikanwa:16721
               :abstract-glyph-of       daikanwa:16721   .
    rep.shinjigen:4007
               :abstract-glyph-of      shinjigen:4007    .
    g2.adobe-japan1-0:05368
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of adobe-japan1-0:05368 ;
        :rep.decomposition   [ :context domain:cid     ;
                               :target  a.ucs:0x6BCB         ,
                                        a.ucs:0xE0100        ] ;
        :eq g2.ucs_jis:0x6BCB         ; # &g2-AJ1-05368;
        :eq g2.ucs_ks:0x6BCB          ; # &g2-AJ1-05368;
        :eq g2.ks-x1001:0x596C        ; # &g2-AJ1-05368;
        :eq g2.jis-x0208:0x5D59       ; # &g2-AJ1-05368;
        :eq g2.jis-x0213-1:0x5D59     ; # &g2-AJ1-05368;
        :eq g2.gt:21437               ; # &g2-AJ1-05368;
        :eq g2.gt-k:00538             ; # &g2-AJ1-05368;
        :eq g2.daikanwa:16721         ; # &g2-AJ1-05368;
        :eq g2.shinjigen:4007         ; # &g2-AJ1-05368;
        :subsume
            repi.daikanwa:16721  ,
            repi.jis-x0208:0x5D59 ,
            repi.adobe-japan1-6:05368 ,
            repi.gt:21437        ,
            repi.ks-x1001:0x596C ;
        .
        g2.ucs_jis:0x6BCB
              :abstract-glyph-form-of [ :context domain:jis     ;
                                        :target     ucs:0x6BCB  ] .
        g2.ucs_ks:0x6BCB
              :abstract-glyph-form-of [ :context domain:ks      ;
                                        :target     ucs:0x6BCB  ] .
        g2.ks-x1001:0x596C
              :abstract-glyph-form-of       ks-x1001:0x596C  .
        g2.jis-x0208:0x5D59
              :abstract-glyph-form-of      jis-x0208:0x5D59  .
        g2.jis-x0213-1:0x5D59
              :abstract-glyph-form-of    jis-x0213-1:0x5D59  .
        g2.gt:21437
              :abstract-glyph-form-of             gt:21437   .
        g2.gt-k:00538
              :abstract-glyph-form-of           gt-k:00538   .
        g2.daikanwa:16721
              :abstract-glyph-form-of       daikanwa:16721   .
        g2.shinjigen:4007
              :abstract-glyph-form-of      shinjigen:4007    .
        repi.daikanwa:16721
            a chisegg:glyph-image ;
            :glyph-image-of daikanwa:16721 ;
            .
        repi.jis-x0208:0x5D59
            a chisegg:glyph-image ;
            :glyph-image-of jis-x0208:0x5D59 ;
            :eq repi.jis-x0213-1:0x5D59   ; # &R-J0-5D59;
            .
            repi.jis-x0213-1:0x5D59
                          :glyph-image-of    jis-x0213-1:0x5D59  .
        repi.adobe-japan1-0:05368
            a chisegg:glyph-image ;
            :glyph-image-of adobe-japan1-0:05368 ;
            .
        repi.gt:21437
            a chisegg:glyph-image ;
            :glyph-image-of gt:21437 ;
            :eq repi.gt-k:00538           ; # &R-GT-21437;
            .
            repi.gt-k:00538
                          :glyph-image-of           gt-k:00538   .
        repi.ks-x1001:0x596C
            a chisegg:glyph-image ;
            :glyph-image-of ks-x1001:0x596C ;
            :eq repi.ucs_ks:0x6BCB        ; # &R-K0-596C;
            .
            repi.ucs_ks:0x6BCB
                          :glyph-image-of [ :context domain:ks      ;
                                            :target     ucs:0x6BCB  ] .
    repi.hng-kar:10110
        a chisegg:glyph-image ;
        :glyph-image-of hng-kar:10110 ;
        :form-of             a.ucs:0x6BCB         ;
        .
    repi.hng-khm:00750
        a chisegg:glyph-image ;
        :glyph-image-of hng-khm:00750 ;
        :form-of             a.ucs:0x6BCD         ;
        .

