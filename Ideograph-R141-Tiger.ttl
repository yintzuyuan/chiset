a.ucs:0x864D
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x864D ;
    ideo:radical         141 ; # ⾌ 
    ideo:strokes           0 ;
    ideo:total-strokes     6 ;
    :eq rep.adobe-japan1-0:06479  ; # &I-AJ1-06479;
    :eq rep.jis-x0208:0x6948      ; # &I-J90-6948;
    :eq rep.gb2312:0x722E         ; # &I-G0-722E;
    :eq rep.cns11643-2:0x226F     ; # &I-C2-226F;
    :eq rep.jis-x0213-1:0x6948    ; # &I-JX1-6948;
    :eq a.big5:0xCA4F             ; # &I-B-CA4F;
    :eq rep.gt:44176              ; # &I-GT-44176;
    :eq rep.gt-k:01740            ; # &I-GT-K01740;
    :eq rep.gt-pj-1:26952         ; # &I-GT-44176;
    :eq rep.daikanwa:32674        ; # &I-M-32674;
    :subsume
        g2.ucs_unicode:0x864D ,
        g2.cns11643-2:0x226F ;
    .
    rep.adobe-japan1-0:06479
               :abstract-glyph-of adobe-japan1-0:06479   .
    rep.jis-x0208:0x6948
               :abstract-glyph-of      jis-x0208:0x6948  .
    rep.gb2312:0x722E
               :abstract-glyph-of         gb2312:0x722E  .
    rep.cns11643-2:0x226F
               :abstract-glyph-of     cns11643-2:0x226F  .
    rep.jis-x0213-1:0x6948
               :abstract-glyph-of    jis-x0213-1:0x6948  .
    a.big5:0xCA4F
           :abstract-character-of           big5:0xCA4F  .
    rep.gt:44176
               :abstract-glyph-of             gt:44176   .
    rep.gt-k:01740
               :abstract-glyph-of           gt-k:01740   .
    rep.gt-pj-1:26952
               :abstract-glyph-of        gt-pj-1:26952   .
    rep.daikanwa:32674
               :abstract-glyph-of       daikanwa:32674   .
    g2.ucs_unicode:0x864D
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of [ :context domain:unicode ;
                                  :target     ucs:0x864D  ] ;
        :eq g2.adobe-japan1-0:06479   ; # &g2-AJ1-06479;
        :eq g2.gb2312:0x722E          ; # &g2-AJ1-06479;
        :eq g2.jis-x0208:0x6948       ; # &g2-AJ1-06479;
        :eq g2.jis-x0213-1:0x6948     ; # &g2-AJ1-06479;
        :eq g2.gt:44176               ; # &g2-AJ1-06479;
        :eq g2.gt-k:01740             ; # &g2-AJ1-06479;
        :eq g2.daikanwa:32674         ; # &g2-AJ1-06479;
        :subsume
            repi.daikanwa:32674  ,
            repi.jis-x0208:0x6948 ,
            repi.adobe-japan1-6:06479 ,
            repi.gt:44176        ,
            repi.ucs_unicode:0x864D ;
        .
        g2.adobe-japan1-0:06479
              :abstract-glyph-form-of adobe-japan1-0:06479   .
        g2.gb2312:0x722E
              :abstract-glyph-form-of         gb2312:0x722E  .
        g2.jis-x0208:0x6948
              :abstract-glyph-form-of      jis-x0208:0x6948  .
        g2.jis-x0213-1:0x6948
              :abstract-glyph-form-of    jis-x0213-1:0x6948  .
        g2.gt:44176
              :abstract-glyph-form-of             gt:44176   .
        g2.gt-k:01740
              :abstract-glyph-form-of           gt-k:01740   .
        g2.daikanwa:32674
              :abstract-glyph-form-of       daikanwa:32674   .
        repi.daikanwa:32674
            a chisegg:glyph-image ;
            :glyph-image-of daikanwa:32674 ;
            .
        repi.jis-x0208:0x6948
            a chisegg:glyph-image ;
            :glyph-image-of jis-x0208:0x6948 ;
            :eq repi.jis-x0213-1:0x6948   ; # &R-J0-6948;
            .
            repi.jis-x0213-1:0x6948
                          :glyph-image-of    jis-x0213-1:0x6948  .
        repi.adobe-japan1-0:06479
            a chisegg:glyph-image ;
            :glyph-image-of adobe-japan1-0:06479 ;
            .
        repi.gt:44176
            a chisegg:glyph-image ;
            :glyph-image-of gt:44176 ;
            :eq repi.gt-k:01740           ; # &R-GT-44176;
            .
            repi.gt-k:01740
                          :glyph-image-of           gt-k:01740   .
        repi.ucs_unicode:0x864D
            a chisegg:glyph-image ;
            :glyph-image-of [ :context domain:unicode ;
                              :target     ucs:0x864D  ] ;
            .
    g2.cns11643-2:0x226F
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of cns11643-2:0x226F ;
        :eq g2.ucs_cns:0x864D         ; # &g2-CU+864D;
