a.ucs_component:0x5E7A
    a chisegg:abstract-character ;
    :abstract-character-of [ :context domain:component ;
                             :target     ucs:0x5E7A  ] ;
    ideo:radical          52 ; # ⼳ 
    ideo:strokes           0 ;
    ideo:total-strokes     3 ;
    :eq bucs:0x5E7A               ; # &BUCS+5E7A;
    :eq a.iwds-1:0129             ; # &BUCS+5E7A;
    .
    bucs:0x5E7A
        :super-abstract-character-of [ :context domain:bucs    ;
                                       :target     ucs:0x5E7A  ] .
    a.iwds-1:0129
           :abstract-character-of         iwds-1:0129    .

a.ucs:0x5E7A
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x5E7A ;
    :denotation-of
        a.ucs_component:0x5E7A ;
    ideo:radical          52 ; # ⼳ 
    ideo:strokes           0 ;
    ideo:total-strokes     3 ;
    :eq rep.adobe-japan1-0:04739  ; # &I-AJ1-04739;
    :eq rep.jis-x0208:0x5676      ; # &I-J90-5676;
    :eq rep.gb2312:0x675B         ; # &I-G0-675B;
    :eq rep.cns11643-3:0x213D     ; # &I-C3-213D;
    :eq rep.jis-x0213-1:0x5676    ; # &I-JX1-5676;
    :eq rep.big5-cdp:0x8B44       ; # &I-CDP-8B44;
    :eq rep.gt:11582              ; # &I-GT-11582;
    :eq rep.gt-k:00225            ; # &I-GT-K00225;
    :eq rep.gt-pj-1:22134         ; # &I-GT-11582;
    :eq rep.daikanwa:09189        ; # &I-M-09189;
    :eq rep.shinjigen:2160        ; # 幺
    .
    rep.adobe-japan1-0:04739
               :abstract-glyph-of adobe-japan1-0:04739   .
    rep.jis-x0208:0x5676
               :abstract-glyph-of      jis-x0208:0x5676  .
    rep.gb2312:0x675B
               :abstract-glyph-of         gb2312:0x675B  .
    rep.cns11643-3:0x213D
               :abstract-glyph-of     cns11643-3:0x213D  .
    rep.jis-x0213-1:0x5676
               :abstract-glyph-of    jis-x0213-1:0x5676  .
    rep.big5-cdp:0x8B44
               :abstract-glyph-of       big5-cdp:0x8B44  .
    rep.gt:11582
               :abstract-glyph-of             gt:11582   .
    rep.gt-k:00225
               :abstract-glyph-of           gt-k:00225   .
    rep.gt-pj-1:22134
               :abstract-glyph-of        gt-pj-1:22134   .
    rep.daikanwa:09189
               :abstract-glyph-of       daikanwa:09189   .
    rep.shinjigen:2160
               :abstract-glyph-of      shinjigen:2160    .

a.ucs:0x2E93
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x2E93 ;
    :denotation-of
        a.ucs:0x5E7A         ;
    :name                 "CJK RADICAL THREAD" ;
    :general-category     "(symbol other)" ; # Informative Category
    :bidi-category        "ON" ;
    :mirrored             "nil" ;
    :from.identical      [ :context domain:component ;
                           :target  a.ucs:0x5E7A         ] ;
    .

