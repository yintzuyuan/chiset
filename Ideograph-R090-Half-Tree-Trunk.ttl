a.ucs_component:0x723F
    a chisegg:abstract-character ;
    :abstract-character-of [ :context domain:component ;
                             :target     ucs:0x723F  ] ;
    ideo:radical          90 ; # ⽙ 
    ideo:strokes           0 ;
    :eq a.iwds-1:0363             ; # &IWDS1-363;
    .
    a.iwds-1:0363
           :abstract-character-of         iwds-1:0363    .

a.ucs:0x723F
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x723F ;
    :denotation-of
        a.ucs_component:0x723F ;
    ideo:radical          90 ; # ⽙ 
    ideo:strokes           0 ;
    ideo:total-strokes     4 ;
    :eq rep.adobe-japan1-0:05606  ; # &I-AJ1-05606;
    :eq rep.jis-x0208:0x602D      ; # &I-J90-602D;
    :eq rep.gb2312:0x635D         ; # &I-G0-635D;
    :eq rep.cns11643-2:0x2142     ; # &I-C2-2142;
    :eq rep.jis-x0213-1:0x602D    ; # &I-JX1-602D;
    :eq a.big5:0xC962             ; # &I-B-C962;
    :eq rep.gt:25375              ; # &I-GT-25375;
    :eq rep.gt-k:00543            ; # &I-GT-K00543;
    :eq rep.gt-pj-1:24621         ; # &I-GT-25375;
    :eq rep.daikanwa:19758        ; # &I-M-19758;
    :eq rep.shinjigen:4717        ; # 爿
    :subsume
        g2.ucs_unicode:0x723F ,
        g2.cns11643-2:0x2142 ;
    .
    rep.adobe-japan1-0:05606
               :abstract-glyph-of adobe-japan1-0:05606   .
    rep.jis-x0208:0x602D
               :abstract-glyph-of      jis-x0208:0x602D  .
    rep.gb2312:0x635D
               :abstract-glyph-of         gb2312:0x635D  .
    rep.cns11643-2:0x2142
               :abstract-glyph-of     cns11643-2:0x2142  .
    rep.jis-x0213-1:0x602D
               :abstract-glyph-of    jis-x0213-1:0x602D  .
    a.big5:0xC962
           :abstract-character-of           big5:0xC962  .
    rep.gt:25375
               :abstract-glyph-of             gt:25375   .
    rep.gt-k:00543
               :abstract-glyph-of           gt-k:00543   .
    rep.gt-pj-1:24621
               :abstract-glyph-of        gt-pj-1:24621   .
    rep.daikanwa:19758
               :abstract-glyph-of       daikanwa:19758   .
    rep.shinjigen:4717
               :abstract-glyph-of      shinjigen:4717    .
    g2.ucs_unicode:0x723F
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of [ :context domain:unicode ;
                                  :target     ucs:0x723F  ] ;
        :eq g2.adobe-japan1-0:05606   ; # &g2-AJ1-05606;
        :eq g2.gb2312:0x635D          ; # &g2-AJ1-05606;
        :eq g2.jis-x0208:0x602D       ; # &g2-AJ1-05606;
        :eq g2.jis-x0213-1:0x602D     ; # &g2-AJ1-05606;
        :eq g2.gt:25375               ; # &g2-AJ1-05606;
        :eq g2.gt-k:00543             ; # &g2-AJ1-05606;
        :eq g2.daikanwa:19758         ; # &g2-AJ1-05606;
        :eq g2.shinjigen:4717         ; # &g2-AJ1-05606;
        :subsume
            repi.daikanwa:19758  ,
            repi.jis-x0208:0x602D ,
            repi.adobe-japan1-6:05606 ,
            repi.ucs_unicode:0x723F ,
            repi.gt:25375        ;
        .
        g2.adobe-japan1-0:05606
              :abstract-glyph-form-of adobe-japan1-0:05606   .
        g2.gb2312:0x635D
              :abstract-glyph-form-of         gb2312:0x635D  .
        g2.jis-x0208:0x602D
              :abstract-glyph-form-of      jis-x0208:0x602D  .
        g2.jis-x0213-1:0x602D
              :abstract-glyph-form-of    jis-x0213-1:0x602D  .
        g2.gt:25375
              :abstract-glyph-form-of             gt:25375   .
        g2.gt-k:00543
              :abstract-glyph-form-of           gt-k:00543   .
        g2.daikanwa:19758
              :abstract-glyph-form-of       daikanwa:19758   .
        g2.shinjigen:4717
              :abstract-glyph-form-of      shinjigen:4717    .
        repi.daikanwa:19758
            a chisegg:glyph-image ;
            :glyph-image-of daikanwa:19758 ;
            .
        repi.jis-x0208:0x602D
            a chisegg:glyph-image ;
            :glyph-image-of jis-x0208:0x602D ;
            :eq repi.jis-x0213-1:0x602D   ; # &R-J0-602D;
            .
            repi.jis-x0213-1:0x602D
                          :glyph-image-of    jis-x0213-1:0x602D  .
        repi.adobe-japan1-0:05606
            a chisegg:glyph-image ;
            :glyph-image-of adobe-japan1-0:05606 ;
            .
        repi.ucs_unicode:0x723F
            a chisegg:glyph-image ;
            :glyph-image-of [ :context domain:unicode ;
                              :target     ucs:0x723F  ] ;
            .
        repi.gt:25375
            a chisegg:glyph-image ;
            :glyph-image-of gt:25375 ;
            :eq repi.gt-k:00543           ; # &R-GT-25375;
            .
            repi.gt-k:00543
                          :glyph-image-of           gt-k:00543   .
    g2.cns11643-2:0x2142
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of cns11643-2:0x2142 ;
        :eq g2.ucs_cns:0x723F         ; # &g2-CU+723F;
        .
        g2.ucs_cns:0x723F
              :abstract-glyph-form-of [ :context domain:cns     ;
                                        :target     ucs:0x723F  ] .

