        rep.ucs_iso:0x23261  ;
    .
    rep.daikanwa:09581
        a chisegg:abstract-glyph ;
        :abstract-glyph-of daikanwa:09581 ;
        .
    rep.ucs_iso:0x23261
        a chisegg:abstract-glyph ;
        :abstract-glyph-of [ :context domain:iso     ;
                             :target     ucs:0x23261 ] ;
        :eq rep.hanziku-4:0xE3B1      ; # &HZK04-E3B1;
        .
        rep.hanziku-4:0xE3B1
                   :abstract-glyph-of      hanziku-4:0xE3B1  .

a.ucs:0x262EA
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x262EA ;
    ideo:radical          54 ; # ⼵ 
    ideo:strokes          11 ;
    ideo:total-strokes    14 ;
    :subsume
        rep.daikanwa:09582   ,
        rep.ucs_iso:0x262EA  ;
    .
    rep.daikanwa:09582
        a chisegg:abstract-glyph ;
        :abstract-glyph-of daikanwa:09582 ;
        .
    rep.ucs_iso:0x262EA
        a chisegg:abstract-glyph ;
        :abstract-glyph-of [ :context domain:iso     ;
                             :target     ucs:0x262EA ] ;
        .

