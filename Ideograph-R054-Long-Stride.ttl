a.ucs:0x5EF4
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x5EF4 ;
    ideo:radical          54 ; # ⼵ 
    ideo:strokes           0 ;
    ideo:total-strokes     3 ;
    :eq rep.adobe-japan1-0:04761  ; # &I-AJ1-04761;
    :eq rep.jis-x0208:0x572E      ; # &I-J90-572E;
    :eq rep.gb2312:0x5B48         ; # &I-G0-5B48;
    :eq rep.cns11643-3:0x213F     ; # &I-C3-213F;
    :eq rep.jis-x0213-1:0x572E    ; # &I-JX1-572E;
    :eq rep.big5-cdp:0x8BD4       ; # &I-CDP-8BD4;
    :eq rep.gt:12051              ; # &I-GT-12051;
    :eq rep.gt-k:00230            ; # &I-GT-K00230;
    :eq rep.gt-pj-1:22318         ; # &I-GT-12051;
    :eq rep.daikanwa:09566        ; # &I-M-09566;
    :subsume
        g2.adobe-japan1-0:04761 ,
        g2.ucs_unicode:0x5EF4 ;
    .
    rep.adobe-japan1-0:04761
               :abstract-glyph-of adobe-japan1-0:04761   .
    rep.jis-x0208:0x572E
               :abstract-glyph-of      jis-x0208:0x572E  .
    rep.gb2312:0x5B48
               :abstract-glyph-of         gb2312:0x5B48  .
    rep.cns11643-3:0x213F
               :abstract-glyph-of     cns11643-3:0x213F  .
    rep.jis-x0213-1:0x572E
               :abstract-glyph-of    jis-x0213-1:0x572E  .
    rep.big5-cdp:0x8BD4
               :abstract-glyph-of       big5-cdp:0x8BD4  .
    rep.gt:12051
               :abstract-glyph-of             gt:12051   .
    rep.gt-k:00230
               :abstract-glyph-of           gt-k:00230   .
    rep.gt-pj-1:22318
               :abstract-glyph-of        gt-pj-1:22318   .
    rep.daikanwa:09566
               :abstract-glyph-of       daikanwa:09566   .
    g2.adobe-japan1-0:04761
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of adobe-japan1-0:04761 ;
        :rep.decomposition   [ :context domain:cid     ;
                               :target  a.ucs:0x5EF4         ,
                                        a.ucs:0xE0100        ] ;
        :eq g2.ucs_jis:0x5EF4         ; # &g2-AJ1-04761;
        :eq g2.jis-x0208:0x572E       ; # &g2-AJ1-04761;
        :eq g2.jis-x0213-1:0x572E     ; # &g2-AJ1-04761;
        :eq g2.gt:12051               ; # &g2-AJ1-04761;
        :eq g2.gt-k:00230             ; # &g2-AJ1-04761;
        :eq g2.daikanwa:09566         ; # &g2-AJ1-04761;
        :subsume
            repi.daikanwa:09566  ,
            repi.jis-x0208:0x572E ,
            repi.adobe-japan1-6:04761 ,
            repi.gt:12051        ;
        .
        g2.ucs_jis:0x5EF4
              :abstract-glyph-form-of [ :context domain:jis     ;
                                        :target     ucs:0x5EF4  ] .
        g2.jis-x0208:0x572E
              :abstract-glyph-form-of      jis-x0208:0x572E  .
        g2.jis-x0213-1:0x572E
              :abstract-glyph-form-of    jis-x0213-1:0x572E  .
        g2.gt:12051
              :abstract-glyph-form-of             gt:12051   .
        g2.gt-k:00230
              :abstract-glyph-form-of           gt-k:00230   .
        g2.daikanwa:09566
              :abstract-glyph-form-of       daikanwa:09566   .
        repi.daikanwa:09566
            a chisegg:glyph-image ;
            :glyph-image-of daikanwa:09566 ;
            .
        repi.jis-x0208:0x572E
            a chisegg:glyph-image ;
            :glyph-image-of jis-x0208:0x572E ;
            :eq repi.jis-x0213-1:0x572E   ; # &R-J0-572E;
            .
            repi.jis-x0213-1:0x572E
                          :glyph-image-of    jis-x0213-1:0x572E  .
        repi.adobe-japan1-0:04761
            a chisegg:glyph-image ;
            :glyph-image-of adobe-japan1-0:04761 ;
            .
        repi.gt:12051
            a chisegg:glyph-image ;
            :glyph-image-of gt:12051 ;
            :eq repi.gt-k:00230           ; # &R-GT-12051;
            .
            repi.gt-k:00230
                          :glyph-image-of           gt-k:00230   .
    g2.ucs_unicode:0x5EF4
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of [ :context domain:unicode ;
                                  :target     ucs:0x5EF4  ] ;
        :g2.ucs_JP...hanazono      rdf:nil ;
        :eq g2.gb2312:0x5B48          ; # &g2-CDP-8BD4;
        :eq g2.cns11643-3:0x213F      ; # &g2-CDP-8BD4;
        :eq g2.big5-cdp:0x8BD4        ; # &g2-CDP-8BD4;
        :subsume
            repi.big5-cdp:0x8BD4 ,
            repi.cns11643-3:0x213F ,
            repi.ucs_unicode:0x5EF4 ;
        .
        g2.gb2312:0x5B48
              :abstract-glyph-form-of         gb2312:0x5B48  .
        g2.cns11643-3:0x213F
              :abstract-glyph-form-of     cns11643-3:0x213F  .
        g2.big5-cdp:0x8BD4
              :abstract-glyph-form-of       big5-cdp:0x8BD4  .
        repi.big5-cdp:0x8BD4
            a chisegg:glyph-image ;
            :glyph-image-of big5-cdp:0x8BD4 ;
            .
        repi.cns11643-3:0x213F
            a chisegg:glyph-image ;
            :glyph-image-of cns11643-3:0x213F ;
            .
        repi.ucs_unicode:0x5EF4
            a chisegg:glyph-image ;
            :glyph-image-of [ :context domain:unicode ;
                              :target     ucs:0x5EF4  ] ;
            .

a.ucs:0x389F
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x389F ;
    ideo:radical          54 ; # ⼵ 
    isd:structure [ a idc:⿸ ;
        isd:surround a.ucs:0x5EF4 ; # 廴
        isd:filling  a.ucs:0x6B62   # 止
    ] ;
    :sound               [ :context domain:ja...on ;
                           :target  ( "teN" ) ;
                         ] ;
    .

rep.ucs_unicode:0x389F
    a chisegg:abstract-glyph ;
    :abstract-glyph-of [ :context domain:unicode ;
                         :target     ucs:0x389F  ] ;
    :denotation-of
        a.ucs:0x389F         ;
    ideo:radical          54 ; # ⼵ 
    ideo:strokes           3 ;
    ideo:total-strokes     6 ;
    isd:structure [ a idc:⿸ ;
        isd:surround a.ucs:0x5EF4 ; # 廴
        isd:filling  rep.hanyo-denshi...ks:184490   # &HD-KS-184490;
    ] ;
    :rep.ucs_JP...hanazono     rdf:nil ;
    :eq rep.daikanwa:09567        ; # &M-09567;
    :subsume
        g2.daikanwa:09567    ,
        g2.ucs_unicode:0x389F ;
    .
    rep.daikanwa:09567
               :abstract-glyph-of       daikanwa:09567   .
    g2.daikanwa:09567
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of daikanwa:09567 ;
        .
    g2.ucs_unicode:0x389F
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of [ :context domain:unicode ;
                                  :target     ucs:0x389F  ] ;
        :g2.ucs_JP...hanazono      rdf:nil ;
        .

