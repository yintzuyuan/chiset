a.ucs:0x8C45
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x8C45 ;
    ideo:radical         150 ; # ⾕ 
    ideo:strokes          16 ;
    ideo:total-strokes    23 ;
    isd:structure [ a idc:⿰ ;
