    :eq rep.jis-x0208:0x432B      ; # &I-J90-432B;
    :eq rep.gb2312:0x3948         ; # &I-G0-3948;
    :eq rep.ks-x1001:0x4D5B       ; # &I-K0-4D5B;
    :eq rep.cns11643-1:0x4B47     ; # &I-C1-4B47;
