    ] ;
    :eq rep.jis-x0212:0x5E66      ; # &I-JSP-5E66;
    :eq rep.cns11643-2:0x6F52     ; # &I-C2-6F52;
    :eq rep.jis-x0213-2:0x787B    ; # &I-JX2-787B;
    :eq a.big5:0xF844             ; # &I-B-F844;
    :eq rep.hanyo-denshi...jb:0x5E66 ; # &I-HD-JB-5E66;
    :eq rep.daikanwa:36241        ; # &I-M-36241;
    :eq rep.jef-china3:0x65DA     ; # &I-JC3-65DA;
    :subsume
        g2.ucs_unicode:0x8C45 ,
        g2.cns11643-2:0x6F52 ;
    .
    rep.jis-x0212:0x5E66
               :abstract-glyph-of      jis-x0212:0x5E66  .
    rep.cns11643-2:0x6F52
               :abstract-glyph-of     cns11643-2:0x6F52  .
    rep.jis-x0213-2:0x787B
               :abstract-glyph-of    jis-x0213-2:0x787B  .
    a.big5:0xF844
           :abstract-character-of           big5:0xF844  .
    rep.hanyo-denshi...jb:0x5E66
               :abstract-glyph-of hanyo-denshi...jb:0x5E66  .
    rep.daikanwa:36241
               :abstract-glyph-of       daikanwa:36241   .
    rep.jef-china3:0x65DA
               :abstract-glyph-of     jef-china3:0x65DA  .
    g2.ucs_unicode:0x8C45
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of [ :context domain:unicode ;
                                  :target     ucs:0x8C45  ] ;
        :rep.decomposition   [ :context domain:hanyo-denshi ;
                               :target  a.ucs:0x8C45         ,
                                        a.ucs:0xE0101        ] ;
        :eq g2.jis-x0212:0x5E66       ; # &g2-HD-JB-5E66;
        :eq g2.jis-x0213-2:0x787B     ; # &g2-HD-JB-5E66;
        :eq g2.hanyo-denshi...jb:0x5E66 ; # &g2-HD-JB-5E66;
        :eq g2.daikanwa:36241         ; # &g2-HD-JB-5E66;
        :eq g2.jef-china3:0x65DA      ; # &g2-HD-JB-5E66;
        :subsume
            repi.daikanwa:36241  ,
            repi.hanyo-denshi...jb:0x5E66 ,
            repi.jef-china3:0x65DA ,
            repi.ucs_unicode:0x8C45 ;
        .
        g2.jis-x0212:0x5E66
              :abstract-glyph-form-of      jis-x0212:0x5E66  .
        g2.jis-x0213-2:0x787B
              :abstract-glyph-form-of    jis-x0213-2:0x787B  .
        g2.hanyo-denshi...jb:0x5E66
              :abstract-glyph-form-of hanyo-denshi...jb:0x5E66  .
        g2.daikanwa:36241
              :abstract-glyph-form-of       daikanwa:36241   .
        g2.jef-china3:0x65DA
              :abstract-glyph-form-of     jef-china3:0x65DA  .
        repi.daikanwa:36241
