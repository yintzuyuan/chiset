a.ucs_component:0x8C37
    a chisegg:abstract-character ;
    :abstract-character-of [ :context domain:component ;
                             :target     ucs:0x8C37  ] ;
    ideo:radical         150 ; # ⾕ 
    ideo:strokes           0 ;
    ideo:total-strokes     7 ;
    :eq a.iwds-1:0132             ; # &A-compU+8C37;
    .
    a.iwds-1:0132
           :abstract-character-of         iwds-1:0132    .

a.ucs:0x8C37
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x8C37 ;
    :from.denotational_component
        a.ucs_component:0x8C37 ;
    ideo:radical         150 ; # ⾕ 
    ideo:strokes           0 ;
    ideo:total-strokes     7 ;
