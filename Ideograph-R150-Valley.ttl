    :eq rep.gt-pj-1:17195         ; # &I-GT-48553;
    :eq rep.daikanwa:36182        ; # &I-M-36182;
    :eq rep.shinjigen:7791        ; # 谷
    :subsume
        g2.ucs_unicode:0x8C37 ,
        rep.gt-k:02608       ;
    .
