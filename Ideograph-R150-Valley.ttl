        :eq g2.adobe-japan1-0:02921   ; # &g2-AJ1-02921;
        :eq g2.gb2312:0x3948          ; # &g2-AJ1-02921;
        :eq g2.ks-x1001:0x4D5B        ; # &g2-AJ1-02921;
        :eq g2.jis-x0208:0x432B       ; # &g2-AJ1-02921;
        :eq g2.cns11643-1:0x4B47      ; # &g2-AJ1-02921;
        :eq g2.jis-x0213-1:0x432B     ; # &g2-AJ1-02921;
        :eq g2.gt:48553               ; # &g2-AJ1-02921;
        :eq g2.gt-k:02607             ; # &g2-AJ1-02921;
        :eq g2.daikanwa:36182         ; # &g2-AJ1-02921;
        :eq g2.shinjigen:7791         ; # &g2-AJ1-02921;
        :subsume
