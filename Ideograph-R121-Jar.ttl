a.ucs_component:0x7F36
    a chisegg:abstract-character ;
    :abstract-character-of [ :context domain:component ;
                             :target     ucs:0x7F36  ] ;
    ideo:radical         121 ; # ⽸ 
    ideo:strokes           0 ;
    :eq a.iwds-1:0295             ; # &A-compU+7F36;
    .
    a.iwds-1:0295
           :abstract-character-of         iwds-1:0295    .

a.ucs_component:0x26222
    a chisegg:abstract-character ;
    :abstract-character-of [ :context domain:component ;
                             :target     ucs:0x26222 ] ;
    ideo:radical         121 ; # ⽸ 
    ideo:strokes           0 ;
    ideo:total-strokes     6 ;
    :eq a.iwds-1:0390             ; # &A-compU+26222;
    .
    a.iwds-1:0390
           :abstract-character-of         iwds-1:0390    .

a.ucs:0x7F36
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x7F36 ;
    :denotation-of
        a.ucs_component:0x26222 ;
    :from.denotational_component
        a.ucs_component:0x7F36 ;
    ideo:radical         121 ; # ⽸ 
    ideo:strokes           0 ;
    ideo:total-strokes     6 ;
    :eq rep.adobe-japan1-0:01544  ; # &I-AJ1-01544;
    :eq rep.jis-x0208:0x344C      ; # &I-J90-344C;
    :eq rep.gb2312:0x733E         ; # &I-G0-733E;
    :eq rep.ks-x1001:0x5D2E       ; # &I-K0-5D2E;
    :eq rep.cns11643-1:0x484F     ; # &I-C1-484F;
    :eq rep.jis-x0213-1:0x344C    ; # &I-JX1-344C;
    :eq a.big5:0xA6CE             ; # &I-B-A6CE;
    :eq rep.gt:36221              ; # &I-GT-36221;
    :eq rep.gt-k:01582            ; # &I-GT-K01582;
    :eq rep.gt-pj-1:13388         ; # &I-GT-36221;
    :eq rep.daikanwa:28108        ; # &I-M-28108;
    :eq rep.shinjigen:6223        ; # 缶
    ideo:simplified-form-of [ :context domain:JP...Jouyou ;
                              :target  rep.adobe-japan1-0:06162 ] ;
    :subsume
        g2.ucs_unicode:0x7F36 ;
    .
    rep.adobe-japan1-0:01544
               :abstract-glyph-of adobe-japan1-0:01544   .
    rep.jis-x0208:0x344C
               :abstract-glyph-of      jis-x0208:0x344C  .
    rep.gb2312:0x733E
               :abstract-glyph-of         gb2312:0x733E  .
    rep.ks-x1001:0x5D2E
               :abstract-glyph-of       ks-x1001:0x5D2E  .
    rep.cns11643-1:0x484F
               :abstract-glyph-of     cns11643-1:0x484F  .
    rep.jis-x0213-1:0x344C
               :abstract-glyph-of    jis-x0213-1:0x344C  .
    a.big5:0xA6CE
           :abstract-character-of           big5:0xA6CE  .
    rep.gt:36221
               :abstract-glyph-of             gt:36221   .
    rep.gt-k:01582
               :abstract-glyph-of           gt-k:01582   .
    rep.gt-pj-1:13388
               :abstract-glyph-of        gt-pj-1:13388   .
    rep.daikanwa:28108
               :abstract-glyph-of       daikanwa:28108   .
    rep.shinjigen:6223
               :abstract-glyph-of      shinjigen:6223    .
    g2.ucs_unicode:0x7F36
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of [ :context domain:unicode ;
                                  :target     ucs:0x7F36  ] ;
        :eq g2.adobe-japan1-0:01544   ; # &g2-AJ1-01544;
        :eq g2.gb2312:0x733E          ; # &g2-AJ1-01544;
        :eq g2.ks-x1001:0x5D2E        ; # &g2-AJ1-01544;
        :eq g2.jis-x0208:0x344C       ; # &g2-AJ1-01544;
        :eq g2.cns11643-1:0x484F      ; # &g2-AJ1-01544;
        :eq g2.jis-x0213-1:0x344C     ; # &g2-AJ1-01544;
        :eq g2.gt:36221               ; # &g2-AJ1-01544;
        :eq g2.gt-k:01582             ; # &g2-AJ1-01544;
        :eq g2.daikanwa:28108         ; # &g2-AJ1-01544;
        :eq g2.shinjigen:6223         ; # &g2-AJ1-01544;
