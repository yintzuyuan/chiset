bucs:0x9149
    a chisegg:super-abstract-character ;
    :super-abstract-character-of [ :context domain:bucs    ;
                                   :target     ucs:0x9149  ] ;
    ideo:radical         164 ; # ⾣ 
    ideo:strokes           0 ;
    .

a.ucs:0x9149
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x9149 ;
    :denotation-of
        bucs:0x9149          ;
    ideo:radical         164 ; # ⾣ 
    ideo:strokes           0 ;
    ideo:total-strokes     7 ;
