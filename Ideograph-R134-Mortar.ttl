a.ucs_component:0x81FC
    a chisegg:abstract-character ;
    :abstract-character-of [ :context domain:component ;
                             :target     ucs:0x81FC  ] ;
    ideo:radical         134 ; # ⾅ 
    ideo:strokes           0 ;
    :eq a.iwds-1:0168             ; # &A-compU+81FC;
    .
    a.iwds-1:0168
           :abstract-character-of         iwds-1:0168    .

a.ucs:0x81FC
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x81FC ;
    :from.denotational_component
        a.ucs_component:0x81FC ;
    ideo:radical         134 ; # ⾅ 
    ideo:strokes           0 ;
    .

rep.adobe-japan1-0:01235
    a chisegg:abstract-glyph ;
    :abstract-glyph-of adobe-japan1-0:01235 ;
    :denotation-of
        a.ucs:0x81FC         ;
    ideo:radical         134 ; # ⾅ 
    ideo:strokes           0 ;
    ideo:total-strokes     6 ;
    :eq rep.ucs_unicode:0x81FC    ; # &AJ1-01235;
    :eq rep.jis-x0208:0x3131      ; # &I-J90-3131;
    :eq rep.gb2312:0x3E4A         ; # &I-G0-3E4A;
    :eq rep.ks-x1001:0x4F3F       ; # &I-K0-4F3F;
    :eq rep.cns11643-1:0x485E     ; # &I-C1-485E;
    :eq rep.jis-x0213-1:0x3131    ; # &I-JX1-3131;
    :eq a.big5:0xA6DD             ; # &I-B-A6DD;
    :eq rep.gt:39032              ; # &I-GT-39032;
    :eq rep.gt-k:01568            ; # &I-GT-K01568;
    :eq rep.gt-pj-1:12593         ; # &I-GT-39032;
    :eq rep.daikanwa:30173        ; # &I-M-30173;
    :eq rep.shinjigen:6607        ; # &AJ1-01235;
    :subsume
        g2.ucs_unicode:0x81FC ;
    .
    rep.ucs_unicode:0x81FC
               :abstract-glyph-of [ :context domain:unicode ;
                                    :target     ucs:0x81FC  ] .
    rep.jis-x0208:0x3131
               :abstract-glyph-of      jis-x0208:0x3131  .
    rep.gb2312:0x3E4A
               :abstract-glyph-of         gb2312:0x3E4A  .
    rep.ks-x1001:0x4F3F
               :abstract-glyph-of       ks-x1001:0x4F3F  .
    rep.cns11643-1:0x485E
