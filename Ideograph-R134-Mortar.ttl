        :abstract-glyph-form-of [ :context domain:unicode ;
                                  :target     ucs:0x81FC  ] ;
        :eq g2.adobe-japan1-0:01235   ; # &g2-AJ1-01235;
        :eq g2.gb2312:0x3E4A          ; # &g2-AJ1-01235;
        :eq g2.ks-x1001:0x4F3F        ; # &g2-AJ1-01235;
        :eq g2.jis-x0208:0x3131       ; # &g2-AJ1-01235;
        :eq g2.cns11643-1:0x485E      ; # &g2-AJ1-01235;
        :eq g2.jis-x0213-1:0x3131     ; # &g2-AJ1-01235;
