        :eq g2.gt-k:01568             ; # &g2-AJ1-01235;
        :eq g2.daikanwa:30173         ; # &g2-AJ1-01235;
        :eq g2.shinjigen:6607         ; # &g2-AJ1-01235;
        :subsume
