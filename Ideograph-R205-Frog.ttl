    :abstract-character-of ucs:0x2A4FF ;
    ideo:radical         205 ; # ⿌ 
    ideo:strokes          14 ;
    ideo:total-strokes    27 ;
    :subsume
        rep.daikanwa:48312   ,
        rep.ucs_iso:0x2A4FF  ,
        rep.cns11643-5:0x7B34 ;
    .
    rep.daikanwa:48312
        a chisegg:abstract-glyph ;
        :abstract-glyph-of daikanwa:48312 ;
        .
    rep.ucs_iso:0x2A4FF
        a chisegg:abstract-glyph ;
        :abstract-glyph-of [ :context domain:iso     ;
                             :target     ucs:0x2A4FF ] ;
        .
    rep.cns11643-5:0x7B34
        a chisegg:abstract-glyph ;
        :abstract-glyph-of cns11643-5:0x7B34 ;
        .

