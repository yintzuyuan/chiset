    rep.cns11643-1:0x455C
               :abstract-glyph-of     cns11643-1:0x455C  .
    rep.jis-x0213-1:0x356D
               :abstract-glyph-of    jis-x0213-1:0x356D  .
    a.big5:0xA4FB
           :abstract-character-of           big5:0xA4FB  .
    rep.gt:25578
               :abstract-glyph-of             gt:25578   .
    rep.gt-k:00410
               :abstract-glyph-of           gt-k:00410   .
    rep.gt-pj-1:13677
               :abstract-glyph-of        gt-pj-1:13677   .
    rep.daikanwa:19922
               :abstract-glyph-of       daikanwa:19922   .
    rep.shinjigen:4733
               :abstract-glyph-of      shinjigen:4733    .
    g2.ucs_unicode:0x725B
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of [ :context domain:unicode ;
                                  :target     ucs:0x725B  ] ;
        :eq g2.adobe-japan1-0:01671   ; # &g2-AJ1-01671;
        :eq g2.gb2312:0x4523          ; # &g2-AJ1-01671;
        :eq g2.ks-x1001:0x695A        ; # &g2-AJ1-01671;
        :eq g2.jis-x0208:0x356D       ; # &g2-AJ1-01671;
        :eq g2.cns11643-1:0x455C      ; # &g2-AJ1-01671;
        :eq g2.jis-x0213-1:0x356D     ; # &g2-AJ1-01671;
        :eq g2.gt:25578               ; # &g2-AJ1-01671;
        :eq g2.gt-k:00410             ; # &g2-AJ1-01671;
        :eq g2.daikanwa:19922         ; # &g2-AJ1-01671;
        :eq g2.shinjigen:4733         ; # &g2-AJ1-01671;
        :subsume
            repi.daikanwa:19922  ,
            repi.jis-x0208:0x356D ,
            repi.adobe-japan1-6:01671 ,
