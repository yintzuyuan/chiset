a.ucs:0x725B
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x725B ;
    ideo:radical          93 ; # ⽜ 
    ideo:strokes           0 ;
    ideo:total-strokes     4 ;
    :eq rep.adobe-japan1-0:01671  ; # &I-AJ1-01671;
    :eq rep.jis-x0208:0x356D      ; # &I-J90-356D;
    :eq rep.gb2312:0x4523         ; # &I-G0-4523;
    :eq rep.ks-x1001:0x695A       ; # &I-K0-695A;
    :eq rep.cns11643-1:0x455C     ; # &I-C1-455C;
    :eq rep.jis-x0213-1:0x356D    ; # &I-JX1-356D;
    :eq a.big5:0xA4FB             ; # &I-B-A4FB;
    :eq rep.gt:25578              ; # &I-GT-25578;
    :eq rep.gt-k:00410            ; # &I-GT-K00410;
    :eq rep.gt-pj-1:13677         ; # &I-GT-25578;
    :eq rep.daikanwa:19922        ; # &I-M-19922;
    :eq rep.shinjigen:4733        ; # 牛
    :subsume
        g2.ucs_unicode:0x725B ;
    .
    rep.adobe-japan1-0:01671
               :abstract-glyph-of adobe-japan1-0:01671   .
    rep.jis-x0208:0x356D
