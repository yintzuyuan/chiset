    ideo:strokes           0 ;
    ideo:total-strokes     6 ;
    :eq rep.ucs_unicode:0x807F    ; # &AJ1-06227;
    :eq rep.jis-x0208:0x6666      ; # &I-J90-6666;
    :eq rep.gb2312:0x6D32         ; # &I-G0-6D32;
    :eq rep.ks-x1001:0x6B53       ; # &I-K0-6B53;
