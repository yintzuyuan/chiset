    :eq rep.gt-pj-1:26214         ; # &I-GT-37829;
    :eq rep.daikanwa:29215        ; # &I-M-29215;
    :eq rep.shinjigen:6411        ; # &AJ1-06227;
    :subsume
        g2.ucs_unicode:0x807F ;
    .
