a.ucs:0x9B25
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x9B25 ;
    ideo:radical         191 ; # ⾾ 
    ideo:strokes           0 ;
    ideo:total-strokes    10 ;
    :eq rep.adobe-japan1-0:07293  ; # &I-AJ1-07293;
    :eq rep.jis-x0208:0x7228      ; # &I-J90-7228;
    :eq rep.iso-ir165:0x2F79      ; # &I-EGB-2F79;
    :eq rep.cns11643-1:0x586E     ; # &I-C1-586E;
    :eq rep.jis-x0213-1:0x7228    ; # &I-JX1-7228;
    :eq rep.gb12345:0x3637        ; # 鬥
    :eq rep.gt:61385              ; # &I-GT-61385;
    :eq rep.gt-k:06655            ; # &I-GT-K06655;
    :eq rep.gt-pj-1:29224         ; # &I-GT-61385;
    :eq rep.daikanwa:45632        ; # &I-M-45632;
    :subsume
        g2.daikanwa:45632    ,
        g2.ucs_unicode:0x9B25 ,
        g2.cns11643-1:0x586E ;
    .
    rep.adobe-japan1-0:07293
               :abstract-glyph-of adobe-japan1-0:07293   .
    rep.jis-x0208:0x7228
               :abstract-glyph-of      jis-x0208:0x7228  .
    rep.iso-ir165:0x2F79
               :abstract-glyph-of      iso-ir165:0x2F79  .
    rep.cns11643-1:0x586E
               :abstract-glyph-of     cns11643-1:0x586E  .
    rep.jis-x0213-1:0x7228
               :abstract-glyph-of    jis-x0213-1:0x7228  .
    rep.gb12345:0x3637
               :abstract-glyph-of        gb12345:0x3637  .
    rep.gt:61385
               :abstract-glyph-of             gt:61385   .
    rep.gt-k:06655
               :abstract-glyph-of           gt-k:06655   .
    rep.gt-pj-1:29224
               :abstract-glyph-of        gt-pj-1:29224   .
    rep.daikanwa:45632
               :abstract-glyph-of       daikanwa:45632   .
    g2.daikanwa:45632
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of daikanwa:45632 ;
        .
    g2.ucs_unicode:0x9B25
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of [ :context domain:unicode ;
                                  :target     ucs:0x9B25  ] ;
        :eq g2.adobe-japan1-0:07293   ; # &g2-AJ1-07293;
        :eq g2.iso-ir165:0x2F79       ; # &g2-AJ1-07293;
        :eq g2.jis-x0208:0x7228       ; # &g2-AJ1-07293;
        :eq g2.jis-x0213-1:0x7228     ; # &g2-AJ1-07293;
        :eq g2.gb12345:0x3637         ; # &g2-AJ1-07293;
        :eq g2.gt:61385               ; # &g2-AJ1-07293;
        :eq g2.gt-k:06655             ; # &g2-AJ1-07293;
        :subsume
            repi.jis-x0208:0x7228 ,
            repi.adobe-japan1-6:07293 ,
            repi.gt:61385        ,
            repi.ucs_unicode:0x9B25 ;
        .
        g2.adobe-japan1-0:07293
              :abstract-glyph-form-of adobe-japan1-0:07293   .
        g2.iso-ir165:0x2F79
              :abstract-glyph-form-of      iso-ir165:0x2F79  .
        g2.jis-x0208:0x7228
              :abstract-glyph-form-of      jis-x0208:0x7228  .
        g2.jis-x0213-1:0x7228
              :abstract-glyph-form-of    jis-x0213-1:0x7228  .
        g2.gb12345:0x3637
              :abstract-glyph-form-of        gb12345:0x3637  .
        g2.gt:61385
              :abstract-glyph-form-of             gt:61385   .
        g2.gt-k:06655
              :abstract-glyph-form-of           gt-k:06655   .
        repi.jis-x0208:0x7228
            a chisegg:glyph-image ;
            :glyph-image-of jis-x0208:0x7228 ;
            :eq repi.jis-x0213-1:0x7228   ; # &R-J0-7228;
            .
            repi.jis-x0213-1:0x7228
                          :glyph-image-of    jis-x0213-1:0x7228  .
        repi.adobe-japan1-0:07293
            a chisegg:glyph-image ;
            :glyph-image-of adobe-japan1-0:07293 ;
            .
        repi.gt:61385
            a chisegg:glyph-image ;
            :glyph-image-of gt:61385 ;
            :eq repi.gt-k:06655           ; # &R-GT-61385;
            .
            repi.gt-k:06655
                          :glyph-image-of           gt-k:06655   .
        repi.ucs_unicode:0x9B25
            a chisegg:glyph-image ;
            :glyph-image-of [ :context domain:unicode ;
                              :target     ucs:0x9B25  ] ;
            .
    g2.cns11643-1:0x586E
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of cns11643-1:0x586E ;
        :eq g2.ucs_cns:0x9B25         ; # &g2-CU+9B25;
        .
        g2.ucs_cns:0x9B25
              :abstract-glyph-form-of [ :context domain:cns     ;
                                        :target     ucs:0x9B25  ] .

a.ucs:0x29C0A
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x29C0A ;
    ideo:radical         191 ; # ⾾ 
    ideo:strokes           0 ;
    ideo:total-strokes     5 ;
    :subsume
        rep.ucs_iso:0x29C0A  ,
        rep.big5-cdp:0x88D0  ;
    .
    rep.ucs_iso:0x29C0A
        a chisegg:abstract-glyph ;
        :abstract-glyph-of [ :context domain:iso     ;
                             :target     ucs:0x29C0A ] ;
        :eq rep.cns11643-6:0x233D     ; # &C6-233D;
        :eq rep.daikanwa:45633        ; # &I-M-45633;
        .
        rep.cns11643-6:0x233D
                   :abstract-glyph-of     cns11643-6:0x233D  .
        rep.daikanwa:45633
                   :abstract-glyph-of       daikanwa:45633   .
    rep.big5-cdp:0x88D0
        a chisegg:abstract-glyph ;
        :abstract-glyph-of big5-cdp:0x88D0 ;
        ideo:hanyu-dazidian  ( 1 14 2 ) ;
        .

a.ucs:0x29C0B
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x29C0B ;
    ideo:radical         191 ; # ⾾ 
    ideo:strokes           0 ;
    ideo:total-strokes     5 ;
    :subsume
        rep.cns11643-6:0x233C ,
        rep.ucs_iso:0x29C0B  ;
    .
    rep.cns11643-6:0x233C
        a chisegg:abstract-glyph ;
        :abstract-glyph-of cns11643-6:0x233C ;
        ideo:hanyu-dazidian  ( 1 15 2 ) ;
        :eq rep.big5-cdp:0x88D1       ; # &I-CDP-88D1;
        :eq rep.daikanwa:45634        ; # &I-M-45634;
        .
        rep.big5-cdp:0x88D1
                   :abstract-glyph-of       big5-cdp:0x88D1  .
        rep.daikanwa:45634
                   :abstract-glyph-of       daikanwa:45634   .
    rep.ucs_iso:0x29C0B
        a chisegg:abstract-glyph ;
        :abstract-glyph-of [ :context domain:iso     ;
                             :target     ucs:0x29C0B ] ;
        .

