a.ucs:0x9999
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x9999 ;
    ideo:radical         186 ; # ⾹ 
    ideo:strokes           0 ;
    ideo:total-strokes     9 ;
    :eq rep.adobe-japan1-0:02035  ; # &I-AJ1-02035;
    :eq rep.jis-x0208:0x3961      ; # &I-J90-3961;
    :eq rep.gb2312:0x4F63         ; # &I-G0-4F63;
    :eq rep.ks-x1001:0x7A45       ; # &I-K0-7A45;
    :eq rep.cns11643-1:0x537C     ; # &I-C1-537C;
