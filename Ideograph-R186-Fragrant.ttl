    rep.gt-k:05081
               :abstract-glyph-of           gt-k:05081   .
    rep.gt-pj-1:14689
               :abstract-glyph-of        gt-pj-1:14689   .
    rep.daikanwa:44518
               :abstract-glyph-of       daikanwa:44518   .
    rep.shinjigen:9323
               :abstract-glyph-of      shinjigen:9323    .
    g2.ucs_unicode:0x9999
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of [ :context domain:unicode ;
                                  :target     ucs:0x9999  ] ;
        :eq g2.adobe-japan1-0:02035   ; # &g2-AJ1-02035;
        :eq g2.gb2312:0x4F63          ; # &g2-AJ1-02035;
        :eq g2.ks-x1001:0x7A45        ; # &g2-AJ1-02035;
        :eq g2.jis-x0208:0x3961       ; # &g2-AJ1-02035;
        :eq g2.cns11643-1:0x537C      ; # &g2-AJ1-02035;
        :eq g2.jis-x0213-1:0x3961     ; # &g2-AJ1-02035;
        :eq g2.gt:59986               ; # &g2-AJ1-02035;
        :eq g2.gt-k:05081             ; # &g2-AJ1-02035;
        :eq g2.daikanwa:44518         ; # &g2-AJ1-02035;
        :eq g2.shinjigen:9323         ; # &g2-AJ1-02035;
        :subsume
            repi.daikanwa:44518  ,
            repi.jis-x0208:0x3961 ,
            repi.adobe-japan1-6:02035 ,
            repi.cns11643-1:0x537C ,
