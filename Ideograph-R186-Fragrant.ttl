    :eq rep.gt-k:05081            ; # &I-GT-K05081;
    :eq rep.gt-pj-1:14689         ; # &I-GT-59986;
    :eq rep.daikanwa:44518        ; # &I-M-44518;
    :eq rep.shinjigen:9323        ; # 香
    :subsume
        g2.ucs_unicode:0x9999 ,
        repi.hng-khm:05910   ,
        repi.hng-khi:06270   ;
    .
