    :eq rep.gt-k:00413            ; # &I-GT-K00413;
    :eq rep.gt-pj-1:13908         ; # &I-GT-17105;
    :eq rep.daikanwa:13534        ; # &I-M-13534;
    :eq rep.shinjigen:3219        ; # &AJ1-01740;
    .
