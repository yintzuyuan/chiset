bucs:0x4E8C
    a chisegg:super-abstract-character ;
    :super-abstract-character-of [ :context domain:bucs    ;
                                   :target     ucs:0x4E8C  ] ;
    ideo:radical           7 ; # ⼆ 
    .

a.ucs:0x4E8C
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x4E8C ;
    :denotation-of
        bucs:0x4E8C          ;
    :from.denotational_component
        a.ucs_component:0x4E8C ,
        a.ucs_component:0x4EA0 ;
    ideo:radical           7 ; # ⼆ 
    ideo:strokes           0 ;
    ideo:total-strokes     2 ;
    ideo:hanyu-dazidian  ( 1 2 1 ) ;
    :sound               [ :context domain:ja...kun ;
                           :target  ( "huta-tu" "huta" ) ;
                         ] ;
    :sound               [ :context domain:ja...on ;
                           :target  ( "ni" "zi" ) ;
                         ] ;
    :eq rep.adobe-japan1-0:03275  ; # &I-AJ1-03275;
    :eq rep.jis-x0208:0x4673      ; # &I-J90-4673;
    :eq rep.gb2312:0x367E         ; # &I-G0-367E;
    :eq rep.ks-x1001:0x6C23       ; # &I-K0-6C23;
    :eq rep.cns11643-1:0x4428     ; # &I-C1-4428;
    :eq rep.jis-x0213-1:0x4673    ; # &I-JX1-4673;
    :eq a.big5:0xA447             ; # &I-B-A447;
    :eq rep.gt:00330              ; # &I-GT-00330;
    :eq rep.gt-k:00054            ; # &I-GT-K00054;
    :eq rep.gt-pj-1:18035         ; # &I-GT-00330;
    :eq rep.daikanwa:00247        ; # &I-M-00247;
    :eq rep.shinjigen:0073        ; # 二
    :subsume
        g2.ucs_unicode:0x4E8C ;
    .
