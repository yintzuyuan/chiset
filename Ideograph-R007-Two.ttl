    rep.shinjigen:0073
               :abstract-glyph-of      shinjigen:0073    .
    g2.ucs_unicode:0x4E8C
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of [ :context domain:unicode ;
                                  :target     ucs:0x4E8C  ] ;
        :rep.decomposition   [ :context domain:cid     ;
                               :target  a.ucs:0x4E8C         ,
                                        a.ucs:0xE0100        ] ;
        :eq g2.adobe-japan1-0:03275   ; # &g2-AJ1-03275;
        :eq g2.gb2312:0x367E          ; # &g2-AJ1-03275;
        :eq g2.ks-x1001:0x6C23        ; # &g2-AJ1-03275;
        :eq g2.jis-x0208:0x4673       ; # &g2-AJ1-03275;
        :eq g2.cns11643-1:0x4428      ; # &g2-AJ1-03275;
        :eq g2.jis-x0213-1:0x4673     ; # &g2-AJ1-03275;
        :eq g2.gt:00330               ; # &g2-AJ1-03275;
        :eq g2.gt-k:00054             ; # &g2-AJ1-03275;
        :eq g2.daikanwa:00247         ; # &g2-AJ1-03275;
        :eq g2.shinjigen:0073         ; # &g2-AJ1-03275;
