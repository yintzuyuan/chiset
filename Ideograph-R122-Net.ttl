a.ucs:0x7F51
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x7F51 ;
    :denotation-of
        bucs:0x7DB2          ;
    ideo:radical         122 ; # ⽹ 
    ideo:strokes           0 ;
    ideo:total-strokes     6 ;
    :eq rep.adobe-japan1-0:06163  ; # &I-AJ1-06163;
    :eq rep.jis-x0208:0x6626      ; # &I-J90-6626;
    :eq rep.gb2312:0x4D78         ; # &I-G0-4D78;
    :eq rep.cns11643-2:0x2269     ; # &I-C2-2269;
    :eq rep.jis-x0213-1:0x6626    ; # &I-JX1-6626;
    :eq a.big5:0xCA49             ; # &I-B-CA49;
    :eq rep.gt:36331              ; # &I-GT-36331;
    :eq rep.gt-k:01731            ; # &I-GT-K01731;
    :eq rep.gt-pj-1:26150         ; # &I-GT-36331;
    :eq rep.daikanwa:28199        ; # &I-M-28199;
    .
    rep.adobe-japan1-0:06163
               :abstract-glyph-of adobe-japan1-0:06163   .
    rep.jis-x0208:0x6626
               :abstract-glyph-of      jis-x0208:0x6626  .
    rep.gb2312:0x4D78
               :abstract-glyph-of         gb2312:0x4D78  .
    rep.cns11643-2:0x2269
               :abstract-glyph-of     cns11643-2:0x2269  .
    rep.jis-x0213-1:0x6626
               :abstract-glyph-of    jis-x0213-1:0x6626  .
    a.big5:0xCA49
           :abstract-character-of           big5:0xCA49  .
    rep.gt:36331
               :abstract-glyph-of             gt:36331   .
    rep.gt-k:01731
               :abstract-glyph-of           gt-k:01731   .
    rep.gt-pj-1:26150
               :abstract-glyph-of        gt-pj-1:26150   .
    rep.daikanwa:28199
               :abstract-glyph-of       daikanwa:28199   .

