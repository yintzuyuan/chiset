    :general-category     "(symbol other)" ; # Informative Category
    :bidi-category        "ON" ;
    :mirrored             "nil" ;
    :from.identical      [ :context domain:component...connect-below ;
                           :target  a.ucs:0x7F52         ] ;
    .

