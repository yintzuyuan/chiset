rep.jis-x0213-2:0x746A
    a chisegg:abstract-glyph ;
    :abstract-glyph-of jis-x0213-2:0x746A ;
    :denotation-of
        a.ucs:0x7F52         ;
    ideo:radical         122 ; # ⽹ 
    ideo:strokes           0 ;
    ideo:total-strokes     5 ;
    :eq rep.ucs_unicode:0x7F52    ; # &JX2-746A;
    :eq rep.jis-x0212:0x5474      ; # &JX2-746A;
    :eq rep.cns11643-4:0x2221     ; # &I-C4-2221;
    :eq rep.daikanwa:28200        ; # &I-M-28200;
    :form-of             [ :context domain:component...connect-below ;
                           :sources chisebib:zihui...char-index ,
                                    chisebib:daikanwa ;
                           :target  a.ucs:0x7F51         ] ;
    :from.wrong          [ :sources chisebib:zhengzitong ,
                                    chisebib:daikanwa ;
                           :target  a.ucs:0x7F51         ] ;
    .
    rep.ucs_unicode:0x7F52
               :abstract-glyph-of [ :context domain:unicode ;
                                    :target     ucs:0x7F52  ] .
    rep.jis-x0212:0x5474
               :abstract-glyph-of      jis-x0212:0x5474  .
    rep.cns11643-4:0x2221
               :abstract-glyph-of     cns11643-4:0x2221  .
    rep.daikanwa:28200
               :abstract-glyph-of       daikanwa:28200   .

