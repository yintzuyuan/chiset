a.ucs_component:0x6BB3
    a chisegg:abstract-character ;
    :abstract-character-of [ :context domain:component ;
                             :target     ucs:0x6BB3  ] ;
    ideo:radical          79 ; # ⽎ 
    ideo:strokes           0 ;
    ideo:total-strokes     4 ;
    :eq a.iwds-1:0220             ; # &A-compU+6BB3;
    .
    a.iwds-1:0220
           :abstract-character-of         iwds-1:0220    .

a.ucs:0x6BB3
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x6BB3 ;
    :from.denotational_component
        a.ucs_component:0x6BB3 ;
    ideo:radical          79 ; # ⽎ 
    ideo:strokes           0 ;
    ideo:total-strokes     4 ;
    .

rep.mj:014908
    a chisegg:abstract-glyph ;
    :abstract-glyph-of mj:014908 ;
    :denotation-of
        a.ucs:0x6BB3         ;
    ideo:radical          79 ; # ⽎ 
    ideo:strokes           0 ;
    ideo:total-strokes     4 ;
    :eq rep.ucs_unicode:0x6BB3    ; # &MJ014908;
    :eq rep.adobe-japan1-0:05364  ; # &I-AJ1-05364;
    :eq rep.jis-x0208:0x5D55      ; # &I-J90-5D55;
    :eq rep.gb2312:0x6C2F         ; # &I-G0-6C2F;
    :eq rep.cns11643-2:0x213F     ; # &I-C2-213F;
    :eq rep.jis-x0213-1:0x5D55    ; # &I-JX1-5D55;
    :eq a.big5:0xC95F             ; # &I-B-C95F;
    :eq rep.hanyo-denshi...ja:0x5D55 ; # &I-HD-JA-5D55;
    :eq rep.gt:21300              ; # &I-GT-21300;
    :eq rep.gt-k:00537            ; # &I-GT-K00537;
    :eq rep.gt-pj-1:23893         ; # &I-GT-21300;
    :eq rep.daikanwa:16613        ; # &I-M-16613;
