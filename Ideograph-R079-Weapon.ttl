    :eq rep.koseki:189520         ; # &MJ038958;
    :eq rep.daikanwa:16720        ; # &I-M-16720;
    :subsume
        g2.daikanwa:16720    ,
        g2.mj:038958         ;
    .
    rep.koseki:189520
               :abstract-glyph-of         koseki:189520  .
    rep.daikanwa:16720
               :abstract-glyph-of       daikanwa:16720   .
    g2.daikanwa:16720
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of daikanwa:16720 ;
        .
    g2.mj:038958
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of mj:038958 ;
        :eq g2.koseki:189520          ; # &g2-MJ038958;
        .
        g2.koseki:189520
              :abstract-glyph-form-of         koseki:189520  .

rep.ucs_iso:0x23AEA
    a chisegg:abstract-glyph ;
    :abstract-glyph-of [ :context domain:iso     ;
                         :target     ucs:0x23AEA ] ;
    :denotation-of
        a.ucs:0x23AEA        ;
    ideo:radical          79 ; # ⽎ 
    ideo:strokes          23 ;
    ideo:total-strokes    27 ;
    isd:structure [ a idc:⿱ ;
        isd:above    a.ucs:0x2F959 ; # 穀
        isd:below    rep.adobe-japan1-0:04171   # &AJ1-04171;
    ] ;
    :subsume
        rep.cbeta:00751      ,
        rep.cbeta:00988      ,
        g2.ucs_iso:0x23AEA   ;
    .
    rep.cbeta:00751
        a chisegg:abstract-glyph ;
        :abstract-glyph-of cbeta:00751 ;
        .
    rep.cbeta:00988
        a chisegg:abstract-glyph ;
        :abstract-glyph-of cbeta:00988 ;
        .
    g2.ucs_iso:0x23AEA
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of [ :context domain:iso     ;
                                  :target     ucs:0x23AEA ] ;
        :subsume
            repi.ucs_iso:0x23AEA ,
            rep.hanziku-6:0xBE6F ;
        .
        repi.ucs_iso:0x23AEA
