        :rep.decomposition   [ :context domain:cid     ;
                               :target  a.ucs:0x51F5         ,
                                        a.ucs:0xE0100        ] ;
        :eq g2.adobe-japan1-0:04248   ; # &g2-AJ1-04248;
        :eq g2.gb2312:0x5B49          ; # &g2-AJ1-04248;
        :eq g2.jis-x0208:0x5161       ; # &g2-AJ1-04248;
        :eq g2.cns11643-2:0x2123      ; # &g2-AJ1-04248;
        :eq g2.jis-x0213-1:0x5161     ; # &g2-AJ1-04248;
        :eq g2.gt:02355               ; # &g2-AJ1-04248;
        :eq g2.gt-k:00087             ; # &g2-AJ1-04248;
        :eq g2.daikanwa:01800         ; # &g2-AJ1-04248;
        :subsume
            repi.daikanwa:01800  ,
            repi.jis-x0208:0x5161 ,
            repi.adobe-japan1-6:04248 ,
