    rep.gt-k:00087
               :abstract-glyph-of           gt-k:00087   .
    rep.gt-pj-1:20833
               :abstract-glyph-of        gt-pj-1:20833   .
    rep.daikanwa:01800
               :abstract-glyph-of       daikanwa:01800   .
    g2.ucs_unicode:0x51F5
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of [ :context domain:unicode ;
