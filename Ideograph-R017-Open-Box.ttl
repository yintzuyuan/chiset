        a.ucs:0x51F5         ;
    ideo:radical          17 ; # ⼐ 
    ideo:strokes           0 ;
    ideo:total-strokes     2 ;
    ideo:hanyu-dazidian  ( 1 306 15 ) ;
    :eq rep.ucs_unicode:0x51F5    ; # &AJ1-04248;
    :eq rep.jis-x0208:0x5161      ; # &I-J90-5161;
    :eq rep.gb2312:0x5B49         ; # &I-G0-5B49;
    :eq rep.cns11643-2:0x2123     ; # &I-C2-2123;
    :eq rep.jis-x0213-1:0x5161    ; # &I-JX1-5161;
    :eq a.big5:0xC942             ; # &I-B-C942;
    :eq rep.gt:02355              ; # &I-GT-02355;
    :eq rep.gt-k:00087            ; # &I-GT-K00087;
    :eq rep.gt-pj-1:20833         ; # &I-GT-02355;
    :eq rep.daikanwa:01800        ; # &I-M-01800;
    :subsume
        g2.ucs_unicode:0x51F5 ;
    .
    rep.ucs_unicode:0x51F5
               :abstract-glyph-of [ :context domain:unicode ;
                                    :target     ucs:0x51F5  ] .
