    :eq rep.adobe-japan1-0:01887  ; # &I-AJ1-01887;
    :eq rep.jis-x0208:0x382B      ; # &I-J90-382B;
    :eq rep.ks-x1001:0x4C38       ; # &I-K0-4C38;
