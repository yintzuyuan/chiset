a.ucs:0x9B3C
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x9B3C ;
    ideo:radical         194 ; # ⿁ 
    ideo:strokes           0 ;
    .

o.ucs_unicode:0x9B3C
    a chisegg:unified-glyph ;
    :unified-glyph-of [ :context domain:unicode ;
                        :target     ucs:0x9B3C  ] ;
    :denotation-of
        a.ucs:0x9B3C         ;
    ideo:radical         194 ; # ⿁ 
    ideo:strokes           0 ;
    :eq a.ucs_iwds-1:0x9B3C       ; # &o-J0-3534;
    :eq o.ucs_jis:0x9B3C          ; # &o-J0-3534;
    :eq o.jis-x0208:0x3534        ; # &o-J0-3534;
    :eq o.jis-x0213-1:0x3534      ; # &o-J0-3534;
    :eq o.adobe-japan1-0:01614    ; # &o-J0-3534;
    :eq a.big5-cdp:0x8A5D         ; # &o-J0-3534;
    :eq o.gt:61541                ; # &o-J0-3534;
    :subsume
        rep.adobe-japan1-0:01614 ,
        rep.gb2312:0x396D    ;
    .
    a.ucs_iwds-1:0x9B3C
           :abstract-character-of [ :context domain:iwds-1  ;
                                    :target     ucs:0x9B3C  ] .
    o.ucs_jis:0x9B3C
                :unified-glyph-of [ :context domain:jis     ;
                                    :target     ucs:0x9B3C  ] .
    o.jis-x0208:0x3534
                :unified-glyph-of      jis-x0208:0x3534  .
    o.jis-x0213-1:0x3534
                :unified-glyph-of    jis-x0213-1:0x3534  .
    o.adobe-japan1-0:01614
                :unified-glyph-of adobe-japan1-0:01614   .
    a.big5-cdp:0x8A5D
           :abstract-character-of       big5-cdp:0x8A5D  .
    o.gt:61541
                :unified-glyph-of             gt:61541   .
    rep.adobe-japan1-0:01614
        a chisegg:abstract-glyph ;
        :abstract-glyph-of adobe-japan1-0:01614 ;
        ideo:total-strokes    10 ;
        :eq rep.ucs_jis:0x9B3C        ; # &AJ1-01614;
        :eq rep.jis-x0208:0x3534      ; # &I-J90-3534;
        :eq rep.ks-x1001:0x5021       ; # &I-K0-5021;
        :eq rep.cns11643-1:0x5870     ; # &I-C1-5870;
        :eq rep.jis-x0213-1:0x3534    ; # &I-JX1-3534;
        :eq rep.gt:61541              ; # &I-GT-61541;
        :eq rep.gt-k:06398            ; # &I-GT-K06398;
        :eq rep.gt-pj-1:13620         ; # &I-GT-61541;
        :eq rep.daikanwa:45758        ; # &I-M-45758;
        :eq rep.shinjigen:9516        ; # &AJ1-01614;
        :subsume
            g2.adobe-japan1-0:01614 ;
        .
        rep.ucs_jis:0x9B3C
                   :abstract-glyph-of [ :context domain:jis     ;
                                        :target     ucs:0x9B3C  ] .
        rep.jis-x0208:0x3534
                   :abstract-glyph-of      jis-x0208:0x3534  .
        rep.ks-x1001:0x5021
                   :abstract-glyph-of       ks-x1001:0x5021  .
        rep.cns11643-1:0x5870
                   :abstract-glyph-of     cns11643-1:0x5870  .
        rep.jis-x0213-1:0x3534
