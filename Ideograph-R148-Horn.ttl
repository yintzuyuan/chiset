a.ucs:0x89D2
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x89D2 ;
    ideo:radical         148 ; # ⾓ 
    ideo:strokes           0 ;
    ideo:total-strokes     7 ;
    :eq a.big5:0xA8A4             ; # &I-B-A8A4;
    .
    a.big5:0xA8A4
           :abstract-character-of           big5:0xA8A4  .

rep.adobe-japan1-0:01455
    a chisegg:abstract-glyph ;
    :abstract-glyph-of adobe-japan1-0:01455 ;
    :denotation-of
        a.ucs:0x89D2         ;
    ideo:radical         148 ; # ⾓ 
    ideo:strokes           0 ;
    ideo:total-strokes     7 ;
    :eq rep.ucs_jis:0x89D2        ; # &AJ1-01455;
    :eq rep.jis-x0208:0x3351      ; # &I-J90-3351;
    :eq rep.ks-x1001:0x4A47       ; # &I-K0-4A47;
    :eq rep.cns11643-1:0x4B45     ; # &I-C1-4B45;
    :eq rep.jis-x0213-1:0x3351    ; # &I-JX1-3351;
    :eq rep.hanyo-denshi...ja:0x3351 ; # &I-HD-JA-3351;
    :eq rep.gt:47107              ; # &I-GT-47107;
    :eq rep.gt-k:02511            ; # &I-GT-K02511;
    :eq rep.gt-pj-1:13137         ; # &I-GT-47107;
    :eq rep.daikanwa:35003        ; # &I-M-35003;
    :eq rep.shinjigen:7510        ; # &AJ1-01455;
    :subsume
        g2.adobe-japan1-0:01455 ,
        repi.hng-kar:03630   ;
    .
    rep.ucs_jis:0x89D2
               :abstract-glyph-of [ :context domain:jis     ;
                                    :target     ucs:0x89D2  ] .
    rep.jis-x0208:0x3351
               :abstract-glyph-of      jis-x0208:0x3351  .
    rep.ks-x1001:0x4A47
               :abstract-glyph-of       ks-x1001:0x4A47  .
    rep.cns11643-1:0x4B45
               :abstract-glyph-of     cns11643-1:0x4B45  .
    rep.jis-x0213-1:0x3351
               :abstract-glyph-of    jis-x0213-1:0x3351  .
    rep.hanyo-denshi...ja:0x3351
               :abstract-glyph-of hanyo-denshi...ja:0x3351  .
    rep.gt:47107
               :abstract-glyph-of             gt:47107   .
    rep.gt-k:02511
               :abstract-glyph-of           gt-k:02511   .
    rep.gt-pj-1:13137
               :abstract-glyph-of        gt-pj-1:13137   .
    rep.daikanwa:35003
               :abstract-glyph-of       daikanwa:35003   .
    rep.shinjigen:7510
               :abstract-glyph-of      shinjigen:7510    .
    g2.adobe-japan1-0:01455
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of adobe-japan1-0:01455 ;
        :rep.decomposition   [ :context domain:hanyo-denshi ;
                               :target  a.ucs:0x89D2         ,
                                        a.ucs:0xE0102        ] ;
        :eq g2.ucs_cns:0x89D2         ; # &g2-AJ1-01455;
        :eq g2.ucs_jis:0x89D2         ; # &g2-AJ1-01455;
        :eq g2.ucs_ks:0x89D2          ; # &g2-AJ1-01455;
        :eq g2.ks-x1001:0x4A47        ; # &g2-AJ1-01455;
        :eq g2.jis-x0208:0x3351       ; # &g2-AJ1-01455;
        :eq g2.cns11643-1:0x4B45      ; # &g2-AJ1-01455;
        :eq g2.jis-x0213-1:0x3351     ; # &g2-AJ1-01455;
        :eq g2.hanyo-denshi...ja:0x3351 ; # &g2-AJ1-01455;
        :eq g2.gt:47107               ; # &g2-AJ1-01455;
        :eq g2.gt-k:02511             ; # &g2-AJ1-01455;
        :eq g2.daikanwa:35003         ; # &g2-AJ1-01455;
        :eq g2.shinjigen:7510         ; # &g2-AJ1-01455;
