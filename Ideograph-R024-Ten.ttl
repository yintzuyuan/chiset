a.ucs_component:0x5341
    a chisegg:abstract-character ;
    :abstract-character-of [ :context domain:component ;
                             :target     ucs:0x5341  ] ;
    ideo:radical          24 ; # ⼗ 
    ideo:strokes           0 ;
    ideo:total-strokes     2 ;
    :eq a.iwds-1:0037             ; # &A-compU+5341;
    .
    a.iwds-1:0037
           :abstract-character-of         iwds-1:0037    .

a.ucs:0x5341
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x5341 ;
    :from.denotational_component
        a.ucs_component:0x5341 ;
    ideo:radical          24 ; # ⼗ 
    ideo:strokes           0 ;
    ideo:total-strokes     2 ;
    ideo:hanyu-dazidian  ( 1 58 9 ) ;
    :eq rep.adobe-japan1-0:02375  ; # &I-AJ1-02375;
    :eq rep.jis-x0208:0x3D3D      ; # &I-J90-3D3D;
    :eq rep.gb2312:0x4A2E         ; # &I-G0-4A2E;
    :eq rep.ks-x1001:0x6428       ; # &I-K0-6428;
    :eq rep.cns11643-1:0x4432     ; # &I-C1-4432;
    :eq rep.jis-x0213-1:0x3D3D    ; # &I-JX1-3D3D;
    :eq a.big5:0xA451             ; # &I-B-A451;
    :eq rep.gt:03452              ; # &I-GT-03452;
    :eq rep.gt-k:00047            ; # &I-GT-K00047;
    :eq rep.gt-pj-1:15677         ; # &I-GT-03452;
    :eq rep.daikanwa:02695        ; # &I-M-02695;
    :eq rep.shinjigen:0808        ; # 十
    :subsume
        g2.ucs_unicode:0x5341 ;
    .
    rep.adobe-japan1-0:02375
               :abstract-glyph-of adobe-japan1-0:02375   .
    rep.jis-x0208:0x3D3D
               :abstract-glyph-of      jis-x0208:0x3D3D  .
    rep.gb2312:0x4A2E
               :abstract-glyph-of         gb2312:0x4A2E  .
    rep.ks-x1001:0x6428
               :abstract-glyph-of       ks-x1001:0x6428  .
    rep.cns11643-1:0x4432
               :abstract-glyph-of     cns11643-1:0x4432  .
    rep.jis-x0213-1:0x3D3D
               :abstract-glyph-of    jis-x0213-1:0x3D3D  .
