            :glyph-image-of jis-x0208:0x4C53 ;
            :eq repi.jis-x0213-1:0x4C53   ; # &R-J0-4C53;
            .
            repi.jis-x0213-1:0x4C53
                          :glyph-image-of    jis-x0213-1:0x4C53  .
        repi.adobe-japan1-0:03807
            a chisegg:glyph-image ;
            :glyph-image-of adobe-japan1-0:03807 ;
            .
