a.ucs:0x6BDB
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x6BDB ;
    ideo:radical          82 ; # ⽑ 
    ideo:strokes           0 ;
    ideo:total-strokes     4 ;
    :eq rep.adobe-japan1-0:03807  ; # &I-AJ1-03807;
    :eq rep.jis-x0208:0x4C53      ; # &I-J90-4C53;
    :eq rep.gb2312:0x432B         ; # &I-G0-432B;
    :eq rep.ks-x1001:0x593E       ; # &I-K0-593E;
    :eq rep.cns11643-1:0x4553     ; # &I-C1-4553;
    :eq rep.jis-x0213-1:0x4C53    ; # &I-JX1-4C53;
    :eq a.big5:0xA4F2             ; # &I-B-A4F2;
    :eq rep.gt:21495              ; # &I-GT-21495;
    :eq rep.gt-k:00492            ; # &I-GT-K00492;
    :eq rep.gt-pj-1:19539         ; # &I-GT-21495;
    :eq rep.daikanwa:16772        ; # &I-M-16772;
    :eq rep.shinjigen:4018        ; # 毛
    :subsume
        g2.ucs_unicode:0x6BDB ,
        g2.cns11643-1:0x4553 ;
    .
    rep.adobe-japan1-0:03807
               :abstract-glyph-of adobe-japan1-0:03807   .
    rep.jis-x0208:0x4C53
               :abstract-glyph-of      jis-x0208:0x4C53  .
    rep.gb2312:0x432B
               :abstract-glyph-of         gb2312:0x432B  .
    rep.ks-x1001:0x593E
               :abstract-glyph-of       ks-x1001:0x593E  .
    rep.cns11643-1:0x4553
               :abstract-glyph-of     cns11643-1:0x4553  .
    rep.jis-x0213-1:0x4C53
               :abstract-glyph-of    jis-x0213-1:0x4C53  .
    a.big5:0xA4F2
           :abstract-character-of           big5:0xA4F2  .
    rep.gt:21495
               :abstract-glyph-of             gt:21495   .
    rep.gt-k:00492
               :abstract-glyph-of           gt-k:00492   .
    rep.gt-pj-1:19539
               :abstract-glyph-of        gt-pj-1:19539   .
    rep.daikanwa:16772
               :abstract-glyph-of       daikanwa:16772   .
    rep.shinjigen:4018
               :abstract-glyph-of      shinjigen:4018    .
    g2.ucs_unicode:0x6BDB
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of [ :context domain:unicode ;
                                  :target     ucs:0x6BDB  ] ;
        :eq g2.adobe-japan1-0:03807   ; # &g2-AJ1-03807;
        :eq g2.gb2312:0x432B          ; # &g2-AJ1-03807;
        :eq g2.ks-x1001:0x593E        ; # &g2-AJ1-03807;
        :eq g2.jis-x0208:0x4C53       ; # &g2-AJ1-03807;
        :eq g2.jis-x0213-1:0x4C53     ; # &g2-AJ1-03807;
        :eq g2.gt:21495               ; # &g2-AJ1-03807;
        :eq g2.gt-k:00492             ; # &g2-AJ1-03807;
        :eq g2.daikanwa:16772         ; # &g2-AJ1-03807;
        :eq g2.shinjigen:4018         ; # &g2-AJ1-03807;
        :subsume
            repi.daikanwa:16772  ,
            repi.jis-x0208:0x4C53 ,
            repi.adobe-japan1-6:03807 ,
            repi.ks-x1001:0x593E ,
            repi.gt:21495        ,
            repi.ucs_unicode:0x6BDB ;
        .
        g2.adobe-japan1-0:03807
              :abstract-glyph-form-of adobe-japan1-0:03807   .
        g2.gb2312:0x432B
              :abstract-glyph-form-of         gb2312:0x432B  .
        g2.ks-x1001:0x593E
              :abstract-glyph-form-of       ks-x1001:0x593E  .
        g2.jis-x0208:0x4C53
              :abstract-glyph-form-of      jis-x0208:0x4C53  .
        g2.jis-x0213-1:0x4C53
              :abstract-glyph-form-of    jis-x0213-1:0x4C53  .
