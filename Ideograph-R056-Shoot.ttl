a.ucs:0x5F0B
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x5F0B ;
    ideo:radical          56 ; # ⼷ 
    ideo:strokes           0 ;
    ideo:total-strokes     3 ;
    :eq rep.adobe-japan1-0:04768  ; # &I-AJ1-04768;
    :eq rep.jis-x0208:0x5735      ; # &I-J90-5735;
    :eq rep.gb2312:0x5F2E         ; # &I-G0-5F2E;
    :eq rep.cns11643-1:0x445D     ; # &I-C1-445D;
    :eq rep.jis-x0213-1:0x5735    ; # &I-JX1-5735;
    :eq a.big5:0xA47C             ; # &I-B-A47C;
    :eq rep.gt:12167              ; # &I-GT-12167;
    :eq rep.gt-k:00232            ; # &I-GT-K00232;
    :eq rep.gt-pj-1:22325         ; # &I-GT-12167;
    :eq rep.daikanwa:09656        ; # &I-M-09656;
    :eq rep.shinjigen:2260        ; # 弋
    :subsume
        g2.ucs_unicode:0x5F0B ,
        rep.gt-k:00233       ;
    .
    rep.adobe-japan1-0:04768
               :abstract-glyph-of adobe-japan1-0:04768   .
    rep.jis-x0208:0x5735
               :abstract-glyph-of      jis-x0208:0x5735  .
    rep.gb2312:0x5F2E
               :abstract-glyph-of         gb2312:0x5F2E  .
    rep.cns11643-1:0x445D
               :abstract-glyph-of     cns11643-1:0x445D  .
    rep.jis-x0213-1:0x5735
               :abstract-glyph-of    jis-x0213-1:0x5735  .
    a.big5:0xA47C
           :abstract-character-of           big5:0xA47C  .
    rep.gt:12167
               :abstract-glyph-of             gt:12167   .
    rep.gt-k:00232
               :abstract-glyph-of           gt-k:00232   .
    rep.gt-pj-1:22325
               :abstract-glyph-of        gt-pj-1:22325   .
    rep.daikanwa:09656
               :abstract-glyph-of       daikanwa:09656   .
    rep.shinjigen:2260
               :abstract-glyph-of      shinjigen:2260    .
    g2.ucs_unicode:0x5F0B
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of [ :context domain:unicode ;
                                  :target     ucs:0x5F0B  ] ;
        :rep.decomposition   [ :context domain:cid     ;
                               :target  a.ucs:0x5F0B         ,
                                        a.ucs:0xE0100        ] ;
        :eq g2.adobe-japan1-0:04768   ; # &g2-AJ1-04768;
        :eq g2.gb2312:0x5F2E          ; # &g2-AJ1-04768;
        :eq g2.jis-x0208:0x5735       ; # &g2-AJ1-04768;
        :eq g2.cns11643-1:0x445D      ; # &g2-AJ1-04768;
        :eq g2.jis-x0213-1:0x5735     ; # &g2-AJ1-04768;
        :eq g2.gt:12167               ; # &g2-AJ1-04768;
        :eq g2.gt-k:00232             ; # &g2-AJ1-04768;
        :eq g2.daikanwa:09656         ; # &g2-AJ1-04768;
        :subsume
            repi.daikanwa:09656  ,
            repi.jis-x0208:0x5735 ,
            repi.adobe-japan1-6:04768 ,
            repi.cns11643-1:0x445D ,
