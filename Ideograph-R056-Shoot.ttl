a.ucs:0x2237A
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x2237A ;
    ideo:radical           [ :context domain:ucs     ;
                             :target           56 ; # ⼷
                           ] ;
    ideo:strokes           [ :context domain:ucs     ;
                             :target  0 ] ;
    ideo:radical           [ :context domain:cns     ;
                             :target           62 ; # ⼽
                           ] ;
    ideo:strokes           [ :context domain:cns     ;
                             :target  0 ] ;
    ideo:total-strokes     3 ;
    :subsume
        rep.daikanwa:09657   ,
        rep.ucs_iso:0x2237A  ,
        rep.cns11643-6:0x2140 ;
    .
    rep.daikanwa:09657
        a chisegg:abstract-glyph ;
        :abstract-glyph-of daikanwa:09657 ;
        ideo:radical          56 ; # ⼷ 
        ideo:strokes           0 ;
        .
