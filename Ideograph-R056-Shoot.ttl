        :abstract-glyph-of [ :context domain:iso     ;
                             :target     ucs:0x2237A ] ;
        ideo:radical          56 ; # ⼷ 
        ideo:strokes           0 ;
        .
    rep.cns11643-6:0x2140
        a chisegg:abstract-glyph ;
