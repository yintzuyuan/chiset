    :eq rep.gt-k:01636            ; # &I-GT-K01636;
    :eq rep.gt-pj-1:15662         ; # &I-GT-39269;
    :eq rep.daikanwa:30350        ; # &I-M-30350;
    :eq rep.shinjigen:6641        ; # 舟
