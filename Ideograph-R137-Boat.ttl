    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x821F ;
    ideo:radical         137 ; # ⾈ 
    ideo:strokes           0 ;
    ideo:total-strokes     6 ;
    :eq rep.adobe-japan1-0:02360  ; # &I-AJ1-02360;
    :eq rep.jis-x0208:0x3D2E      ; # &I-J90-3D2E;
    :eq rep.gb2312:0x565B         ; # &I-G0-565B;
