a.ucs:0x897E
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x897E ;
    ideo:radical         146 ; # ⾑ 
    ideo:strokes           0 ;
    ideo:total-strokes     6 ;
    :eq rep.adobe-japan1-0:06635  ; # &I-AJ1-06635;
    :eq rep.jis-x0208:0x6B28      ; # &I-J90-6B28;
    :eq rep.cns11643-2:0x2270     ; # &I-C2-2270;
    :eq rep.jis-x0213-1:0x6B28    ; # &I-JX1-6B28;
    :eq a.big5:0xCA50             ; # &I-B-CA50;
