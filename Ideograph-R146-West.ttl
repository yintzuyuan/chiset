    :eq rep.gt-k:01741            ; # &I-GT-K01741;
    :eq rep.gt-pj-1:27432         ; # &I-GT-46802;
    :eq rep.daikanwa:34762        ; # &I-M-34762;
    :subsume
        g2.ucs_unicode:0x897E ;
    .
    rep.adobe-japan1-0:06635
               :abstract-glyph-of adobe-japan1-0:06635   .
    rep.jis-x0208:0x6B28
               :abstract-glyph-of      jis-x0208:0x6B28  .
