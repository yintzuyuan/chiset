    g2.ucs_unicode:0x897E
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of [ :context domain:unicode ;
                                  :target     ucs:0x897E  ] ;
        :eq g2.adobe-japan1-0:06635   ; # &g2-AJ1-06635;
        :eq g2.jis-x0208:0x6B28       ; # &g2-AJ1-06635;
        :eq g2.cns11643-2:0x2270      ; # &g2-AJ1-06635;
        :eq g2.jis-x0213-1:0x6B28     ; # &g2-AJ1-06635;
        :eq g2.gt:46802               ; # &g2-AJ1-06635;
        :eq g2.gt-k:01741             ; # &g2-AJ1-06635;
        :eq g2.daikanwa:34762         ; # &g2-AJ1-06635;
        :subsume
            repi.daikanwa:34762  ,
            repi.jis-x0208:0x6B28 ,
            repi.adobe-japan1-6:06635 ,
            repi.cns11643-2:0x2270 ,
            repi.gt:46802        ,
            repi.ucs_unicode:0x897E ;
        .
        g2.adobe-japan1-0:06635
              :abstract-glyph-form-of adobe-japan1-0:06635   .
        g2.jis-x0208:0x6B28
