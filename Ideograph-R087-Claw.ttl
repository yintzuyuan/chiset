a.ucs:0x722A
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x722A ;
    ideo:radical          87 ; # ⽖ 
    ideo:strokes           0 ;
    ideo:total-strokes     4 ;
    :eq rep.adobe-japan1-0:03066  ; # &I-AJ1-03066;
    :eq rep.jis-x0208:0x445E      ; # &I-J90-445E;
    :eq rep.gb2312:0x5726         ; # &I-G0-5726;
    :eq rep.ks-x1001:0x7050       ; # &I-K0-7050;
    :eq rep.cns11643-1:0x4557     ; # &I-C1-4557;
    :eq rep.jis-x0213-1:0x445E    ; # &I-JX1-445E;
    :eq a.big5:0xA4F6             ; # &I-B-A4F6;
    :eq rep.gt:25224              ; # &I-GT-25224;
    :eq rep.gt-k:00466            ; # &I-GT-K00466;
    :eq rep.gt-pj-1:17502         ; # &I-GT-25224;
    :eq rep.daikanwa:19653        ; # &I-M-19653;
    :eq rep.shinjigen:4696        ; # 爪
    .
    rep.adobe-japan1-0:03066
               :abstract-glyph-of adobe-japan1-0:03066   .
    rep.jis-x0208:0x445E
               :abstract-glyph-of      jis-x0208:0x445E  .
    rep.gb2312:0x5726
               :abstract-glyph-of         gb2312:0x5726  .
    rep.ks-x1001:0x7050
               :abstract-glyph-of       ks-x1001:0x7050  .
    rep.cns11643-1:0x4557
               :abstract-glyph-of     cns11643-1:0x4557  .
    rep.jis-x0213-1:0x445E
               :abstract-glyph-of    jis-x0213-1:0x445E  .
    a.big5:0xA4F6
           :abstract-character-of           big5:0xA4F6  .
    rep.gt:25224
               :abstract-glyph-of             gt:25224   .
    rep.gt-k:00466
               :abstract-glyph-of           gt-k:00466   .
    rep.gt-pj-1:17502
               :abstract-glyph-of        gt-pj-1:17502   .
    rep.daikanwa:19653
               :abstract-glyph-of       daikanwa:19653   .
    rep.shinjigen:4696
               :abstract-glyph-of      shinjigen:4696    .

a.ucs:0x244EF
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x244EF ;
    ideo:radical          87 ; # ⽖ 
    ideo:strokes           0 ;
    ideo:total-strokes     4 ;
    :subsume
        rep.daikanwa:19654   ,
        rep.ucs_iso:0x244EF  ,
        rep.cns11643-5:0x214B ;
    .
    rep.daikanwa:19654
        a chisegg:abstract-glyph ;
        :abstract-glyph-of daikanwa:19654 ;
        .
    rep.ucs_iso:0x244EF
        a chisegg:abstract-glyph ;
        :abstract-glyph-of [ :context domain:iso     ;
                             :target     ucs:0x244EF ] ;
        .
    rep.cns11643-5:0x214B
        a chisegg:abstract-glyph ;
        :abstract-glyph-of cns11643-5:0x214B ;
        .

