a.ucs:0x24D14
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x24D14 ;
    ideo:radical         103 ; # ⽦ 
    ideo:strokes           0 ;
    ideo:total-strokes     5 ;
    :eq rep.jis-x0213-2:0x7144    ; # &I-JX2-7144;
    :form-of             [ :context domain:component...connect-right ;
