        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of [ :context domain:iso     ;
                                  :target     ucs:0x24D14 ] ;
        :eq g2.jis-x0213-2:0x7144     ; # &g2-JX2-7144;
        :subsume
            repi.jis-x0213-2:0x7144 ,
            repi.ucs_iso:0x24D14 ;
        .
        g2.jis-x0213-2:0x7144
              :abstract-glyph-form-of    jis-x0213-2:0x7144  .
        repi.jis-x0213-2:0x7144
            a chisegg:glyph-image ;
            :glyph-image-of jis-x0213-2:0x7144 ;
            .
        repi.ucs_iso:0x24D14
            a chisegg:glyph-image ;
            :glyph-image-of [ :context domain:iso     ;
                              :target     ucs:0x24D14 ] ;
            .
    rep.big5-cdp:0x8DC5
        a chisegg:abstract-glyph ;
        :abstract-glyph-of big5-cdp:0x8DC5 ;
        :form-of             [ :context domain:component ;
                               :target  a.ucs:0x758B         ] ;
        .

