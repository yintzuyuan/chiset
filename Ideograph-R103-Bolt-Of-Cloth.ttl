a.ucs:0x758B
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x758B ;
    ideo:radical         103 ; # ⽦ 
    ideo:strokes           0 ;
    ideo:total-strokes     5 ;
    :eq rep.adobe-japan1-0:03479  ; # &I-AJ1-03479;
    :eq rep.jis-x0208:0x4925      ; # &I-J90-4925;
    :eq rep.gb2312:0x7162         ; # &I-G0-7162;
    :eq rep.ks-x1001:0x7935       ; # &I-K0-7935;
    :eq rep.cns11643-1:0x4674     ; # &I-C1-4674;
    :eq rep.jis-x0213-1:0x4925    ; # &I-JX1-4925;
    :eq a.big5:0xA5D4             ; # &I-B-A5D4;
    :eq rep.gt:28230              ; # &I-GT-28230;
    :eq rep.gt-k:00991            ; # &I-GT-K00991;
    :eq rep.gt-pj-1:18725         ; # &I-GT-28230;
    :eq rep.daikanwa:21994        ; # &I-M-21994;
    :eq rep.shinjigen:5084        ; # 疋
    .
    rep.adobe-japan1-0:03479
               :abstract-glyph-of adobe-japan1-0:03479   .
    rep.jis-x0208:0x4925
               :abstract-glyph-of      jis-x0208:0x4925  .
    rep.gb2312:0x7162
               :abstract-glyph-of         gb2312:0x7162  .
    rep.ks-x1001:0x7935
               :abstract-glyph-of       ks-x1001:0x7935  .
    rep.cns11643-1:0x4674
               :abstract-glyph-of     cns11643-1:0x4674  .
    rep.jis-x0213-1:0x4925
               :abstract-glyph-of    jis-x0213-1:0x4925  .
    a.big5:0xA5D4
           :abstract-character-of           big5:0xA5D4  .
    rep.gt:28230
               :abstract-glyph-of             gt:28230   .
    rep.gt-k:00991
               :abstract-glyph-of           gt-k:00991   .
    rep.gt-pj-1:18725
               :abstract-glyph-of        gt-pj-1:18725   .
    rep.daikanwa:21994
