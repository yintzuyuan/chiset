a.ucs:0x5E72
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x5E72 ;
    ideo:radical          51 ; # ⼲ 
    ideo:strokes           0 ;
    ideo:total-strokes     3 ;
    :eq rep.adobe-japan1-0:01519  ; # &I-AJ1-01519;
    :eq rep.jis-x0208:0x3433      ; # &I-J90-3433;
    :eq rep.gb2312:0x3849         ; # &I-G0-3849;
