        :eq g2.gb2312:0x3849          ; # &g2-AJ1-01519;
        :eq g2.ks-x1001:0x4A4E        ; # &g2-AJ1-01519;
        :eq g2.jis-x0208:0x3433       ; # &g2-AJ1-01519;
        :eq g2.cns11643-1:0x445B      ; # &g2-AJ1-01519;
        :eq g2.jis-x0213-1:0x3433     ; # &g2-AJ1-01519;
        :eq g2.gt:11548               ; # &g2-AJ1-01519;
        :eq g2.gt-k:00160             ; # &g2-AJ1-01519;
        :eq g2.daikanwa:09165         ; # &g2-AJ1-01519;
        :eq g2.shinjigen:2149         ; # &g2-AJ1-01519;
