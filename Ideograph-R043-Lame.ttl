a.ucs:0x5C22
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x5C22 ;
    :from.denotational_component
        a.ucs_component:0x5C22 ,
        a.ucs_component:0x4E5D ,
        a.ucs_component:0x5C24 ;
    ideo:radical          43 ; # ⼪ 
    ideo:strokes           0 ;
    ideo:total-strokes     3 ;
    :eq a.jis-x0208:0x5577        ; # 尢
    :eq a.jis-x0213-1:0x5577      ; # 尢
    :eq a.big5:0xA471             ; # &I-B-A471;
    :eq a.iwds-1:0117             ; # 尢
    .
    a.jis-x0208:0x5577
           :abstract-character-of      jis-x0208:0x5577  .
    a.jis-x0213-1:0x5577
           :abstract-character-of    jis-x0213-1:0x5577  .
    a.big5:0xA471
           :abstract-character-of           big5:0xA471  .
    a.iwds-1:0117
           :abstract-character-of         iwds-1:0117    .

rep.gt:09497
    a chisegg:abstract-glyph ;
    :abstract-glyph-of gt:09497 ;
    :denotation-of
        a.ucs:0x5C22         ;
    ideo:radical          43 ; # ⼪ 
    ideo:strokes           0 ;
    ideo:total-strokes     3 ;
    :eq rep.ucs_cns:0x5C22        ; # &GT-09497;
    :eq rep.cns11643-1:0x4452     ; # &GT-09497;
    :eq rep.gt-pj-3:12888         ; # &I-GT-09497;
    :eq rep.daikanwa:07538        ; # &I-M-07538;
    :subsume
        g2.gt:09497          ,
        g2.cns11643-1:0x4452 ;
    .
    rep.ucs_cns:0x5C22
               :abstract-glyph-of [ :context domain:cns     ;
                                    :target     ucs:0x5C22  ] .
    rep.cns11643-1:0x4452
               :abstract-glyph-of     cns11643-1:0x4452  .
    rep.gt-pj-3:12888
               :abstract-glyph-of        gt-pj-3:12888   .
    rep.daikanwa:07538
               :abstract-glyph-of       daikanwa:07538   .
    g2.gt:09497
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of gt:09497 ;
        :eq g2.daikanwa:07538         ; # &g2-GT-09497;
        :subsume
            repi.daikanwa:07538  ,
            repi.gt:09497        ;
        .
        g2.daikanwa:07538
              :abstract-glyph-form-of       daikanwa:07538   .
        repi.daikanwa:07538
            a chisegg:glyph-image ;
            :glyph-image-of daikanwa:07538 ;
            .
        repi.gt:09497
            a chisegg:glyph-image ;
            :glyph-image-of gt:09497 ;
            .
    g2.cns11643-1:0x4452
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of cns11643-1:0x4452 ;
        :eq g2.ucs_cns:0x5C22         ; # &g2-CU+5C22;
        .
        g2.ucs_cns:0x5C22
              :abstract-glyph-form-of [ :context domain:cns     ;
                                        :target     ucs:0x5C22  ] .

rep.gt-k:00221
    a chisegg:abstract-glyph ;
    :abstract-glyph-of gt-k:00221 ;
    :denotation-of
        rep.gt:09497         ;
    ideo:radical          43 ; # ⼪ 
    ideo:strokes           0 ;
    ideo:total-strokes     3 ;
    :eq rep.gt-pj-k1:19291        ; # &GT-K00221;
    :form-of             [ :context domain:component...connect-right ;
                           :target  rep.gt:09497         ] ;
    .
    rep.gt-pj-k1:19291
               :abstract-glyph-of       gt-pj-k1:19291   .

a.ucs:0x2E90
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x2E90 ;
    :denotation-of
        a.ucs:0x5C22         ;
    :name                 "CJK RADICAL LAME THREE" ;
    :general-category     "(symbol other)" ; # Informative Category
    :bidi-category        "ON" ;
    :mirrored             "nil" ;
    :from.identical      [ :context domain:component ;
                           :target  a.ucs:0x5C22         ] ;
    .

a.ucs:0x2F875
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x2F875 ;
    :denotation-of
        a.ucs:0x5C22         ;
    :to.canonical-ucs	a.ucs:0x5C22 ; # 尢
    ideo:radical          43 ; # ⼪ 
    ideo:strokes           0 ;
    ideo:total-strokes     3 ;
    :rep.decomposition   [ :context domain:cid     ;
                           :target  a.ucs:0x5C22         ,
                                    a.ucs:0xE0100        ] ;
    :eq rep.ucs_unicode:0x5C22    ; # 尢
    :eq rep.ucs_cns:0x2F875       ; # 尢
    :eq rep.adobe-japan1-0:04646  ; # &I-AJ1-04646;
    :eq rep.jis-x0208:0x5577      ; # &I-J90-5577;
    :eq rep.gb2312:0x5E4C         ; # &I-G0-5E4C;
    :eq rep.cns11643-4:0x2134     ; # &I-C4-2134;
    :eq rep.jis-x0213-1:0x5577    ; # &I-JX1-5577;
