a.ucs:0x9F3B
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x9F3B ;
    ideo:radical         209 ; # ⿐ 
    ideo:strokes           0 ;
    ideo:total-strokes    14 ;
    :eq a.jis-x0208:0x4921        ; # 鼻
    :eq a.jis-x0213-1:0x4921      ; # 鼻
    .
    a.jis-x0208:0x4921
           :abstract-character-of      jis-x0208:0x4921  .
    a.jis-x0213-1:0x4921
           :abstract-character-of    jis-x0213-1:0x4921  .

rep.gt:66224
    a chisegg:abstract-glyph ;
    :abstract-glyph-of gt:66224 ;
    :denotation-of
        a.ucs:0x9F3B         ;
    ideo:radical         209 ; # ⿐ 
    ideo:strokes           0 ;
    ideo:total-strokes    14 ;
    :eq rep.ucs_unicode:0x9F3B    ; # &GT-66224;
    :rep.ucs_JP...hanazono     rdf:nil ;
    :eq rep.gb2312:0x3147         ; # &GT-66224;
    :eq rep.cns11643-1:0x6B7C     ; # &I-C1-6B7C;
    :eq rep.gt-k:11266            ; # &I-GT-K11266;
    :eq rep.gt-pj-8:29548         ; # &I-GT-66224;
    :eq rep.daikanwa:48498        ; # &I-M-48498;
    :eq rep.jef-china3:0x6FF3     ; # &I-JC3-6FF3;
    .
    rep.ucs_unicode:0x9F3B
               :abstract-glyph-of [ :context domain:unicode ;
                                    :target     ucs:0x9F3B  ] .
    rep.gb2312:0x3147
               :abstract-glyph-of         gb2312:0x3147  .
    rep.cns11643-1:0x6B7C
               :abstract-glyph-of     cns11643-1:0x6B7C  .
    rep.gt-k:11266
               :abstract-glyph-of           gt-k:11266   .
    rep.gt-pj-8:29548
               :abstract-glyph-of        gt-pj-8:29548   .
    rep.daikanwa:48498
               :abstract-glyph-of       daikanwa:48498   .
    rep.jef-china3:0x6FF3
               :abstract-glyph-of     jef-china3:0x6FF3  .

a.ucs:0x2FA1C
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x2FA1C ;
    :denotation-of
        a.ucs:0x9F3B         ;
    :to.canonical-ucs	a.ucs:0x9F3B ; # 鼻
    ideo:radical         209 ; # ⿐ 
    ideo:strokes           0 ;
    ideo:total-strokes    14 ;
    :eq rep.ucs_jis:0x9F3B        ; # 鼻
    :eq rep.ucs_ks:0x9F3B         ; # 鼻
    :eq rep.adobe-japan1-0:03475  ; # &I-AJ1-03475;
    :eq rep.jis-x0208:0x4921      ; # &I-J90-4921;
    :eq rep.ks-x1001:0x5E2C       ; # &I-K0-5E2C;
    :eq rep.cns11643-4:0x4877     ; # &I-C4-4877;
    :eq rep.jis-x0213-1:0x4921    ; # &I-JX1-4921;
    :eq rep.gt:66225              ; # &I-GT-66225;
    :eq rep.gt-k:11267            ; # &I-GT-K11267;
    :eq rep.gt-pj-1:18721         ; # &I-GT-66225;
    :eq rep.daikanwa...._.p:48498 ; # 鼻
    :subsume
        g2.ucs_iso:0x2FA1C   ;
    .
    rep.ucs_jis:0x9F3B
               :abstract-glyph-of [ :context domain:jis     ;
                                    :target     ucs:0x9F3B  ] .
    rep.ucs_ks:0x9F3B
               :abstract-glyph-of [ :context domain:ks      ;
                                    :target     ucs:0x9F3B  ] .
    rep.adobe-japan1-0:03475
               :abstract-glyph-of adobe-japan1-0:03475   .
    rep.jis-x0208:0x4921
               :abstract-glyph-of      jis-x0208:0x4921  .
    rep.ks-x1001:0x5E2C
               :abstract-glyph-of       ks-x1001:0x5E2C  .
    rep.cns11643-4:0x4877
               :abstract-glyph-of     cns11643-4:0x4877  .
    rep.jis-x0213-1:0x4921
               :abstract-glyph-of    jis-x0213-1:0x4921  .
    rep.gt:66225
               :abstract-glyph-of             gt:66225   .
    rep.gt-k:11267
               :abstract-glyph-of           gt-k:11267   .
    rep.gt-pj-1:18721
               :abstract-glyph-of        gt-pj-1:18721   .
    rep.daikanwa...._.p:48498
               :abstract-glyph-of daikanwa...._.p:48498   .
    g2.ucs_iso:0x2FA1C
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of [ :context domain:iso     ;
                                  :target     ucs:0x2FA1C ] ;
        :eq g2.ucs_jis:0x9F3B         ; # &g2-AJ1-03475;
        :eq g2.ucs_ks:0x9F3B          ; # &g2-AJ1-03475;
        :eq g2.adobe-japan1-0:03475   ; # &g2-AJ1-03475;
        :eq g2.ks-x1001:0x5E2C        ; # &g2-AJ1-03475;
        :eq g2.jis-x0208:0x4921       ; # &g2-AJ1-03475;
        :eq g2.cns11643-4:0x4877      ; # &g2-AJ1-03475;
        :eq g2.jis-x0213-1:0x4921     ; # &g2-AJ1-03475;
        :eq g2.gt:66225               ; # &g2-AJ1-03475;
        :eq g2.gt-k:11267             ; # &g2-AJ1-03475;
        :eq g2.daikanwa...._.p:48498  ; # &g2-AJ1-03475;
        :subsume
            repi.daikanwa...._.p:48498 ,
            repi.jis-x0208:0x4921 ,
            repi.adobe-japan1-6:03475 ,
            repi.cns11643-4:0x4877 ,
            repi.gt:66225        ,
            repi.ks-x1001:0x5E2C ,
            repi.ucs_iso:0x2FA1C ;
        .
        g2.ucs_jis:0x9F3B
              :abstract-glyph-form-of [ :context domain:jis     ;
                                        :target     ucs:0x9F3B  ] .
        g2.ucs_ks:0x9F3B
              :abstract-glyph-form-of [ :context domain:ks      ;
                                        :target     ucs:0x9F3B  ] .
        g2.adobe-japan1-0:03475
              :abstract-glyph-form-of adobe-japan1-0:03475   .
        g2.ks-x1001:0x5E2C
              :abstract-glyph-form-of       ks-x1001:0x5E2C  .
        g2.jis-x0208:0x4921
              :abstract-glyph-form-of      jis-x0208:0x4921  .
