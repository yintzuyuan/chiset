              :abstract-glyph-form-of    jis-x0213-1:0x4921  .
        g2.gt:66225
              :abstract-glyph-form-of             gt:66225   .
        g2.gt-k:11267
              :abstract-glyph-form-of           gt-k:11267   .
        g2.daikanwa...._.p:48498
              :abstract-glyph-form-of daikanwa...._.p:48498   .
        repi.daikanwa...._.p:48498
            a chisegg:glyph-image ;
            :glyph-image-of daikanwa...._.p:48498 ;
            .
        repi.jis-x0208:0x4921
            a chisegg:glyph-image ;
            :glyph-image-of jis-x0208:0x4921 ;
            :eq repi.jis-x0213-1:0x4921   ; # &R-J0-4921;
            .
            repi.jis-x0213-1:0x4921
