a.ucs:0x21C23
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x21C23 ;
    ideo:radical          44 ; # ⼫ 
    ideo:strokes           0 ;
    ideo:total-strokes     3 ;
    :eq rep.cns11643-6:0x213E     ; # &I-C6-213E;
    :eq rep.big5-cdp:0x86BA       ; # &I-CDP-86BA;
    :eq rep.daikanwa:07629        ; # &I-M-07629;
    .
    rep.cns11643-6:0x213E
               :abstract-glyph-of     cns11643-6:0x213E  .
    rep.big5-cdp:0x86BA
               :abstract-glyph-of       big5-cdp:0x86BA  .
    rep.daikanwa:07629
               :abstract-glyph-of       daikanwa:07629   .

