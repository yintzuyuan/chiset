a.ucs:0x6B79
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x6B79 ;
    ideo:radical          78 ; # ⽍ 
    ideo:strokes           0 ;
    ideo:total-strokes     4 ;
    :eq rep.adobe-japan1-0:05349  ; # &I-AJ1-05349;
    :eq rep.jis-x0208:0x5D46      ; # &I-J90-5D46;
    :eq rep.gb2312:0x3475         ; # &I-G0-3475;
    :eq rep.cns11643-1:0x4550     ; # &I-C1-4550;
    :eq rep.jis-x0213-1:0x5D46    ; # &I-JX1-5D46;
    :eq a.big5:0xA4EF             ; # &I-B-A4EF;
    :eq rep.gt:21005              ; # &I-GT-21005;
    :eq rep.gt-k:00536            ; # &I-GT-K00536;
    :eq rep.gt-pj-1:23878         ; # &I-GT-21005;
    :eq rep.daikanwa:16359        ; # &I-M-16359;
    .
    rep.adobe-japan1-0:05349
               :abstract-glyph-of adobe-japan1-0:05349   .
    rep.jis-x0208:0x5D46
               :abstract-glyph-of      jis-x0208:0x5D46  .
    rep.gb2312:0x3475
               :abstract-glyph-of         gb2312:0x3475  .
    rep.cns11643-1:0x4550
               :abstract-glyph-of     cns11643-1:0x4550  .
    rep.jis-x0213-1:0x5D46
               :abstract-glyph-of    jis-x0213-1:0x5D46  .
    a.big5:0xA4EF
           :abstract-character-of           big5:0xA4EF  .
    rep.gt:21005
               :abstract-glyph-of             gt:21005   .
    rep.gt-k:00536
               :abstract-glyph-of           gt-k:00536   .
    rep.gt-pj-1:23878
               :abstract-glyph-of        gt-pj-1:23878   .
    rep.daikanwa:16359
               :abstract-glyph-of       daikanwa:16359   .

a.ucs:0x239B6
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x239B6 ;
    ideo:radical          78 ; # ⽍ 
    ideo:strokes           0 ;
    ideo:total-strokes     4 ;
    :subsume
        rep.ucs_iso:0x239B6  ,
        rep.cns11643-5:0x2149 ;
    .
    rep.ucs_iso:0x239B6
        a chisegg:abstract-glyph ;
        :abstract-glyph-of [ :context domain:iso     ;
                             :target     ucs:0x239B6 ] ;
        :eq rep.daikanwa:16360        ; # &M-16360;
        .
        rep.daikanwa:16360
                   :abstract-glyph-of       daikanwa:16360   .
    rep.cns11643-5:0x2149
        a chisegg:abstract-glyph ;
        :abstract-glyph-of cns11643-5:0x2149 ;
        .

a.ucs:0x239B5
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x239B5 ;
    ideo:radical          78 ; # ⽍ 
    ideo:strokes           0 ;
    ideo:total-strokes     5 ;
    :subsume
        rep.daikanwa:16361   ,
