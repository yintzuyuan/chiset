a.ucs:0x8C78
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x8C78 ;
    ideo:radical         153 ; # ⾘ 
    ideo:strokes           0 ;
    ideo:total-strokes     7 ;
    :eq rep.adobe-japan1-0:06745  ; # &I-AJ1-06745;
    :eq rep.jis-x0208:0x6C38      ; # &I-J90-6C38;
    :eq rep.gb2312:0x7574         ; # &I-G0-7574;
    :eq rep.cns11643-2:0x2524     ; # &I-C2-2524;
    :eq rep.jis-x0213-1:0x6C38    ; # &I-JX1-6C38;
    :eq a.big5:0xCBA4             ; # &I-B-CBA4;
    :eq rep.gt:48928              ; # &I-GT-48928;
    :eq rep.gt-k:02732            ; # &I-GT-K02732;
    :eq rep.gt-pj-1:27704         ; # &I-GT-48928;
    :eq rep.daikanwa:36496        ; # &I-M-36496;
    :eq rep.shinjigen:7831        ; # 豸
    :subsume
        g2.ucs_unicode:0x8C78 ;
    .
    rep.adobe-japan1-0:06745
               :abstract-glyph-of adobe-japan1-0:06745   .
    rep.jis-x0208:0x6C38
               :abstract-glyph-of      jis-x0208:0x6C38  .
    rep.gb2312:0x7574
               :abstract-glyph-of         gb2312:0x7574  .
    rep.cns11643-2:0x2524
               :abstract-glyph-of     cns11643-2:0x2524  .
    rep.jis-x0213-1:0x6C38
               :abstract-glyph-of    jis-x0213-1:0x6C38  .
    a.big5:0xCBA4
           :abstract-character-of           big5:0xCBA4  .
    rep.gt:48928
               :abstract-glyph-of             gt:48928   .
    rep.gt-k:02732
               :abstract-glyph-of           gt-k:02732   .
    rep.gt-pj-1:27704
               :abstract-glyph-of        gt-pj-1:27704   .
    rep.daikanwa:36496
               :abstract-glyph-of       daikanwa:36496   .
    rep.shinjigen:7831
               :abstract-glyph-of      shinjigen:7831    .
    g2.ucs_unicode:0x8C78
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of [ :context domain:unicode ;
                                  :target     ucs:0x8C78  ] ;
        :eq g2.adobe-japan1-0:06745   ; # &g2-AJ1-06745;
        :eq g2.gb2312:0x7574          ; # &g2-AJ1-06745;
        :eq g2.jis-x0208:0x6C38       ; # &g2-AJ1-06745;
        :eq g2.cns11643-2:0x2524      ; # &g2-AJ1-06745;
        :eq g2.jis-x0213-1:0x6C38     ; # &g2-AJ1-06745;
        :eq g2.gt:48928               ; # &g2-AJ1-06745;
        :eq g2.gt-k:02732             ; # &g2-AJ1-06745;
        :eq g2.daikanwa:36496         ; # &g2-AJ1-06745;
        :eq g2.shinjigen:7831         ; # &g2-AJ1-06745;
        :subsume
            repi.daikanwa:36496  ,
            repi.jis-x0208:0x6C38 ,
            repi.adobe-japan1-6:06745 ,
            repi.cns11643-2:0x2524 ,
