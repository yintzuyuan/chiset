a.ucs:0x5EFE
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x5EFE ;
    ideo:radical          55 ; # ⼶ 
    ideo:strokes           0 ;
    :sound               [ :context domain:ja...on...go ;
                           :target  ( "ku" ) ;
                         ] ;
    :sound               [ :context domain:ja...on...kan ;
                           :target  ( "kIyou" ) ;
                         ] ;
    .

rep.mj:011120
    a chisegg:abstract-glyph ;
    :abstract-glyph-of mj:011120 ;
    :denotation-of
        a.ucs:0x5EFE         ;
    ideo:radical          55 ; # ⼶ 
    ideo:strokes           0 ;
    ideo:total-strokes     3 ;
    :eq rep.ucs_unicode:0x5EFE    ; # &MJ011120;
    :eq rep.adobe-japan1-0:04763  ; # &I-AJ1-04763;
    :eq rep.jis-x0208:0x5730      ; # &I-J90-5730;
    :eq rep.gb2312:0x5E43         ; # &I-G0-5E43;
    :eq rep.cns11643-1:0x445C     ; # &I-C1-445C;
    :eq rep.jis-x0213-1:0x5730    ; # &I-JX1-5730;
    :eq a.big5:0xA47B             ; # &I-B-A47B;
    :eq rep.hanyo-denshi...ja:0x5730 ; # &I-HD-JA-5730;
    :eq rep.gt:12077              ; # &I-GT-12077;
    :eq rep.gt-k:00231            ; # &I-GT-K00231;
    :eq rep.gt-pj-1:22320         ; # &I-GT-12077;
    :eq rep.daikanwa:09583        ; # &I-M-09583;
    :to.mistakable       [ :sources chisebib:daikanwa ;
                           :target  rep.cns11643-3:0x2138 ] ;
    :subsume
        g2.mj:011120         ;
    .
    rep.ucs_unicode:0x5EFE
               :abstract-glyph-of [ :context domain:unicode ;
                                    :target     ucs:0x5EFE  ] .
    rep.adobe-japan1-0:04763
               :abstract-glyph-of adobe-japan1-0:04763   .
    rep.jis-x0208:0x5730
               :abstract-glyph-of      jis-x0208:0x5730  .
    rep.gb2312:0x5E43
               :abstract-glyph-of         gb2312:0x5E43  .
    rep.cns11643-1:0x445C
               :abstract-glyph-of     cns11643-1:0x445C  .
    rep.jis-x0213-1:0x5730
               :abstract-glyph-of    jis-x0213-1:0x5730  .
    a.big5:0xA47B
           :abstract-character-of           big5:0xA47B  .
    rep.hanyo-denshi...ja:0x5730
               :abstract-glyph-of hanyo-denshi...ja:0x5730  .
    rep.gt:12077
               :abstract-glyph-of             gt:12077   .
    rep.gt-k:00231
               :abstract-glyph-of           gt-k:00231   .
    rep.gt-pj-1:22320
               :abstract-glyph-of        gt-pj-1:22320   .
    rep.daikanwa:09583
               :abstract-glyph-of       daikanwa:09583   .
    g2.mj:011120
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of mj:011120 ;
        :rep.decomposition   [ :context domain:cid     ;
                               :target  a.ucs:0x5EFE         ,
                                        a.ucs:0xE0100        ] ;
        :rep.decomposition   [ :context domain:hanyo-denshi ;
                               :target  a.ucs:0x5EFE         ,
                                        a.ucs:0xE0101        ] ;
        :eq g2.ucs_unicode:0x5EFE     ; # &g2-MJ011120;
        :eq g2.adobe-japan1-0:04763   ; # &g2-MJ011120;
        :eq g2.gb2312:0x5E43          ; # &g2-MJ011120;
        :eq g2.jis-x0208:0x5730       ; # &g2-MJ011120;
        :eq g2.cns11643-1:0x445C      ; # &g2-MJ011120;
        :eq g2.jis-x0213-1:0x5730     ; # &g2-MJ011120;
        :eq g2.hanyo-denshi...ja:0x5730 ; # &g2-MJ011120;
        :eq g2.gt:12077               ; # &g2-MJ011120;
        :eq g2.gt-k:00231             ; # &g2-MJ011120;
        :eq g2.daikanwa:09583         ; # &g2-MJ011120;
        :subsume
            repi.daikanwa:09583  ,
            repi.jis-x0208:0x5730 ,
            repi.adobe-japan1-6:04763 ,
            repi.mj:011120       ,
            repi.cns11643-1:0x445C ,
            repi.gt:12077        ,
            repi.ucs_unicode:0x5EFE ;
        .
