a.ucs_component:0x9751
    a chisegg:abstract-character ;
    :abstract-character-of [ :context domain:component ;
                             :target     ucs:0x9751  ] ;
    ideo:radical         174 ; # ⾭ 
    ideo:strokes           0 ;
    ideo:total-strokes     8 ;
    :eq a.iwds-1:0319             ; # &IWDS1-319;
    .
    a.iwds-1:0319
           :abstract-character-of         iwds-1:0319    .

a.ucs:0x9751
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x9751 ;
    :denotation-of
        a.ucs_component:0x9751 ;
    ideo:radical         174 ; # ⾭ 
    ideo:strokes           0 ;
    ideo:total-strokes     8 ;
    :eq rep.adobe-japan1-2:08695  ; # &I-AJ1-08695;
    :eq rep.ks-x1001:0x746C       ; # &I-K0-746C;
    :eq rep.cns11643-3:0x2A7E     ; # &I-C3-2A7E;
    :eq rep.daikanwa:42564        ; # &I-M-42564;
    :eq rep.jef-china3:0x6CB3     ; # &I-JC3-6CB3;
    :subsume
        g2.ucs_unicode:0x9751 ,
        g2.cns11643-3:0x2A7E ;
    .
    rep.adobe-japan1-2:08695
               :abstract-glyph-of adobe-japan1-2:08695   .
    rep.ks-x1001:0x746C
               :abstract-glyph-of       ks-x1001:0x746C  .
    rep.cns11643-3:0x2A7E
               :abstract-glyph-of     cns11643-3:0x2A7E  .
    rep.daikanwa:42564
               :abstract-glyph-of       daikanwa:42564   .
    rep.jef-china3:0x6CB3
               :abstract-glyph-of     jef-china3:0x6CB3  .
    g2.ucs_unicode:0x9751
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of [ :context domain:unicode ;
                                  :target     ucs:0x9751  ] ;
        :eq g2.adobe-japan1-2:08695   ; # &g2-AJ1-08695;
        :eq g2.ks-x1001:0x746C        ; # &g2-AJ1-08695;
        :eq g2.daikanwa:42564         ; # &g2-AJ1-08695;
        :eq g2.jef-china3:0x6CB3      ; # &g2-AJ1-08695;
        :subsume
            repi.daikanwa:42564  ,
            repi.adobe-japan1-6:08695 ,
            repi.jef-china3:0x6CB3 ,
            repi.ks-x1001:0x746C ,
            repi.ucs_unicode:0x9751 ;
        .
        g2.adobe-japan1-2:08695
              :abstract-glyph-form-of adobe-japan1-2:08695   .
        g2.ks-x1001:0x746C
              :abstract-glyph-form-of       ks-x1001:0x746C  .
        g2.daikanwa:42564
              :abstract-glyph-form-of       daikanwa:42564   .
        g2.jef-china3:0x6CB3
              :abstract-glyph-form-of     jef-china3:0x6CB3  .
        repi.daikanwa:42564
            a chisegg:glyph-image ;
            :glyph-image-of daikanwa:42564 ;
            .
        repi.adobe-japan1-2:08695
            a chisegg:glyph-image ;
            :glyph-image-of adobe-japan1-2:08695 ;
            .
        repi.jef-china3:0x6CB3
            a chisegg:glyph-image ;
            :glyph-image-of jef-china3:0x6CB3 ;
            .
        repi.ks-x1001:0x746C
