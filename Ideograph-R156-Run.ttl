a.ucs:0x8D70
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x8D70 ;
    ideo:radical         156 ; # ⾛ 
    ideo:strokes           0 ;
    ideo:total-strokes     7 ;
    :eq rep.adobe-japan1-0:02808  ; # &I-AJ1-02808;
    :eq rep.jis-x0208:0x4176      ; # &I-J90-4176;
    :eq rep.gb2312:0x575F         ; # &I-G0-575F;
    :eq rep.ks-x1001:0x714B       ; # &I-K0-714B;
    :eq rep.cns11643-1:0x4B4C     ; # &I-C1-4B4C;
    :eq rep.jis-x0213-1:0x4176    ; # &I-JX1-4176;
    :eq a.big5:0xA8AB             ; # &I-B-A8AB;
    :eq rep.gt:49582              ; # &I-GT-49582;
    :eq rep.gt-k:02595            ; # &I-GT-K02595;
    :eq rep.gt-pj-1:16758         ; # &I-GT-49582;
    :eq rep.daikanwa:37034        ; # &I-M-37034;
    :eq rep.shinjigen:7954        ; # 走
    :subsume
        g2.ucs_unicode:0x8D70 ;
    .
    rep.adobe-japan1-0:02808
               :abstract-glyph-of adobe-japan1-0:02808   .
    rep.jis-x0208:0x4176
               :abstract-glyph-of      jis-x0208:0x4176  .
    rep.gb2312:0x575F
               :abstract-glyph-of         gb2312:0x575F  .
    rep.ks-x1001:0x714B
               :abstract-glyph-of       ks-x1001:0x714B  .
    rep.cns11643-1:0x4B4C
               :abstract-glyph-of     cns11643-1:0x4B4C  .
    rep.jis-x0213-1:0x4176
               :abstract-glyph-of    jis-x0213-1:0x4176  .
    a.big5:0xA8AB
           :abstract-character-of           big5:0xA8AB  .
    rep.gt:49582
               :abstract-glyph-of             gt:49582   .
    rep.gt-k:02595
               :abstract-glyph-of           gt-k:02595   .
    rep.gt-pj-1:16758
               :abstract-glyph-of        gt-pj-1:16758   .
    rep.daikanwa:37034
               :abstract-glyph-of       daikanwa:37034   .
    rep.shinjigen:7954
               :abstract-glyph-of      shinjigen:7954    .
    g2.ucs_unicode:0x8D70
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of [ :context domain:unicode ;
                                  :target     ucs:0x8D70  ] ;
        :eq g2.adobe-japan1-0:02808   ; # &g2-AJ1-02808;
        :eq g2.gb2312:0x575F          ; # &g2-AJ1-02808;
        :eq g2.ks-x1001:0x714B        ; # &g2-AJ1-02808;
        :eq g2.jis-x0208:0x4176       ; # &g2-AJ1-02808;
        :eq g2.cns11643-1:0x4B4C      ; # &g2-AJ1-02808;
        :eq g2.jis-x0213-1:0x4176     ; # &g2-AJ1-02808;
        :eq g2.gt:49582               ; # &g2-AJ1-02808;
        :eq g2.gt-k:02595             ; # &g2-AJ1-02808;
        :eq g2.daikanwa:37034         ; # &g2-AJ1-02808;
        :eq g2.shinjigen:7954         ; # &g2-AJ1-02808;
        :subsume
            repi.daikanwa:37034  ,
            repi.jis-x0208:0x4176 ,
            repi.adobe-japan1-6:02808 ,
            repi.cns11643-1:0x4B4C ,
            repi.gt:49582        ,
            repi.ks-x1001:0x714B ,
            repi.ucs_unicode:0x8D70 ;
        .
        g2.adobe-japan1-0:02808
              :abstract-glyph-form-of adobe-japan1-0:02808   .
        g2.gb2312:0x575F
              :abstract-glyph-form-of         gb2312:0x575F  .
        g2.ks-x1001:0x714B
              :abstract-glyph-form-of       ks-x1001:0x714B  .
        g2.jis-x0208:0x4176
              :abstract-glyph-form-of      jis-x0208:0x4176  .
