    :abstract-character-of ucs:0x8DB2 ;
    ideo:radical         156 ; # ⾛ 
    ideo:strokes          19 ;
    ideo:total-strokes    26 ;
    :eq rep.jis-x0212:0x5F59      ; # &I-JSP-5F59;
    :eq rep.cns11643-2:0x715E     ; # &I-C2-715E;
    :eq rep.gb12345:0x7475        ; # 趲
    :eq a.big5:0xF96F             ; # &I-B-F96F;
    :eq rep.daikanwa:37362        ; # &I-M-37362;
