        repi.daikanwa:37034
            a chisegg:glyph-image ;
            :glyph-image-of daikanwa:37034 ;
            .
        repi.jis-x0208:0x4176
            a chisegg:glyph-image ;
            :glyph-image-of jis-x0208:0x4176 ;
            :eq repi.jis-x0213-1:0x4176   ; # &R-J0-4176;
            .
            repi.jis-x0213-1:0x4176
                          :glyph-image-of    jis-x0213-1:0x4176  .
        repi.adobe-japan1-0:02808
            a chisegg:glyph-image ;
            :glyph-image-of adobe-japan1-0:02808 ;
