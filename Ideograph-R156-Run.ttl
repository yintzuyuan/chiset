                          :glyph-image-of           gt-k:02595   .
        repi.ks-x1001:0x714B
            a chisegg:glyph-image ;
            :glyph-image-of ks-x1001:0x714B ;
            :eq repi.ucs_ks:0x8D70        ; # &R-K0-714B;
            .
