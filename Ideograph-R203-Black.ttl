a.ucs:0x9ED1
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x9ED1 ;
    :denotation-of
        a.jis-x0208_1997:0x3975 ;
    ideo:radical         203 ; # ⿊ 
    ideo:strokes           0 ;
    ideo:total-strokes    12 ;
    :eq rep.gb2312:0x3A5A         ; # &I-G0-3A5A;
    :eq rep.ks-x1001:0x7D59       ; # &I-K0-7D59;
    :eq rep.cns11643-1:0x6329     ; # &I-C1-6329;
    :eq rep.jis-x0213-1:0x7E72    ; # &I-JX1-7E72;
    :eq rep.daikanwa:48038        ; # &I-M-48038;
    :eq rep.shinjigen:9818        ; # 黑
    :eq rep.jef-china3:0x6FD6     ; # &I-JC3-6FD6;
    .
    rep.gb2312:0x3A5A
               :abstract-glyph-of         gb2312:0x3A5A  .
    rep.ks-x1001:0x7D59
               :abstract-glyph-of       ks-x1001:0x7D59  .
    rep.cns11643-1:0x6329
               :abstract-glyph-of     cns11643-1:0x6329  .
    rep.jis-x0213-1:0x7E72
               :abstract-glyph-of    jis-x0213-1:0x7E72  .
    rep.daikanwa:48038
               :abstract-glyph-of       daikanwa:48038   .
    rep.shinjigen:9818
               :abstract-glyph-of      shinjigen:9818    .
    rep.jef-china3:0x6FD6
               :abstract-glyph-of     jef-china3:0x6FD6  .

a.ucs:0x2A417
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x2A417 ;
    ideo:radical         203 ; # ⿊ 
    ideo:strokes           0 ;
    ideo:total-strokes    14 ;
    :subsume
        rep.ucs_iso:0x2A417  ,
        rep.cns11643-6:0x6476 ;
    .
    rep.ucs_iso:0x2A417
        a chisegg:abstract-glyph ;
        :abstract-glyph-of [ :context domain:iso     ;
                             :target     ucs:0x2A417 ] ;
        :eq rep.daikanwa:48039        ; # &M-48039;
        .
        rep.daikanwa:48039
                   :abstract-glyph-of       daikanwa:48039   .
    rep.cns11643-6:0x6476
        a chisegg:abstract-glyph ;
        :abstract-glyph-of cns11643-6:0x6476 ;
        .

