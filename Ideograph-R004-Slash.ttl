a.ucs:0x4E3F
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x4E3F ;
    ideo:radical           4 ; # ⼃ 
    ideo:strokes           0 ;
    ideo:total-strokes     1 ;
    ideo:hanyu-dazidian  ( 1 31 2 ) ;
    :sound               [ :context domain:ja...on...kan ;
                           :target  ( "hetu" ) ;
                         ] ;
    :eq rep.adobe-japan1-0:04097  ; # &I-AJ1-04097;
    :eq rep.jis-x0208:0x5028      ; # &I-J90-5028;
    :eq rep.gb2312:0x582F         ; # &I-G0-582F;
