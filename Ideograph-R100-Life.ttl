a.ucs:0x9FB6
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x9FB6 ;
    ideo:radical         100 ; # ⽣ 
    ideo:radical           [ :context domain:unicode ;
                             :target           32 ; # ⼟
                           ] ;
    ideo:strokes           [ :context domain:unicode ;
                             :target  1 ] ;
    ideo:strokes           0 ;
    ideo:total-strokes     4 ;
    :eq rep.big5-cdp:0x8B77       ; # &I-CDP-8B77;
    :eq rep.gt-k:00586            ; # &I-GT-K00586;
    :eq rep.gt-pj-k1:12863        ; # 龶
    :eq rep.jef-china3:0x72FD     ; # &I-JC3-72FD;
    :form-of             [ :context domain:component...connect-below ;
