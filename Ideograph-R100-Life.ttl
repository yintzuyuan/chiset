a.ucs:0x751F
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x751F ;
    ideo:radical         100 ; # ⽣ 
    ideo:strokes           0 ;
    ideo:total-strokes     5 ;
    :eq rep.adobe-japan1-0:02652  ; # &I-AJ1-02652;
    :eq rep.jis-x0208:0x4038      ; # &I-J90-4038;
    :eq rep.gb2312:0x497A         ; # &I-G0-497A;
    :eq rep.ks-x1001:0x5F66       ; # &I-K0-5F66;
    :eq rep.cns11643-1:0x466D     ; # &I-C1-466D;
    :eq rep.jis-x0213-1:0x4038    ; # &I-JX1-4038;
    :eq a.big5:0xA5CD             ; # &I-B-A5CD;
    :eq rep.gt:27833              ; # &I-GT-27833;
    :eq rep.gt-k:00964            ; # &I-GT-K00964;
    :eq rep.gt-pj-1:16440         ; # &I-GT-27833;
    :eq rep.daikanwa:21670        ; # &I-M-21670;
    :eq rep.shinjigen:5008        ; # 生
    :subsume
        g2.ucs_unicode:0x751F ;
    .
    rep.adobe-japan1-0:02652
               :abstract-glyph-of adobe-japan1-0:02652   .
    rep.jis-x0208:0x4038
               :abstract-glyph-of      jis-x0208:0x4038  .
    rep.gb2312:0x497A
               :abstract-glyph-of         gb2312:0x497A  .
    rep.ks-x1001:0x5F66
               :abstract-glyph-of       ks-x1001:0x5F66  .
    rep.cns11643-1:0x466D
               :abstract-glyph-of     cns11643-1:0x466D  .
    rep.jis-x0213-1:0x4038
               :abstract-glyph-of    jis-x0213-1:0x4038  .
    a.big5:0xA5CD
           :abstract-character-of           big5:0xA5CD  .
    rep.gt:27833
               :abstract-glyph-of             gt:27833   .
    rep.gt-k:00964
               :abstract-glyph-of           gt-k:00964   .
    rep.gt-pj-1:16440
               :abstract-glyph-of        gt-pj-1:16440   .
    rep.daikanwa:21670
               :abstract-glyph-of       daikanwa:21670   .
    rep.shinjigen:5008
               :abstract-glyph-of      shinjigen:5008    .
    g2.ucs_unicode:0x751F
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of [ :context domain:unicode ;
                                  :target     ucs:0x751F  ] ;
        :eq g2.adobe-japan1-0:02652   ; # &g2-AJ1-02652;
        :eq g2.gb2312:0x497A          ; # &g2-AJ1-02652;
        :eq g2.ks-x1001:0x5F66        ; # &g2-AJ1-02652;
        :eq g2.jis-x0208:0x4038       ; # &g2-AJ1-02652;
        :eq g2.cns11643-1:0x466D      ; # &g2-AJ1-02652;
        :eq g2.jis-x0213-1:0x4038     ; # &g2-AJ1-02652;
        :eq g2.gt:27833               ; # &g2-AJ1-02652;
        :eq g2.gt-k:00964             ; # &g2-AJ1-02652;
        :eq g2.daikanwa:21670         ; # &g2-AJ1-02652;
        :eq g2.shinjigen:5008         ; # &g2-AJ1-02652;
        :subsume
            repi.daikanwa:21670  ,
            repi.jis-x0208:0x4038 ,
            repi.adobe-japan1-6:02652 ,
            repi.cns11643-1:0x466D ,
            repi.gt:27833        ,
            repi.ks-x1001:0x5F66 ,
            repi.ucs_unicode:0x751F ,
            repi.hng-khi:04890   ,
            repi.hng-khm:04370   ,
            repi.hng-kar:10790   ;
        .
        g2.adobe-japan1-0:02652
              :abstract-glyph-form-of adobe-japan1-0:02652   .
        g2.gb2312:0x497A
              :abstract-glyph-form-of         gb2312:0x497A  .
        g2.ks-x1001:0x5F66
              :abstract-glyph-form-of       ks-x1001:0x5F66  .
        g2.jis-x0208:0x4038
              :abstract-glyph-form-of      jis-x0208:0x4038  .
        g2.cns11643-1:0x466D
              :abstract-glyph-form-of     cns11643-1:0x466D  .
        g2.jis-x0213-1:0x4038
              :abstract-glyph-form-of    jis-x0213-1:0x4038  .
        g2.gt:27833
              :abstract-glyph-form-of             gt:27833   .
        g2.gt-k:00964
              :abstract-glyph-form-of           gt-k:00964   .
        g2.daikanwa:21670
              :abstract-glyph-form-of       daikanwa:21670   .
        g2.shinjigen:5008
              :abstract-glyph-form-of      shinjigen:5008    .
        repi.daikanwa:21670
            a chisegg:glyph-image ;
            :glyph-image-of daikanwa:21670 ;
            .
        repi.jis-x0208:0x4038
            a chisegg:glyph-image ;
            :glyph-image-of jis-x0208:0x4038 ;
            :eq repi.jis-x0213-1:0x4038   ; # &R-J0-4038;
            .
            repi.jis-x0213-1:0x4038
                          :glyph-image-of    jis-x0213-1:0x4038  .
        repi.adobe-japan1-0:02652
            a chisegg:glyph-image ;
            :glyph-image-of adobe-japan1-0:02652 ;
            .
        repi.cns11643-1:0x466D
            a chisegg:glyph-image ;
            :glyph-image-of cns11643-1:0x466D ;
            .
        repi.gt:27833
            a chisegg:glyph-image ;
            :glyph-image-of gt:27833 ;
            :eq repi.gt-k:00964           ; # &R-GT-27833;
            .
            repi.gt-k:00964
                          :glyph-image-of           gt-k:00964   .
        repi.ks-x1001:0x5F66
            a chisegg:glyph-image ;
            :glyph-image-of ks-x1001:0x5F66 ;
            :eq repi.ucs_ks:0x751F        ; # &R-K0-5F66;
            .
            repi.ucs_ks:0x751F
                          :glyph-image-of [ :context domain:ks      ;
                                            :target     ucs:0x751F  ] .
        repi.ucs_unicode:0x751F
            a chisegg:glyph-image ;
            :glyph-image-of [ :context domain:unicode ;
                              :target     ucs:0x751F  ] ;
            .
        repi.hng-khi:04890
            a chisegg:glyph-image ;
            :glyph-image-of hng-khi:04890 ;
