a.ucs:0x2092C
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x2092C ;
    ideo:radical           [ :context domain:ucs     ;
                             :target           22 ; # ⼕
                           ] ;
    ideo:radical           [ :context domain:cns     ;
                             :target           23 ; # ⼖
                           ] ;
    ideo:strokes           0 ;
    ideo:total-strokes     2 ;
    ideo:hanyu-dazidian  ( 1 50 2 ) ;
    :subsume
        rep.ucs_iso:0x2092C  ,
        rep.cns11643-6:0x212B ;
    .
    rep.ucs_iso:0x2092C
        a chisegg:abstract-glyph ;
        :abstract-glyph-of [ :context domain:iso     ;
                             :target     ucs:0x2092C ] ;
        :eq rep.big5-cdp:0x87D4       ; # &CDP-87D4;
        :eq rep.daikanwa:02596        ; # &I-M-02596;
        .
        rep.big5-cdp:0x87D4
                   :abstract-glyph-of       big5-cdp:0x87D4  .
        rep.daikanwa:02596
                   :abstract-glyph-of       daikanwa:02596   .
    rep.cns11643-6:0x212B
        a chisegg:abstract-glyph ;
        :abstract-glyph-of cns11643-6:0x212B ;
        .

a.ucs:0x5338
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x5338 ;
    :from.denotational_component
        a.ucs_component:0x531A ;
    ideo:radical          23 ; # ⼖ 
    ideo:strokes           0 ;
    ideo:total-strokes     2 ;
    :eq o.jis-x0208:0x523E        ; # 匸
    :eq o.jis-x0213-1:0x523E      ; # 匸
    :eq o.adobe-japan1-0:04307    ; # 匸
    :eq o.gt:03427                ; # 匸
    :subsume
        rep.adobe-japan1-0:04307 ,
        rep.ucs-var-002:0x5338 ;
    .
    o.jis-x0208:0x523E
                :unified-glyph-of      jis-x0208:0x523E  .
    o.jis-x0213-1:0x523E
                :unified-glyph-of    jis-x0213-1:0x523E  .
    o.adobe-japan1-0:04307
                :unified-glyph-of adobe-japan1-0:04307   .
    o.gt:03427
                :unified-glyph-of             gt:03427   .
    rep.adobe-japan1-0:04307
        a chisegg:abstract-glyph ;
        :abstract-glyph-of adobe-japan1-0:04307 ;
        ideo:hanyu-dazidian  ( 1 81 4 ) ;
        :eq rep.ucs_unicode:0x5338    ; # &AJ1-04307;
        :eq rep.jis-x0208:0x523E      ; # &I-J90-523E;
        :eq rep.cns11643-3:0x2129     ; # &I-C3-2129;
        :eq rep.jis-x0213-1:0x523E    ; # &I-JX1-523E;
        :eq rep.big5-cdp:0x8A70       ; # &I-CDP-8A70;
        :eq rep.gt:03427              ; # &I-GT-03427;
        :eq rep.gt-k:00096            ; # &I-GT-K00096;
        :eq rep.gt-pj-1:21054         ; # &I-GT-03427;
        :eq rep.daikanwa:02672        ; # &I-M-02672;
        :eq rep.shinjigen:0800        ; # &AJ1-04307;
        :subsume
            g2.adobe-japan1-0:04307 ,
            g2.ucs_unicode:0x5338 ;
        .
        rep.ucs_unicode:0x5338
                   :abstract-glyph-of [ :context domain:unicode ;
                                        :target     ucs:0x5338  ] .
        rep.jis-x0208:0x523E
                   :abstract-glyph-of      jis-x0208:0x523E  .
        rep.cns11643-3:0x2129
                   :abstract-glyph-of     cns11643-3:0x2129  .
        rep.jis-x0213-1:0x523E
                   :abstract-glyph-of    jis-x0213-1:0x523E  .
        rep.big5-cdp:0x8A70
                   :abstract-glyph-of       big5-cdp:0x8A70  .
        rep.gt:03427
