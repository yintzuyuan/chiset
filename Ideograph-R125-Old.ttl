a.ucs:0x8001
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x8001 ;
    ideo:radical         125 ; # ⽼ 
    ideo:strokes           0 ;
    .

rep.adobe-japan1-0:04061
    a chisegg:abstract-glyph ;
    :abstract-glyph-of adobe-japan1-0:04061 ;
    :denotation-of
        a.ucs:0x8001         ;
    ideo:radical         125 ; # ⽼ 
    ideo:strokes           0 ;
    ideo:total-strokes     6 ;
    isd:structure [ a idc:⿱ ;
        isd:above    a.ucs:0x8002 ; # 耂
        isd:below    a.ucs:0x5315   # 匕
    ] ;
    :eq a.ucs_iwds-1:0x8001       ; # &AJ1-04061;
    :eq rep.ucs_unicode:0x8001    ; # &AJ1-04061;
    :eq rep.jis-x0208:0x4F37      ; # &I-J90-4F37;
    :eq rep.gb2312:0x404F         ; # &I-G0-404F;
    :eq rep.ks-x1001:0x5655       ; # &I-K0-5655;
    :eq rep.cns11643-1:0x4852     ; # &I-C1-4852;
    :eq rep.jis-x0213-1:0x4F37    ; # &I-JX1-4F37;
    :eq a.big5:0xA6D1             ; # &I-B-A6D1;
    :eq rep.gt:37307              ; # &I-GT-37307;
    :eq rep.gt-k:01708            ; # &I-GT-K01708;
    :eq rep.gt-pj-1:20279         ; # &I-GT-37307;
    :eq rep.daikanwa:28842        ; # &I-M-28842;
    :eq rep.shinjigen:6340        ; # &AJ1-04061;
    :subsume
        g2.ucs_unicode:0x8001 ,
        repi.hng-kar:11820   ,
        g2.cns11643-1:0x4852 ;
    .
    a.ucs_iwds-1:0x8001
           :abstract-character-of [ :context domain:iwds-1  ;
                                    :target     ucs:0x8001  ] .
    rep.ucs_unicode:0x8001
               :abstract-glyph-of [ :context domain:unicode ;
                                    :target     ucs:0x8001  ] .
    rep.jis-x0208:0x4F37
               :abstract-glyph-of      jis-x0208:0x4F37  .
    rep.gb2312:0x404F
               :abstract-glyph-of         gb2312:0x404F  .
    rep.ks-x1001:0x5655
               :abstract-glyph-of       ks-x1001:0x5655  .
    rep.cns11643-1:0x4852
               :abstract-glyph-of     cns11643-1:0x4852  .
    rep.jis-x0213-1:0x4F37
               :abstract-glyph-of    jis-x0213-1:0x4F37  .
    a.big5:0xA6D1
           :abstract-character-of           big5:0xA6D1  .
    rep.gt:37307
               :abstract-glyph-of             gt:37307   .
    rep.gt-k:01708
               :abstract-glyph-of           gt-k:01708   .
    rep.gt-pj-1:20279
               :abstract-glyph-of        gt-pj-1:20279   .
    rep.daikanwa:28842
               :abstract-glyph-of       daikanwa:28842   .
    rep.shinjigen:6340
               :abstract-glyph-of      shinjigen:6340    .
    g2.ucs_unicode:0x8001
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of [ :context domain:unicode ;
                                  :target     ucs:0x8001  ] ;
        :eq g2.adobe-japan1-0:04061   ; # &g2-AJ1-04061;
        :eq g2.gb2312:0x404F          ; # &g2-AJ1-04061;
        :eq g2.ks-x1001:0x5655        ; # &g2-AJ1-04061;
        :eq g2.jis-x0208:0x4F37       ; # &g2-AJ1-04061;
        :eq g2.jis-x0213-1:0x4F37     ; # &g2-AJ1-04061;
        :eq g2.gt:37307               ; # &g2-AJ1-04061;
        :eq g2.gt-k:01708             ; # &g2-AJ1-04061;
        :eq g2.daikanwa:28842         ; # &g2-AJ1-04061;
        :eq g2.shinjigen:6340         ; # &g2-AJ1-04061;
        :subsume
            repi.daikanwa:28842  ,
            repi.jis-x0208:0x4F37 ,
            repi.adobe-japan1-6:04061 ,
            repi.gt:37307        ,
            repi.ks-x1001:0x5655 ,
            repi.ucs_unicode:0x8001 ;
        .
        g2.adobe-japan1-0:04061
              :abstract-glyph-form-of adobe-japan1-0:04061   .
        g2.gb2312:0x404F
              :abstract-glyph-form-of         gb2312:0x404F  .
        g2.ks-x1001:0x5655
              :abstract-glyph-form-of       ks-x1001:0x5655  .
        g2.jis-x0208:0x4F37
              :abstract-glyph-form-of      jis-x0208:0x4F37  .
        g2.jis-x0213-1:0x4F37
              :abstract-glyph-form-of    jis-x0213-1:0x4F37  .
        g2.gt:37307
              :abstract-glyph-form-of             gt:37307   .
        g2.gt-k:01708
              :abstract-glyph-form-of           gt-k:01708   .
        g2.daikanwa:28842
              :abstract-glyph-form-of       daikanwa:28842   .
        g2.shinjigen:6340
              :abstract-glyph-form-of      shinjigen:6340    .
        repi.daikanwa:28842
            a chisegg:glyph-image ;
            :glyph-image-of daikanwa:28842 ;
            .
        repi.jis-x0208:0x4F37
            a chisegg:glyph-image ;
            :glyph-image-of jis-x0208:0x4F37 ;
            :eq repi.jis-x0213-1:0x4F37   ; # &R-J0-4F37;
            .
            repi.jis-x0213-1:0x4F37
                          :glyph-image-of    jis-x0213-1:0x4F37  .
        repi.adobe-japan1-0:04061
            a chisegg:glyph-image ;
            :glyph-image-of adobe-japan1-0:04061 ;
            .
        repi.gt:37307
            a chisegg:glyph-image ;
            :glyph-image-of gt:37307 ;
            :eq repi.gt-k:01708           ; # &R-GT-37307;
            .
            repi.gt-k:01708
                          :glyph-image-of           gt-k:01708   .
        repi.ks-x1001:0x5655
            a chisegg:glyph-image ;
            :glyph-image-of ks-x1001:0x5655 ;
            :eq repi.ucs_ks:0x8001        ; # &R-K0-5655;
            .
            repi.ucs_ks:0x8001
                          :glyph-image-of [ :context domain:ks      ;
                                            :target     ucs:0x8001  ] .
        repi.ucs_unicode:0x8001
            a chisegg:glyph-image ;
            :glyph-image-of [ :context domain:unicode ;
                              :target     ucs:0x8001  ] ;
            .
    repi.hng-kar:11820
        a chisegg:glyph-image ;
        :glyph-image-of hng-kar:11820 ;
        .
