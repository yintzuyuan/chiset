    :abstract-character-of ucs:0x23C4E ;
    ideo:radical          83 ; # ⽒ 
    ideo:strokes           7 ;
    ideo:total-strokes    11 ;
    :eq rep.cns11643-6:0x4128     ; # &I-C6-4128;
    :eq rep.daikanwa:17037        ; # &I-M-17037;
    .
    rep.cns11643-6:0x4128
               :abstract-glyph-of     cns11643-6:0x4128  .
    rep.daikanwa:17037
               :abstract-glyph-of       daikanwa:17037   .

