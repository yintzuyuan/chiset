a.ucs:0x9AA8
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x9AA8 ;
    ideo:radical         188 ; # ⾻ 
    ideo:strokes           0 ;
    .

a.ucs_iwds-1:0x9AA8
    a chisegg:abstract-character ;
    :abstract-character-of [ :context domain:iwds-1  ;
                             :target     ucs:0x9AA8  ] ;
    :denotation-of
        a.ucs:0x9AA8         ;
    ideo:radical         188 ; # ⾻ 
    ideo:strokes           0 ;
    :eq a.ucs_unicode:0x9AA8      ; # &A-IWDSU+9AA8;
    .
    a.ucs_unicode:0x9AA8
           :abstract-character-of [ :context domain:unicode ;
                                    :target     ucs:0x9AA8  ] .

rep.adobe-japan1-0:02062
    a chisegg:abstract-glyph ;
    :abstract-glyph-of adobe-japan1-0:02062 ;
    :denotation-of
        a.ucs_iwds-1:0x9AA8  ;
    ideo:radical         188 ; # ⾻ 
    ideo:strokes           0 ;
    ideo:total-strokes    10 ;
    :eq rep.ucs_jis:0x9AA8        ; # &AJ1-02062;
    :eq rep.jis-x0208:0x397C      ; # &I-J90-397C;
    :eq rep.ks-x1001:0x4D69       ; # &I-K0-4D69;
    :eq rep.cns11643-1:0x586C     ; # &I-C1-586C;
    :eq rep.jis-x0213-1:0x397C    ; # &I-JX1-397C;
    :eq a.big5:0xB0A9             ; # &I-B-B0A9;
    :eq rep.gt:60709              ; # &I-GT-60709;
    :eq rep.gt-k:06431            ; # &I-GT-K06431;
    :eq rep.gt-pj-1:14716         ; # &I-GT-60709;
    :eq rep.daikanwa:45098        ; # &I-M-45098;
    :eq rep.shinjigen:9431        ; # &AJ1-02062;
    :subsume
        g2.adobe-japan1-0:02062 ,
        g2.cns11643-1:0x586C ;
    .
    rep.ucs_jis:0x9AA8
               :abstract-glyph-of [ :context domain:jis     ;
                                    :target     ucs:0x9AA8  ] .
    rep.jis-x0208:0x397C
               :abstract-glyph-of      jis-x0208:0x397C  .
    rep.ks-x1001:0x4D69
               :abstract-glyph-of       ks-x1001:0x4D69  .
    rep.cns11643-1:0x586C
               :abstract-glyph-of     cns11643-1:0x586C  .
    rep.jis-x0213-1:0x397C
               :abstract-glyph-of    jis-x0213-1:0x397C  .
    a.big5:0xB0A9
           :abstract-character-of           big5:0xB0A9  .
    rep.gt:60709
               :abstract-glyph-of             gt:60709   .
    rep.gt-k:06431
               :abstract-glyph-of           gt-k:06431   .
    rep.gt-pj-1:14716
               :abstract-glyph-of        gt-pj-1:14716   .
    rep.daikanwa:45098
               :abstract-glyph-of       daikanwa:45098   .
    rep.shinjigen:9431
               :abstract-glyph-of      shinjigen:9431    .
    g2.adobe-japan1-0:02062
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of adobe-japan1-0:02062 ;
        :eq g2.ucs_jis:0x9AA8         ; # &g2-AJ1-02062;
        :eq g2.ucs_ks:0x9AA8          ; # &g2-AJ1-02062;
        :eq g2.ks-x1001:0x4D69        ; # &g2-AJ1-02062;
        :eq g2.jis-x0208:0x397C       ; # &g2-AJ1-02062;
        :eq g2.jis-x0213-1:0x397C     ; # &g2-AJ1-02062;
        :eq g2.gt:60709               ; # &g2-AJ1-02062;
        :eq g2.gt-k:06431             ; # &g2-AJ1-02062;
        :eq g2.daikanwa:45098         ; # &g2-AJ1-02062;
        :eq g2.shinjigen:9431         ; # &g2-AJ1-02062;
        :subsume
            repi.daikanwa:45098  ,
            repi.jis-x0208:0x397C ,
            repi.adobe-japan1-6:02062 ,
            repi.gt:60709        ,
            repi.ks-x1001:0x4D69 ;
        .
        g2.ucs_jis:0x9AA8
              :abstract-glyph-form-of [ :context domain:jis     ;
                                        :target     ucs:0x9AA8  ] .
        g2.ucs_ks:0x9AA8
              :abstract-glyph-form-of [ :context domain:ks      ;
                                        :target     ucs:0x9AA8  ] .
        g2.ks-x1001:0x4D69
              :abstract-glyph-form-of       ks-x1001:0x4D69  .
        g2.jis-x0208:0x397C
              :abstract-glyph-form-of      jis-x0208:0x397C  .
        g2.jis-x0213-1:0x397C
              :abstract-glyph-form-of    jis-x0213-1:0x397C  .
        g2.gt:60709
              :abstract-glyph-form-of             gt:60709   .
        g2.gt-k:06431
              :abstract-glyph-form-of           gt-k:06431   .
        g2.daikanwa:45098
              :abstract-glyph-form-of       daikanwa:45098   .
        g2.shinjigen:9431
              :abstract-glyph-form-of      shinjigen:9431    .
        repi.daikanwa:45098
            a chisegg:glyph-image ;
            :glyph-image-of daikanwa:45098 ;
            .
        repi.jis-x0208:0x397C
            a chisegg:glyph-image ;
            :glyph-image-of jis-x0208:0x397C ;
            :eq repi.jis-x0213-1:0x397C   ; # &R-J0-397C;
            .
            repi.jis-x0213-1:0x397C
                          :glyph-image-of    jis-x0213-1:0x397C  .
        repi.adobe-japan1-0:02062
            a chisegg:glyph-image ;
            :glyph-image-of adobe-japan1-0:02062 ;
            .
        repi.gt:60709
            a chisegg:glyph-image ;
            :glyph-image-of gt:60709 ;
            :eq repi.gt-k:06431           ; # &R-GT-60709;
            .
            repi.gt-k:06431
                          :glyph-image-of           gt-k:06431   .
        repi.ks-x1001:0x4D69
            a chisegg:glyph-image ;
            :glyph-image-of ks-x1001:0x4D69 ;
            :eq repi.ucs_ks:0x9AA8        ; # &R-K0-4D69;
            .
            repi.ucs_ks:0x9AA8
                          :glyph-image-of [ :context domain:ks      ;
                                            :target     ucs:0x9AA8  ] .
