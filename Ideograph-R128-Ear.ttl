a.ucs:0x8033
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x8033 ;
    ideo:radical         128 ; # ⽿ 
    ideo:strokes           0 ;
    ideo:total-strokes     6 ;
    :eq rep.adobe-japan1-0:02262  ; # &I-AJ1-02262;
    :eq rep.jis-x0208:0x3C2A      ; # &I-J90-3C2A;
    :eq rep.gb2312:0x367A         ; # &I-G0-367A;
    :eq rep.ks-x1001:0x6C3C       ; # &I-K0-6C3C;
    :eq rep.cns11643-1:0x4856     ; # &I-C1-4856;
    :eq rep.jis-x0213-1:0x3C2A    ; # &I-JX1-3C2A;
    :eq a.big5:0xA6D5             ; # &I-B-A6D5;
    :eq rep.gt:37565              ; # &I-GT-37565;
    :eq rep.gt-k:01629            ; # &I-GT-K01629;
    :eq rep.gt-pj-1:15402         ; # &I-GT-37565;
    :eq rep.daikanwa:28999        ; # &I-M-28999;
    :eq rep.shinjigen:6374        ; # 耳
    :subsume
        g2.daikanwa:28999    ,
        g2.adobe-japan1-0:02262 ,
        g2.ucs_unicode:0x8033 ,
        g2.cns11643-1:0x4856 ;
    .
