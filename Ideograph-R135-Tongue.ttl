            repi.jis-x0208:0x4065
                a chisegg:glyph-image ;
                :glyph-image-of jis-x0208:0x4065 ;
                :eq repi.jis-x0213-1:0x4065   ; # &R-J0-4065;
                .
                repi.jis-x0213-1:0x4065
                              :glyph-image-of    jis-x0213-1:0x4065  .
            repi.adobe-japan1-0:02697
                a chisegg:glyph-image ;
                :glyph-image-of adobe-japan1-0:02697 ;
                .
            repi.gt:39171
                a chisegg:glyph-image ;
                :glyph-image-of gt:39171 ;
                :eq repi.gt-k:01652           ; # &R-GT-39171;
                .
                repi.gt-k:01652
                              :glyph-image-of           gt-k:01652   .
            repi.ks-x1001:0x605F
                a chisegg:glyph-image ;
                :glyph-image-of ks-x1001:0x605F ;
                :eq repi.ucs_ks:0x820C        ; # &R-K0-605F;
                .
