                                            :target     ucs:0x820C  ] .
            g2.shinjigen:6629
                  :abstract-glyph-form-of      shinjigen:6629    .

rep.ucs-itaiji-002:0x820C
    a chisegg:abstract-glyph ;
    :abstract-glyph-of ucs-itaiji-002:0x820C ;
    :denotation-of
        bucs:0x820C          ;
    ideo:radical         135 ; # ⾆ 
    ideo:strokes           0 ;
    ideo:total-strokes     5 ;
    isd:structure [ a idc:⿱ ;
        isd:above    a.ucs:0x5343 ; # 千
        isd:below    a.ucs:0x5182   # 冂
    ] ;
    :form-of             [ :context domain:component...avoiding-taboo ;
                           :target  a.ucs:0x820C         ] ;
    .

