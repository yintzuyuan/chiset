bucs:0x820C
    a chisegg:super-abstract-character ;
    :super-abstract-character-of [ :context domain:bucs    ;
                                   :target     ucs:0x820C  ] ;
    ideo:radical         135 ; # ⾆ 
    ideo:strokes           0 ;
    .

a.ucs:0x820C
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x820C ;
    :denotation-of
        bucs:0x820C          ;
    ideo:radical         135 ; # ⾆ 
    ideo:strokes           0 ;
    ideo:total-strokes     6 ;
    :eq a.big5:0xA6DE             ; # &I-B-A6DE;
    :subsume
        rep.adobe-japan1-0:02697 ,
        rep.cns11643-1:0x485F ;
    .
    a.big5:0xA6DE
           :abstract-character-of           big5:0xA6DE  .
    rep.adobe-japan1-0:02697
        a chisegg:abstract-glyph ;
        :abstract-glyph-of adobe-japan1-0:02697 ;
        :eq rep.ucs_unicode:0x820C    ; # &AJ1-02697;
        :eq rep.jis-x0208:0x4065      ; # &I-J90-4065;
        :eq rep.gb2312:0x4960         ; # &I-G0-4960;
        :eq rep.ks-x1001:0x605F       ; # &I-K0-605F;
        :eq rep.jis-x0213-1:0x4065    ; # &I-JX1-4065;
        :eq rep.hanyo-denshi...ja:0x4065 ; # &I-HD-JA-4065;
        :eq rep.gt:39171              ; # &I-GT-39171;
        :eq rep.gt-k:01652            ; # &I-GT-K01652;
        :eq rep.gt-pj-1:16485         ; # &I-GT-39171;
        :eq rep.daikanwa:30277        ; # &I-M-30277;
        :eq rep.shinjigen:6628        ; # &AJ1-02697;
        :subsume
            g2.ucs_unicode:0x820C ,
            repi.hng-kar:03260   ;
        .
        rep.ucs_unicode:0x820C
                   :abstract-glyph-of [ :context domain:unicode ;
                                        :target     ucs:0x820C  ] .
        rep.jis-x0208:0x4065
                   :abstract-glyph-of      jis-x0208:0x4065  .
        rep.gb2312:0x4960
                   :abstract-glyph-of         gb2312:0x4960  .
        rep.ks-x1001:0x605F
                   :abstract-glyph-of       ks-x1001:0x605F  .
        rep.jis-x0213-1:0x4065
                   :abstract-glyph-of    jis-x0213-1:0x4065  .
        rep.hanyo-denshi...ja:0x4065
                   :abstract-glyph-of hanyo-denshi...ja:0x4065  .
        rep.gt:39171
                   :abstract-glyph-of             gt:39171   .
        rep.gt-k:01652
                   :abstract-glyph-of           gt-k:01652   .
        rep.gt-pj-1:16485
                   :abstract-glyph-of        gt-pj-1:16485   .
        rep.daikanwa:30277
                   :abstract-glyph-of       daikanwa:30277   .
        rep.shinjigen:6628
                   :abstract-glyph-of      shinjigen:6628    .
        g2.ucs_unicode:0x820C
            a chisegg:abstract-glyph-form ;
            :abstract-glyph-form-of [ :context domain:unicode ;
                                      :target     ucs:0x820C  ] ;
            :rep.decomposition   [ :context domain:hanyo-denshi ;
                                   :target  a.ucs:0x820C         ,
                                            a.ucs:0xE0102        ] ;
            :eq g2.adobe-japan1-0:02697   ; # &g2-AJ1-02697;
            :eq g2.gb2312:0x4960          ; # &g2-AJ1-02697;
            :eq g2.ks-x1001:0x605F        ; # &g2-AJ1-02697;
            :eq g2.jis-x0208:0x4065       ; # &g2-AJ1-02697;
            :eq g2.jis-x0213-1:0x4065     ; # &g2-AJ1-02697;
            :eq g2.hanyo-denshi...ja:0x4065 ; # &g2-AJ1-02697;
            :eq g2.gt:39171               ; # &g2-AJ1-02697;
            :eq g2.gt-k:01652             ; # &g2-AJ1-02697;
            :eq g2.daikanwa:30277         ; # &g2-AJ1-02697;
            :eq g2.shinjigen:6628         ; # &g2-AJ1-02697;
            :subsume
                repi.daikanwa:30277  ,
                repi.jis-x0208:0x4065 ,
                repi.adobe-japan1-6:02697 ,
                repi.gt:39171        ,
                repi.ks-x1001:0x605F ,
                repi.ucs_unicode:0x820C ;
            .
            g2.adobe-japan1-0:02697
                  :abstract-glyph-form-of adobe-japan1-0:02697   .
            g2.gb2312:0x4960
