        a.ucs:0x9F8D         ;
    ideo:radical         212 ; # ⿓ 
    ideo:strokes           0 ;
    ideo:total-strokes    16 ;
    :eq a.ucs_unicode:0x9F8D      ; # &A-IWDSU+9F8D;
    .
