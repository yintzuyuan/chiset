a.ucs:0x53B6
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x53B6 ;
    ideo:radical          28 ; # ⼛ 
    ideo:strokes           0 ;
    ideo:total-strokes     2 ;
    ideo:hanyu-dazidian  ( 1 383 9 ) ;
    :eq rep.adobe-japan1-0:04328  ; # &I-AJ1-04328;
    :eq rep.jis-x0208:0x5253      ; # &I-J90-5253;
    :eq rep.gb2312:0x5B4C         ; # &I-G0-5B4C;
    :eq rep.cns11643-3:0x212B     ; # &I-C3-212B;
    :eq rep.jis-x0213-1:0x5253    ; # &I-JX1-5253;
    :eq rep.big5-cdp:0x8AFD       ; # &I-CDP-8AFD;
    :eq rep.gt:03875              ; # &I-GT-03875;
    :eq rep.gt-pj-1:21075         ; # &I-GT-03875;
    :eq rep.daikanwa:03057        ; # &I-M-03057;
    :eq rep.shinjigen:0889        ; # 厶
    :subsume
        g2.ucs_unicode:0x53B6 ;
    .
    rep.adobe-japan1-0:04328
               :abstract-glyph-of adobe-japan1-0:04328   .
    rep.jis-x0208:0x5253
               :abstract-glyph-of      jis-x0208:0x5253  .
    rep.gb2312:0x5B4C
               :abstract-glyph-of         gb2312:0x5B4C  .
    rep.cns11643-3:0x212B
               :abstract-glyph-of     cns11643-3:0x212B  .
    rep.jis-x0213-1:0x5253
               :abstract-glyph-of    jis-x0213-1:0x5253  .
    rep.big5-cdp:0x8AFD
               :abstract-glyph-of       big5-cdp:0x8AFD  .
    rep.gt:03875
               :abstract-glyph-of             gt:03875   .
    rep.gt-pj-1:21075
               :abstract-glyph-of        gt-pj-1:21075   .
    rep.daikanwa:03057
               :abstract-glyph-of       daikanwa:03057   .
    rep.shinjigen:0889
               :abstract-glyph-of      shinjigen:0889    .
    g2.ucs_unicode:0x53B6
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of [ :context domain:unicode ;
                                  :target     ucs:0x53B6  ] ;
        :eq g2.adobe-japan1-0:04328   ; # &g2-AJ1-04328;
        :eq g2.gb2312:0x5B4C          ; # &g2-AJ1-04328;
        :eq g2.jis-x0208:0x5253       ; # &g2-AJ1-04328;
        :eq g2.cns11643-3:0x212B      ; # &g2-AJ1-04328;
        :eq g2.jis-x0213-1:0x5253     ; # &g2-AJ1-04328;
        :eq g2.big5-cdp:0x8AFD        ; # &g2-AJ1-04328;
        :eq g2.gt:03875               ; # &g2-AJ1-04328;
        :eq g2.daikanwa:03057         ; # &g2-AJ1-04328;
        :eq g2.shinjigen:0889         ; # &g2-AJ1-04328;
        :subsume
            repi.daikanwa:03057  ,
            repi.jis-x0208:0x5253 ,
            repi.adobe-japan1-6:04328 ,
            repi.big5-cdp:0x8AFD ,
            repi.cns11643-3:0x212B ,
            repi.gt:03875        ,
            repi.ucs_unicode:0x53B6 ;
        .
        g2.adobe-japan1-0:04328
              :abstract-glyph-form-of adobe-japan1-0:04328   .
        g2.gb2312:0x5B4C
              :abstract-glyph-form-of         gb2312:0x5B4C  .
