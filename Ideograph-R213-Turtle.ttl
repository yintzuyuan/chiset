a.ucs:0x4E80
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x4E80 ;
    ideo:radical           [ :context domain:ucs     ;
                             :target            5 ; # ⼄
                           ] ;
    ideo:strokes           [ :context domain:ucs     ;
                             :target  10 ] ;
    ideo:radical           [ :context domain:cns     ;
                             :target          213 ; # ⿔
                           ] ;
    ideo:strokes           [ :context domain:cns     ;
                             :target  0 ] ;
    ideo:total-strokes    11 ;
    ideo:hanyu-dazidian  ( 8 10 19 ) ;
    isd:structure [ a idc:⿱ ;
        isd:above    a.ucs:0x2008A ; # 𠂊
        isd:below    rep.big5-cdp:0x89BD   # &CDP-89BD;
    ] ;
    :sound               [ :context domain:ja...kun ;
                           :target  ( "kame" ) ;
                         ] ;
    :sound               [ :context domain:ja...on ;
                           :target  ( "ki" ) ;
                         ] ;
    :eq rep.adobe-japan1-0:01615  ; # &I-AJ1-01615;
    :eq rep.jis-x0208:0x3535      ; # &I-J90-3535;
    :eq rep.cns11643-3:0x396C     ; # &I-C3-396C;
    :eq rep.jis-x0213-1:0x3535    ; # &I-JX1-3535;
    :eq rep.gt:66701              ; # &I-GT-66701;
    :eq rep.gt-k:07742            ; # &I-GT-K07742;
    :eq rep.gt-pj-1:13621         ; # &I-GT-66701;
    :eq rep.daikanwa:00210        ; # &I-M-00210;
    :eq rep.shinjigen_1ed:9917    ; # 亀
    :eq rep.shinjigen_rev:9916    ; # 亀
    :from.vulgar         [ :sources chisebib:daikanwa ;
                           :target  rep.adobe-japan1-0:07472 ] ;
    :subsume
        g2.ucs_unicode:0x4E80 ;
    .
    rep.adobe-japan1-0:01615
               :abstract-glyph-of adobe-japan1-0:01615   .
    rep.jis-x0208:0x3535
               :abstract-glyph-of      jis-x0208:0x3535  .
    rep.cns11643-3:0x396C
               :abstract-glyph-of     cns11643-3:0x396C  .
    rep.jis-x0213-1:0x3535
               :abstract-glyph-of    jis-x0213-1:0x3535  .
    rep.gt:66701
               :abstract-glyph-of             gt:66701   .
    rep.gt-k:07742
               :abstract-glyph-of           gt-k:07742   .
    rep.gt-pj-1:13621
               :abstract-glyph-of        gt-pj-1:13621   .
    rep.daikanwa:00210
               :abstract-glyph-of       daikanwa:00210   .
    rep.shinjigen_1ed:9917
               :abstract-glyph-of [ :context domain:1ed     ;
                                    :target shinjigen:9917    ] .
    rep.shinjigen_rev:9916
               :abstract-glyph-of [ :context domain:rev     ;
                                    :target shinjigen:9916    ] .
    g2.ucs_unicode:0x4E80
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of [ :context domain:unicode ;
                                  :target     ucs:0x4E80  ] ;
        :eq g2.adobe-japan1-0:01615   ; # &g2-AJ1-01615;
        :eq g2.jis-x0208:0x3535       ; # &g2-AJ1-01615;
        :eq g2.cns11643-3:0x396C      ; # &g2-AJ1-01615;
        :eq g2.jis-x0213-1:0x3535     ; # &g2-AJ1-01615;
        :eq g2.gt:66701               ; # &g2-AJ1-01615;
        :eq g2.gt-k:07742             ; # &g2-AJ1-01615;
        :eq g2.daikanwa:00210         ; # &g2-AJ1-01615;
        :eq g2.shinjigen_1ed:9917     ; # &g2-AJ1-01615;
        :eq g2.shinjigen_rev:9916     ; # &g2-AJ1-01615;
        :subsume
            repi.daikanwa:00210  ,
            repi.jis-x0208:0x3535 ,
            repi.adobe-japan1-6:01615 ,
            repi.cns11643-3:0x396C ,
