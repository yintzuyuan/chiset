a.ucs:0x9F52
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x9F52 ;
    ideo:radical         211 ; # ⿒ 
    ideo:strokes           0 ;
    ideo:total-strokes    15 ;
    :eq rep.adobe-japan1-0:07458  ; # &I-AJ1-07458;
    :eq rep.jis-x0208:0x736F      ; # &I-J90-736F;
    :eq rep.ks-x1001:0x764D       ; # &I-K0-764D;
    :eq rep.cns11643-1:0x702F     ; # &I-C1-702F;
    :eq rep.jis-x0213-1:0x736F    ; # &I-JX1-736F;
    :eq rep.gb12345:0x335D        ; # 齒
    :eq rep.gt:66387              ; # &I-GT-66387;
    :eq rep.gt-pj-1:29551         ; # &I-GT-66387;
    :eq rep.daikanwa:48583        ; # &I-M-48583;
    :eq rep.shinjigen:9883        ; # 齒
    :subsume
        g2.ucs_unicode:0x9F52 ,
        repi.hng-kar:04690   ;
    .
    rep.adobe-japan1-0:07458
               :abstract-glyph-of adobe-japan1-0:07458   .
    rep.jis-x0208:0x736F
               :abstract-glyph-of      jis-x0208:0x736F  .
    rep.ks-x1001:0x764D
               :abstract-glyph-of       ks-x1001:0x764D  .
    rep.cns11643-1:0x702F
               :abstract-glyph-of     cns11643-1:0x702F  .
    rep.jis-x0213-1:0x736F
               :abstract-glyph-of    jis-x0213-1:0x736F  .
    rep.gb12345:0x335D
               :abstract-glyph-of        gb12345:0x335D  .
    rep.gt:66387
               :abstract-glyph-of             gt:66387   .
    rep.gt-pj-1:29551
               :abstract-glyph-of        gt-pj-1:29551   .
    rep.daikanwa:48583
               :abstract-glyph-of       daikanwa:48583   .
    rep.shinjigen:9883
               :abstract-glyph-of      shinjigen:9883    .
    g2.ucs_unicode:0x9F52
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of [ :context domain:unicode ;
                                  :target     ucs:0x9F52  ] ;
        :eq g2.adobe-japan1-0:07458   ; # &g2-AJ1-07458;
        :eq g2.ks-x1001:0x764D        ; # &g2-AJ1-07458;
        :eq g2.jis-x0208:0x736F       ; # &g2-AJ1-07458;
        :eq g2.cns11643-1:0x702F      ; # &g2-AJ1-07458;
        :eq g2.jis-x0213-1:0x736F     ; # &g2-AJ1-07458;
        :eq g2.gb12345:0x335D         ; # &g2-AJ1-07458;
        :eq g2.gt:66387               ; # &g2-AJ1-07458;
        :eq g2.daikanwa:48583         ; # &g2-AJ1-07458;
        :eq g2.shinjigen:9883         ; # &g2-AJ1-07458;
        :subsume
            repi.daikanwa:48583  ,
            repi.jis-x0208:0x736F ,
            repi.adobe-japan1-6:07458 ,
            repi.cns11643-1:0x702F ,
            repi.gt:66387        ,
            repi.ks-x1001:0x764D ,
            repi.ucs_unicode:0x9F52 ;
        .
        g2.adobe-japan1-0:07458
              :abstract-glyph-form-of adobe-japan1-0:07458   .
        g2.ks-x1001:0x764D
              :abstract-glyph-form-of       ks-x1001:0x764D  .
        g2.jis-x0208:0x736F
              :abstract-glyph-form-of      jis-x0208:0x736F  .
        g2.cns11643-1:0x702F
              :abstract-glyph-form-of     cns11643-1:0x702F  .
        g2.jis-x0213-1:0x736F
              :abstract-glyph-form-of    jis-x0213-1:0x736F  .
        g2.gb12345:0x335D
              :abstract-glyph-form-of        gb12345:0x335D  .
        g2.gt:66387
              :abstract-glyph-form-of             gt:66387   .
        g2.daikanwa:48583
              :abstract-glyph-form-of       daikanwa:48583   .
        g2.shinjigen:9883
              :abstract-glyph-form-of      shinjigen:9883    .
        repi.daikanwa:48583
            a chisegg:glyph-image ;
            :glyph-image-of daikanwa:48583 ;
            .
        repi.jis-x0208:0x736F
            a chisegg:glyph-image ;
            :glyph-image-of jis-x0208:0x736F ;
            :eq repi.jis-x0213-1:0x736F   ; # &R-J0-736F;
