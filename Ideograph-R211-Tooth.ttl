            repi.jis-x0213-1:0x736F
                          :glyph-image-of    jis-x0213-1:0x736F  .
        repi.adobe-japan1-0:07458
            a chisegg:glyph-image ;
            :glyph-image-of adobe-japan1-0:07458 ;
            .
        repi.cns11643-1:0x702F
            a chisegg:glyph-image ;
            :glyph-image-of cns11643-1:0x702F ;
            .
        repi.gt:66387
            a chisegg:glyph-image ;
            :glyph-image-of gt:66387 ;
            .
        repi.ks-x1001:0x764D
            a chisegg:glyph-image ;
            :glyph-image-of ks-x1001:0x764D ;
            :eq repi.ucs_ks:0x9F52        ; # &R-K0-764D;
            .
            repi.ucs_ks:0x9F52
                          :glyph-image-of [ :context domain:ks      ;
                                            :target     ucs:0x9F52  ] .
        repi.ucs_unicode:0x9F52
            a chisegg:glyph-image ;
            :glyph-image-of [ :context domain:unicode ;
                              :target     ucs:0x9F52  ] ;
            .
    repi.hng-kar:04690
        a chisegg:glyph-image ;
        :glyph-image-of hng-kar:04690 ;
        .

