    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x96E8 ;
    ideo:radical         173 ; # ⾬ 
    ideo:strokes           0 ;
    ideo:total-strokes     8 ;
    :eq rep.adobe-japan1-0:01229  ; # &I-AJ1-01229;
    :eq rep.jis-x0208:0x312B      ; # &I-J90-312B;
    :eq rep.gb2312:0x536A         ; # &I-G0-536A;
    :eq rep.ks-x1001:0x696B       ; # &I-K0-696B;
    :eq rep.cns11643-1:0x4F64     ; # &I-C1-4F64;
    :eq rep.jis-x0213-1:0x312B    ; # &I-JX1-312B;
    :eq rep.gt:56689              ; # &I-GT-56689;
    :eq rep.gt-k:03629            ; # &I-GT-K03629;
    :eq rep.gt-pj-1:12587         ; # &I-GT-56689;
    :eq rep.daikanwa:42210        ; # &I-M-42210;
    :eq rep.shinjigen:8984        ; # 雨
    :subsume
        g2.ucs_unicode:0x96E8 ,
        repi.hng-khm:05750   ,
        g2.cns11643-1:0x4F64 ,
        repi.hng-khi:06120   ;
    .
