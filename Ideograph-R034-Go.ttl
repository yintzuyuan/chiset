a.ucs:0x5902
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x5902 ;
    :from.denotational_component
        a.ucs_component:0x590A ,
        a.ucs_component:0x6535 ;
    ideo:radical          34 ; # ⼡ 
    ideo:strokes           0 ;
    ideo:total-strokes     3 ;
    ideo:hanyu-dazidian  ( 2 867 15 ) ;
    :eq rep.adobe-japan1-0:04538  ; # &I-AJ1-04538;
    :eq rep.jis-x0208:0x5469      ; # &I-J90-5469;
    :eq rep.gb2312:0x623A         ; # &I-G0-623A;
    :eq rep.cns11643-3:0x2139     ; # &I-C3-2139;
    :eq rep.jis-x0213-1:0x5469    ; # &I-JX1-5469;
    :eq rep.big5-cdp:0x8B45       ; # &I-CDP-8B45;
    :eq rep.gt:07201              ; # &I-GT-07201;
    :eq rep.gt-k:00217            ; # &I-GT-K00217;
    :eq rep.gt-pj-1:21609         ; # &I-GT-07201;
    :eq rep.daikanwa:05691        ; # &I-M-05691;
    :subsume
        g2.ucs_unicode:0x5902 ;
    .
    rep.adobe-japan1-0:04538
               :abstract-glyph-of adobe-japan1-0:04538   .
    rep.jis-x0208:0x5469
               :abstract-glyph-of      jis-x0208:0x5469  .
    rep.gb2312:0x623A
               :abstract-glyph-of         gb2312:0x623A  .
    rep.cns11643-3:0x2139
               :abstract-glyph-of     cns11643-3:0x2139  .
    rep.jis-x0213-1:0x5469
               :abstract-glyph-of    jis-x0213-1:0x5469  .
    rep.big5-cdp:0x8B45
               :abstract-glyph-of       big5-cdp:0x8B45  .
    rep.gt:07201
               :abstract-glyph-of             gt:07201   .
    rep.gt-k:00217
               :abstract-glyph-of           gt-k:00217   .
    rep.gt-pj-1:21609
               :abstract-glyph-of        gt-pj-1:21609   .
    rep.daikanwa:05691
               :abstract-glyph-of       daikanwa:05691   .
    g2.ucs_unicode:0x5902
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of [ :context domain:unicode ;
                                  :target     ucs:0x5902  ] ;
        :eq g2.adobe-japan1-0:04538   ; # &g2-AJ1-04538;
        :eq g2.gb2312:0x623A          ; # &g2-AJ1-04538;
        :eq g2.jis-x0208:0x5469       ; # &g2-AJ1-04538;
        :eq g2.cns11643-3:0x2139      ; # &g2-AJ1-04538;
        :eq g2.jis-x0213-1:0x5469     ; # &g2-AJ1-04538;
        :eq g2.big5-cdp:0x8B45        ; # &g2-AJ1-04538;
        :eq g2.gt:07201               ; # &g2-AJ1-04538;
        :eq g2.gt-k:00217             ; # &g2-AJ1-04538;
        :eq g2.daikanwa:05691         ; # &g2-AJ1-04538;
        :subsume
            repi.daikanwa:05691  ,
            repi.jis-x0208:0x5469 ,
            repi.adobe-japan1-6:04538 ,
            repi.big5-cdp:0x8B45 ,
            repi.cns11643-3:0x2139 ,
            repi.gt:07201        ,
            repi.ucs_unicode:0x5902 ;
        .
        g2.adobe-japan1-0:04538
              :abstract-glyph-form-of adobe-japan1-0:04538   .
        g2.gb2312:0x623A
              :abstract-glyph-form-of         gb2312:0x623A  .
        g2.jis-x0208:0x5469
              :abstract-glyph-form-of      jis-x0208:0x5469  .
        g2.cns11643-3:0x2139
              :abstract-glyph-form-of     cns11643-3:0x2139  .
        g2.jis-x0213-1:0x5469
              :abstract-glyph-form-of    jis-x0213-1:0x5469  .
        g2.big5-cdp:0x8B45
              :abstract-glyph-form-of       big5-cdp:0x8B45  .
        g2.gt:07201
              :abstract-glyph-form-of             gt:07201   .
        g2.gt-k:00217
              :abstract-glyph-form-of           gt-k:00217   .
        g2.daikanwa:05691
              :abstract-glyph-form-of       daikanwa:05691   .
        repi.daikanwa:05691
            a chisegg:glyph-image ;
            :glyph-image-of daikanwa:05691 ;
            .
        repi.jis-x0208:0x5469
            a chisegg:glyph-image ;
            :glyph-image-of jis-x0208:0x5469 ;
            :eq repi.jis-x0213-1:0x5469   ; # &R-J0-5469;
            .
            repi.jis-x0213-1:0x5469
                          :glyph-image-of    jis-x0213-1:0x5469  .
        repi.adobe-japan1-0:04538
            a chisegg:glyph-image ;
            :glyph-image-of adobe-japan1-0:04538 ;
            .
        repi.big5-cdp:0x8B45
            a chisegg:glyph-image ;
            :glyph-image-of big5-cdp:0x8B45 ;
            .
        repi.cns11643-3:0x2139
            a chisegg:glyph-image ;
            :glyph-image-of cns11643-3:0x2139 ;
            .
        repi.gt:07201
            a chisegg:glyph-image ;
            :glyph-image-of gt:07201 ;
            :eq repi.gt-k:00217           ; # &R-GT-07201;
            .
            repi.gt-k:00217
                          :glyph-image-of           gt-k:00217   .
        repi.ucs_unicode:0x5902
            a chisegg:glyph-image ;
            :glyph-image-of [ :context domain:unicode ;
                              :target     ucs:0x5902  ] ;
            .

