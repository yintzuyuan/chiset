a.ucs_component:0x531A
    a chisegg:abstract-character ;
    :abstract-character-of [ :context domain:component ;
                             :target     ucs:0x531A  ] ;
    ideo:radical          22 ; # ⼕ 
    ideo:strokes           0 ;
    ideo:total-strokes     2 ;
    :eq a.iwds-1:0209             ; # &IWDS1-209;
    .
    a.iwds-1:0209
           :abstract-character-of         iwds-1:0209    .

a.ucs:0x531A
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x531A ;
    :from.denotational_component
        a.ucs_component:0x531A ;
    ideo:radical          22 ; # ⼕ 
    ideo:strokes           0 ;
    ideo:total-strokes     2 ;
    ideo:hanyu-dazidian  ( 1 81 3 ) ;
    :eq rep.adobe-japan1-0:04302  ; # &I-AJ1-04302;
    :eq rep.jis-x0208:0x5239      ; # &I-J90-5239;
    :eq rep.gb2312:0x584E         ; # &I-G0-584E;
    :eq rep.cns11643-2:0x2124     ; # &I-C2-2124;
    :eq rep.jis-x0213-1:0x5239    ; # &I-JX1-5239;
    :eq a.big5:0xC943             ; # &I-B-C943;
    :eq rep.gt:03325              ; # &I-GT-03325;
    :eq rep.gt-k:00097            ; # &I-GT-K00097;
    :eq rep.gt-pj-1:21049         ; # &I-GT-03325;
    :eq rep.daikanwa:02595        ; # &I-M-02595;
    :eq rep.shinjigen:0786        ; # 匚
    :subsume
        g2.ucs_unicode:0x531A ;
    .
    rep.adobe-japan1-0:04302
               :abstract-glyph-of adobe-japan1-0:04302   .
    rep.jis-x0208:0x5239
               :abstract-glyph-of      jis-x0208:0x5239  .
    rep.gb2312:0x584E
               :abstract-glyph-of         gb2312:0x584E  .
    rep.cns11643-2:0x2124
               :abstract-glyph-of     cns11643-2:0x2124  .
    rep.jis-x0213-1:0x5239
               :abstract-glyph-of    jis-x0213-1:0x5239  .
    a.big5:0xC943
           :abstract-character-of           big5:0xC943  .
    rep.gt:03325
               :abstract-glyph-of             gt:03325   .
    rep.gt-k:00097
               :abstract-glyph-of           gt-k:00097   .
    rep.gt-pj-1:21049
               :abstract-glyph-of        gt-pj-1:21049   .
    rep.daikanwa:02595
               :abstract-glyph-of       daikanwa:02595   .
    rep.shinjigen:0786
               :abstract-glyph-of      shinjigen:0786    .
    g2.ucs_unicode:0x531A
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of [ :context domain:unicode ;
                                  :target     ucs:0x531A  ] ;
        :eq g2.adobe-japan1-0:04302   ; # &g2-AJ1-04302;
        :eq g2.gb2312:0x584E          ; # &g2-AJ1-04302;
        :eq g2.jis-x0208:0x5239       ; # &g2-AJ1-04302;
        :eq g2.cns11643-2:0x2124      ; # &g2-AJ1-04302;
        :eq g2.jis-x0213-1:0x5239     ; # &g2-AJ1-04302;
        :eq g2.gt:03325               ; # &g2-AJ1-04302;
        :eq g2.gt-k:00097             ; # &g2-AJ1-04302;
        :eq g2.daikanwa:02595         ; # &g2-AJ1-04302;
        :eq g2.shinjigen:0786         ; # &g2-AJ1-04302;
        :subsume
            repi.daikanwa:02595  ,
            repi.jis-x0208:0x5239 ,
            repi.adobe-japan1-6:04302 ,
            repi.cns11643-2:0x2124 ,
            repi.gt:03325        ,
            repi.ucs_unicode:0x531A ;
        .
        g2.adobe-japan1-0:04302
              :abstract-glyph-form-of adobe-japan1-0:04302   .
        g2.gb2312:0x584E
              :abstract-glyph-form-of         gb2312:0x584E  .
        g2.jis-x0208:0x5239
              :abstract-glyph-form-of      jis-x0208:0x5239  .
        g2.cns11643-2:0x2124
              :abstract-glyph-form-of     cns11643-2:0x2124  .
        g2.jis-x0213-1:0x5239
              :abstract-glyph-form-of    jis-x0213-1:0x5239  .
        g2.gt:03325
              :abstract-glyph-form-of             gt:03325   .
        g2.gt-k:00097
              :abstract-glyph-form-of           gt-k:00097   .
        g2.daikanwa:02595
              :abstract-glyph-form-of       daikanwa:02595   .
        g2.shinjigen:0786
              :abstract-glyph-form-of      shinjigen:0786    .
        repi.daikanwa:02595
            a chisegg:glyph-image ;
            :glyph-image-of daikanwa:02595 ;
            .
        repi.jis-x0208:0x5239
            a chisegg:glyph-image ;
            :glyph-image-of jis-x0208:0x5239 ;
            :eq repi.jis-x0213-1:0x5239   ; # &R-J0-5239;
            .
            repi.jis-x0213-1:0x5239
                          :glyph-image-of    jis-x0213-1:0x5239  .
        repi.adobe-japan1-0:04302
            a chisegg:glyph-image ;
            :glyph-image-of adobe-japan1-0:04302 ;
            .
        repi.cns11643-2:0x2124
            a chisegg:glyph-image ;
            :glyph-image-of cns11643-2:0x2124 ;
            .
        repi.gt:03325
            a chisegg:glyph-image ;
            :glyph-image-of gt:03325 ;
            :eq repi.gt-k:00097           ; # &R-GT-03325;
            .
            repi.gt-k:00097
                          :glyph-image-of           gt-k:00097   .
        repi.ucs_unicode:0x531A
            a chisegg:glyph-image ;
            :glyph-image-of [ :context domain:unicode ;
                              :target     ucs:0x531A  ] ;
            .

a.ucs:0x2092C
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x2092C ;
    ideo:radical           [ :context domain:ucs     ;
                             :target           22 ; # ⼕
                           ] ;
    ideo:radical           [ :context domain:cns     ;
                             :target           23 ; # ⼖
                           ] ;
    ideo:strokes           0 ;
    ideo:total-strokes     2 ;
    ideo:hanyu-dazidian  ( 1 50 2 ) ;
    :subsume
        rep.ucs_iso:0x2092C  ,
        rep.cns11643-6:0x212B ;
    .
    rep.ucs_iso:0x2092C
        a chisegg:abstract-glyph ;
        :abstract-glyph-of [ :context domain:iso     ;
                             :target     ucs:0x2092C ] ;
        :eq rep.big5-cdp:0x87D4       ; # &CDP-87D4;
        :eq rep.daikanwa:02596        ; # &I-M-02596;
        .
        rep.big5-cdp:0x87D4
                   :abstract-glyph-of       big5-cdp:0x87D4  .
        rep.daikanwa:02596
                   :abstract-glyph-of       daikanwa:02596   .
    rep.cns11643-6:0x212B
        a chisegg:abstract-glyph ;
        :abstract-glyph-of cns11643-6:0x212B ;
        .

a.ucs:0x531B
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x531B ;
    ideo:radical          22 ; # ⼕ 
    ideo:strokes           3 ;
