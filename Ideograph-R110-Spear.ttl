a.ucs:0x77DB
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x77DB ;
    ideo:radical         110 ; # ⽭ 
    ideo:strokes           0 ;
    ideo:total-strokes     5 ;
    :eq rep.adobe-japan1-0:03779  ; # &I-AJ1-03779;
    :eq rep.jis-x0208:0x4C37      ; # &I-J90-4C37;
    :eq rep.gb2312:0x432C         ; # &I-G0-432C;
    :eq rep.ks-x1001:0x5943       ; # &I-K0-5943;
    :eq rep.cns11643-1:0x4679     ; # &I-C1-4679;
    :eq rep.jis-x0213-1:0x4C37    ; # &I-JX1-4C37;
    :eq a.big5:0xA5D9             ; # &I-B-A5D9;
    :eq rep.gt:30525              ; # &I-GT-30525;
    :eq rep.gt-k:01009            ; # &I-GT-K01009;
    :eq rep.gt-pj-1:19511         ; # &I-GT-30525;
    :eq rep.daikanwa:23846        ; # &I-M-23846;
    :eq rep.shinjigen_rev:5384    ; # 矛
    .
    rep.adobe-japan1-0:03779
               :abstract-glyph-of adobe-japan1-0:03779   .
    rep.jis-x0208:0x4C37
