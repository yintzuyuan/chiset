    ideo:strokes           0 ;
    ideo:total-strokes     7 ;
    :eq rep.adobe-japan1-0:02914  ; # &I-AJ1-02914;
    :eq rep.jis-x0208:0x4324      ; # &I-J90-4324;
    :eq rep.gb2312:0x333D         ; # &I-G0-333D;
