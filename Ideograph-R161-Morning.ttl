    :eq rep.daikanwa:38682        ; # &I-M-38682;
    :eq rep.shinjigen:8205        ; # 辰
    :subsume
        g2.adobe-japan1-0:02914 ,
        g2.ucs_unicode:0x8FB0 ;
    .
