a.ucs_component:0x5C6E
    a chisegg:abstract-character ;
    :abstract-character-of [ :context domain:component ;
                             :target     ucs:0x5C6E  ] ;
    ideo:radical          45 ; # ⼬ 
    ideo:strokes           0 ;
    ideo:total-strokes     3 ;
    :eq a.iwds-1:0096             ; # &IWDS1-096;
    .
    a.iwds-1:0096
           :abstract-character-of         iwds-1:0096    .

a.ucs:0x5C6E
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x5C6E ;
    :from.denotational_component
        a.ucs_component:0x5C6E ;
    ideo:radical          45 ; # ⼬ 
    ideo:strokes           0 ;
    ideo:total-strokes     3 ;
    :eq a.big5:0xC94B             ; # &I-B-C94B;
    .
    a.big5:0xC94B
           :abstract-character-of           big5:0xC94B  .

a.ucs:0xFA3C
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0xFA3C ;
    :denotation-of
        a.ucs:0x5C6E         ;
    :to.canonical-ucs	a.ucs:0x5C6E ; # 屮
    ideo:radical          45 ; # ⼬ 
    ideo:strokes           0 ;
    ideo:total-strokes     3 ;
    :rep.decomposition   [ :context domain:cid     ;
                           :target  a.ucs:0x5C6E         ,
                                    a.ucs:0xE0100        ] ;
    :eq rep.ucs_unicode:0x5C6E    ; # 屮
    :eq rep.ucs_jis:0xFA3C        ; # 屮
    :eq rep.adobe-japan1-5:16837  ; # &I-AJ1-16837;
    :eq rep.gb2312:0x6578         ; # &I-G0-6578;
    :eq rep.cns11643-2:0x212B     ; # &I-C2-212B;
    :eq rep.jis-x0213-1:0x4F62    ; # &I-JX1-4F62;
    :eq rep.gt-k:00269            ; # &I-GT-K00269;
    :eq rep.gt-pj-k1:14959        ; # 屮
    :eq rep.daikanwa:07825        ; # &I-M-07825;
    .
    rep.ucs_unicode:0x5C6E
               :abstract-glyph-of [ :context domain:unicode ;
                                    :target     ucs:0x5C6E  ] .
    rep.ucs_jis:0xFA3C
               :abstract-glyph-of [ :context domain:jis     ;
                                    :target     ucs:0xFA3C  ] .
    rep.adobe-japan1-5:16837
               :abstract-glyph-of adobe-japan1-5:16837   .
    rep.gb2312:0x6578
               :abstract-glyph-of         gb2312:0x6578  .
    rep.cns11643-2:0x212B
               :abstract-glyph-of     cns11643-2:0x212B  .
    rep.jis-x0213-1:0x4F62
               :abstract-glyph-of    jis-x0213-1:0x4F62  .
    rep.gt-k:00269
               :abstract-glyph-of           gt-k:00269   .
    rep.gt-pj-k1:14959
               :abstract-glyph-of       gt-pj-k1:14959   .
    rep.daikanwa:07825
               :abstract-glyph-of       daikanwa:07825   .

a.ucs:0x2F878
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x2F878 ;
    :denotation-of
        a.ucs:0x5C6E         ;
    :to.canonical-ucs	a.ucs:0x5C6E ; # 屮
    ideo:radical          45 ; # ⼬ 
    ideo:strokes           0 ;
    ideo:total-strokes     3 ;
    :eq rep.ucs_jis:0x5C6E        ; # 屮
    :eq rep.adobe-japan1-0:04658  ; # &I-AJ1-04658;
    :eq rep.jis-x0208:0x5625      ; # &I-J90-5625;
    :eq rep.cns11643-4:0x2135     ; # &I-C4-2135;
    :eq rep.jis-x0213-1:0x5625    ; # &I-JX1-5625;
    :eq rep.big5-cdp:0x8D6A       ; # &I-CDP-8D6A;
    :eq rep.gt:09850              ; # &I-GT-09850;
    :eq rep.gt-k:00270            ; # &I-GT-K00270;
    :eq rep.gt-pj-1:22053         ; # &I-GT-09850;
    :eq rep.daikanwa:07826        ; # &I-M-07826;
    :to.mistakable       [ :sources chisebib:daikanwa ;
                           :target  a.ucs:0xFA3C         ] ;
    :subsume
        g2.ucs_iso:0x2F878   ;
    .
    rep.ucs_jis:0x5C6E
               :abstract-glyph-of [ :context domain:jis     ;
                                    :target     ucs:0x5C6E  ] .
    rep.adobe-japan1-0:04658
               :abstract-glyph-of adobe-japan1-0:04658   .
    rep.jis-x0208:0x5625
               :abstract-glyph-of      jis-x0208:0x5625  .
    rep.cns11643-4:0x2135
               :abstract-glyph-of     cns11643-4:0x2135  .
    rep.jis-x0213-1:0x5625
               :abstract-glyph-of    jis-x0213-1:0x5625  .
    rep.big5-cdp:0x8D6A
               :abstract-glyph-of       big5-cdp:0x8D6A  .
    rep.gt:09850
               :abstract-glyph-of             gt:09850   .
    rep.gt-k:00270
               :abstract-glyph-of           gt-k:00270   .
    rep.gt-pj-1:22053
               :abstract-glyph-of        gt-pj-1:22053   .
    rep.daikanwa:07826
               :abstract-glyph-of       daikanwa:07826   .
    g2.ucs_iso:0x2F878
        a chisegg:abstract-glyph-form ;
        :abstract-glyph-form-of [ :context domain:iso     ;
                                  :target     ucs:0x2F878 ] ;
        :rep.decomposition   [ :context domain:cid     ;
                               :target  a.ucs:0x5C6E         ,
                                        a.ucs:0xE0101        ] ;
        :eq g2.ucs_jis:0x5C6E         ; # &g2-AJ1-04658;
        :eq g2.adobe-japan1-0:04658   ; # &g2-AJ1-04658;
        :eq g2.jis-x0208:0x5625       ; # &g2-AJ1-04658;
        :eq g2.cns11643-4:0x2135      ; # &g2-AJ1-04658;
        :eq g2.jis-x0213-1:0x5625     ; # &g2-AJ1-04658;
        :eq g2.big5-cdp:0x8D6A        ; # &g2-AJ1-04658;
        :eq g2.gt:09850               ; # &g2-AJ1-04658;
        :eq g2.gt-k:00270             ; # &g2-AJ1-04658;
        :eq g2.daikanwa:07826         ; # &g2-AJ1-04658;
        :subsume
            repi.daikanwa:07826  ,
            repi.jis-x0208:0x5625 ,
            repi.adobe-japan1-6:04658 ,
            repi.big5-cdp:0x8D6A ,
            repi.cns11643-4:0x2135 ,
            repi.gt:09850        ,
            repi.ucs_iso:0x2F878 ;
        .
        g2.ucs_jis:0x5C6E
              :abstract-glyph-form-of [ :context domain:jis     ;
                                        :target     ucs:0x5C6E  ] .
        g2.adobe-japan1-0:04658
              :abstract-glyph-form-of adobe-japan1-0:04658   .
        g2.jis-x0208:0x5625
              :abstract-glyph-form-of      jis-x0208:0x5625  .
        g2.cns11643-4:0x2135
              :abstract-glyph-form-of     cns11643-4:0x2135  .
        g2.jis-x0213-1:0x5625
              :abstract-glyph-form-of    jis-x0213-1:0x5625  .
        g2.big5-cdp:0x8D6A
              :abstract-glyph-form-of       big5-cdp:0x8D6A  .
        g2.gt:09850
              :abstract-glyph-form-of             gt:09850   .
        g2.gt-k:00270
              :abstract-glyph-form-of           gt-k:00270   .
        g2.daikanwa:07826
              :abstract-glyph-form-of       daikanwa:07826   .
        repi.daikanwa:07826
            a chisegg:glyph-image ;
            :glyph-image-of daikanwa:07826 ;
            .
        repi.jis-x0208:0x5625
            a chisegg:glyph-image ;
            :glyph-image-of jis-x0208:0x5625 ;
            :eq repi.jis-x0213-1:0x5625   ; # &R-J0-5625;
            .
            repi.jis-x0213-1:0x5625
                          :glyph-image-of    jis-x0213-1:0x5625  .
        repi.adobe-japan1-0:04658
            a chisegg:glyph-image ;
            :glyph-image-of adobe-japan1-0:04658 ;
            .
        repi.big5-cdp:0x8D6A
            a chisegg:glyph-image ;
            :glyph-image-of big5-cdp:0x8D6A ;
