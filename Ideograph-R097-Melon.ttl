bucs:0x74DC
    a chisegg:super-abstract-character ;
    :super-abstract-character-of [ :context domain:bucs    ;
                                   :target     ucs:0x74DC  ] ;
    ideo:radical          97 ; # ⽠ 
    ideo:strokes           0 ;
    .

a.ucs:0x74DC
    a chisegg:abstract-character ;
    :abstract-character-of ucs:0x74DC ;
    :denotation-of
        bucs:0x74DC          ;
    ideo:radical          97 ; # ⽠ 
    ideo:strokes           0 ;
    ideo:total-strokes     5 ;
    :eq a.big5:0xA5CA             ; # &I-B-A5CA;
    :subsume
        rep.gb2312:0x394F    ,
        rep.adobe-japan1-0:01245 ,
        rep.cns11643-1:0x466A ;
    .
    a.big5:0xA5CA
           :abstract-character-of           big5:0xA5CA  .
    rep.gb2312:0x394F
        a chisegg:abstract-glyph ;
        :abstract-glyph-of gb2312:0x394F ;
        :eq rep.ucs_unicode:0x74DC    ; # &G0-394F;
        :rep.ucs_JP...hanazono     rdf:nil ;
        :eq rep.daikanwa:21371        ; # &I-M-21371;
        :subsume
            g2.daikanwa:21371    ,
            g2.ucs_unicode:0x74DC ;
        .
        rep.ucs_unicode:0x74DC
                   :abstract-glyph-of [ :context domain:unicode ;
                                        :target     ucs:0x74DC  ] .
        rep.daikanwa:21371
                   :abstract-glyph-of       daikanwa:21371   .
        g2.daikanwa:21371
            a chisegg:abstract-glyph-form ;
            :abstract-glyph-form-of daikanwa:21371 ;
            .
        g2.ucs_unicode:0x74DC
            a chisegg:abstract-glyph-form ;
            :abstract-glyph-form-of [ :context domain:unicode ;
                                      :target     ucs:0x74DC  ] ;
            :g2.ucs_JP...hanazono      rdf:nil ;
            :eq g2.gb2312:0x394F          ; # &g2-UU+74DC;
            .
            g2.gb2312:0x394F
                  :abstract-glyph-form-of         gb2312:0x394F  .
    rep.adobe-japan1-0:01245
        a chisegg:abstract-glyph ;
        :abstract-glyph-of adobe-japan1-0:01245 ;
        :eq rep.ucs_jis:0x74DC        ; # &AJ1-01245;
        :eq rep.ucs_ks:0x74DC         ; # &AJ1-01245;
        :eq rep.jis-x0208:0x313B      ; # &I-J90-313B;
        :eq rep.ks-x1001:0x4D7E       ; # &I-K0-4D7E;
        :eq rep.jis-x0213-1:0x313B    ; # &I-JX1-313B;
        :eq rep.hanyo-denshi...ja:0x313B ; # &I-HD-JA-313B;
        :eq rep.gt:27382              ; # &I-GT-27382;
        :eq rep.gt-k:01570            ; # &I-GT-K01570;
        :eq rep.gt-pj-1:12603         ; # &I-GT-27382;
        :subsume
            g2.adobe-japan1-0:01245 ;
        .
        rep.ucs_jis:0x74DC
                   :abstract-glyph-of [ :context domain:jis     ;
                                        :target     ucs:0x74DC  ] .
        rep.ucs_ks:0x74DC
                   :abstract-glyph-of [ :context domain:ks      ;
                                        :target     ucs:0x74DC  ] .
        rep.jis-x0208:0x313B
                   :abstract-glyph-of      jis-x0208:0x313B  .
        rep.ks-x1001:0x4D7E
                   :abstract-glyph-of       ks-x1001:0x4D7E  .
        rep.jis-x0213-1:0x313B
                   :abstract-glyph-of    jis-x0213-1:0x313B  .
        rep.hanyo-denshi...ja:0x313B
                   :abstract-glyph-of hanyo-denshi...ja:0x313B  .
        rep.gt:27382
                   :abstract-glyph-of             gt:27382   .
        rep.gt-k:01570
                   :abstract-glyph-of           gt-k:01570   .
        rep.gt-pj-1:12603
                   :abstract-glyph-of        gt-pj-1:12603   .
        g2.adobe-japan1-0:01245
            a chisegg:abstract-glyph-form ;
            :abstract-glyph-form-of adobe-japan1-0:01245 ;
            :rep.decomposition   [ :context domain:hanyo-denshi ;
                                   :target  a.ucs:0x74DC         ,
                                            a.ucs:0xE0102        ] ;
            :eq g2.ucs_jis:0x74DC         ; # &g2-AJ1-01245;
            :eq g2.ucs_ks:0x74DC          ; # &g2-AJ1-01245;
            :eq g2.ks-x1001:0x4D7E        ; # &g2-AJ1-01245;
            :eq g2.jis-x0208:0x313B       ; # &g2-AJ1-01245;
            :eq g2.jis-x0213-1:0x313B     ; # &g2-AJ1-01245;
            :eq g2.hanyo-denshi...ja:0x313B ; # &g2-AJ1-01245;
            :eq g2.gt:27382               ; # &g2-AJ1-01245;
            :eq g2.gt-k:01570             ; # &g2-AJ1-01245;
            :subsume
                repi.jis-x0208:0x313B ,
                repi.adobe-japan1-6:01245 ,
                repi.gt:27382        ,
                repi.ks-x1001:0x4D7E ;
            .
            g2.ucs_jis:0x74DC
                  :abstract-glyph-form-of [ :context domain:jis     ;
                                            :target     ucs:0x74DC  ] .
            g2.ucs_ks:0x74DC
                  :abstract-glyph-form-of [ :context domain:ks      ;
                                            :target     ucs:0x74DC  ] .
            g2.ks-x1001:0x4D7E
                  :abstract-glyph-form-of       ks-x1001:0x4D7E  .
            g2.jis-x0208:0x313B
                  :abstract-glyph-form-of      jis-x0208:0x313B  .
            g2.jis-x0213-1:0x313B
                  :abstract-glyph-form-of    jis-x0213-1:0x313B  .
            g2.hanyo-denshi...ja:0x313B
                  :abstract-glyph-form-of hanyo-denshi...ja:0x313B  .
            g2.gt:27382
                  :abstract-glyph-form-of             gt:27382   .
            g2.gt-k:01570
                  :abstract-glyph-form-of           gt-k:01570   .
            repi.jis-x0208:0x313B
                a chisegg:glyph-image ;
                :glyph-image-of jis-x0208:0x313B ;
                :eq repi.jis-x0213-1:0x313B   ; # &R-J0-313B;
                .
                repi.jis-x0213-1:0x313B
                              :glyph-image-of    jis-x0213-1:0x313B  .
            repi.adobe-japan1-0:01245
                a chisegg:glyph-image ;
                :glyph-image-of adobe-japan1-0:01245 ;
                .
            repi.gt:27382
                a chisegg:glyph-image ;
                :glyph-image-of gt:27382 ;
                :eq repi.gt-k:01570           ; # &R-GT-27382;
                .
                repi.gt-k:01570
                              :glyph-image-of           gt-k:01570   .
            repi.ks-x1001:0x4D7E
                a chisegg:glyph-image ;
                :glyph-image-of ks-x1001:0x4D7E ;
                :eq repi.ucs_ks:0x74DC        ; # &R-K0-4D7E;
                .
                repi.ucs_ks:0x74DC
                              :glyph-image-of [ :context domain:ks      ;
                                                :target     ucs:0x74DC  ] .
